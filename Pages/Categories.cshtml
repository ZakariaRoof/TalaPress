        // Clean & update icon preview text
        function updateIconPreview(iconClass) {
            const preview = document.getElementById('form-icon-preview');
            let cleanClass = iconClass.trim();
            if (!cleanClass) {
                cleanClass = 'bi-folder-fill';
            }
            if (!cleanClass.startsWith('bi-') && !cleanClass.startsWith('bi ')) {
                cleanClass = 'bi-' + cleanClass;
            }
            preview.innerHTML = `<i class="bi ${cleanClass}"></i>`;
            
            // Mark corresponding grid icon as selected
            document.querySelectorAll('.tp-icon-select-box').forEach(box => {
                if (box.title === cleanClass) {
                    box.classList.add('selected');
                } else {
                    box.classList.remove('selected');
                }
            });
        }

        // Triggers category deletion post form
        function deleteCategory(id, name) {
            // Check if this category has subcategories locally first
            const hasSubcategories = rawCategories.some(c => Number(c.ParentId) === Number(id));
            if (hasSubcategories) {
                alert(pageTranslations[currentLang].errorDeleteChildren);
                return;
            }
            
            const confirmMsg = pageTranslations[currentLang].confirmDelete.replace('{0}', name) || `Are you sure you want to delete ${name}?`;
            if (confirm(confirmMsg)) {
                document.getElementById('delete-id-input').value = id;
                document.getElementById('deleteForm').submit();
            }
        }

        // Robust slugifier logic supporting multi-language defaults
        function slugify(text) {
            return text
                .toString()
                .toLowerCase()
                .replace(/[^\w\s-]/g, '') // Remove special chars
                .replace(/[\s_]+/g, '-')  // Replace spaces/underscores with dashes
                .replace(/^-+|-+$/g, ''); // Trim leading/trailing dashes
        }

        // SortableJS Drag & Drop Initialization
        function initSortable() {
            const lists = document.querySelectorAll('.tp-tree-list');
            lists.forEach(list => {
                new Sortable(list, {
                    group: {
                        name: 'nested-categories',
                        pull: true,
                        put: true
                    },
                    animation: 200,
                    fallbackOnBody: true,
                    swapThreshold: 0.65,
                    handle: '.tp-drag-handle', // drag only by handle
                    ghostClass: 'tp-sortable-ghost',
                    chosenClass: 'tp-sortable-chosen',
                    dragClass: 'tp-sortable-drag',
                    onStart: function (evt) {
                        document.body.classList.add('dragging-active');
                    },
                    onEnd: function (evt) {
                        document.body.classList.remove('dragging-active');
                        saveDomOrder();
                    }
                });
            });
        }

        // Parse DOM tree structure to save parentage and order
        function saveDomOrder() {
            const originalState = rawCategories.map(c => ({
                Id: c.Id,
                ParentId: c.ParentId,
                SortOrder: c.SortOrder
            }));

            // Recursive DOM scanner
            function scanList(ulElement, parentId = null) {
                const liElements = ulElement.querySelectorAll(':scope > .tp-tree-item');
                liElements.forEach((li, index) => {
                    const id = Number(li.getAttribute('id').replace('node-', ''));
                    const cat = rawCategories.find(c => Number(c.Id) === id);
                    if (cat) {
                        cat.ParentId = parentId;
                        cat.SortOrder = index;
                    }
                    
                    const childUl = li.querySelector(':scope > .tp-tree-list');
                    if (childUl) {
                        scanList(childUl, id);
                    }
                });
            }

            // Target the root list inside tree-root
            const rootUl = document.querySelector('#tree-root > .tp-tree-list');
            if (rootUl) {
                scanList(rootUl, null);
            }

            // Extract changes
            const changedItems = [];
            rawCategories.forEach(c => {
                const orig = originalState.find(o => Number(o.Id) === Number(c.Id));
                if (orig && (orig.ParentId !== c.ParentId || orig.SortOrder !== c.SortOrder)) {
                    changedItems.push({
                        Id: c.Id,
                        ParentId: c.ParentId,
                        SortOrder: c.SortOrder
                    });
                }
            });

            // Re-render the tree with the new changes and update forms
            const searchVal = document.getElementById('tree-search').value.trim();
            renderTree(searchVal);
            syncStateToForm();

            // Send changed records only
            if (changedItems.length > 0) {
                sendReorderDataToServer(changedItems);
            }
        }

        // Send updates using AJAX POST to the reorder handler
        function sendReorderDataToServer(changedItems) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            // Show saving toast loading spinner
            showToast(currentLang === 'ar' ? 'جاري حفظ الترتيب الجديد...' : 'Saving new sort order...', 'info', true);

            fetch('?handler=Reorder', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token,
                    'X-Request-Verification-Token': token
                },
                body: JSON.stringify(changedItems)
            })
            .then(response => response.json())
            .then(data => {
                // Clear any loading toasts
                clearLoadingToasts();
                
                if (data.success) {
                    showToast(currentLang === 'ar' ? 'تم حفظ الترتيب الجديد بنجاح.' : 'Sort order updated successfully.', 'success');
                    
                    // Update client state and reload tree from server response!
                    if (data.categories) {
                        // Defensively map keys from camelCase/PascalCase to ensure compatibility
                        const mappedCategories = data.categories.map(c => ({
                            Id: c.Id !== undefined ? c.Id : c.id,
                            Name: c.Name !== undefined ? c.Name : c.name,
                            Name_En: c.Name_En !== undefined ? c.Name_En : (c.name_En !== undefined ? c.name_En : (c.nameEn !== undefined ? c.nameEn : c.name_en)),
                            Slug: c.Slug !== undefined ? c.Slug : c.slug,
                            ParentId: c.ParentId !== undefined ? c.ParentId : c.parentId,
                            IconValue: c.IconValue !== undefined ? c.IconValue : c.iconValue,
                            Image: c.Image !== undefined ? c.Image : c.image,
                            SortOrder: c.SortOrder !== undefined ? c.SortOrder : c.sortOrder,
                            IsActive: c.IsActive !== undefined ? c.IsActive : c.isActive,
                            CreatedAt: c.CreatedAt !== undefined ? c.CreatedAt : c.createdAt,
                            UpdatedAt: c.UpdatedAt !== undefined ? c.UpdatedAt : c.updatedAt
                        }));

                        rawCategories.length = 0;
                        rawCategories.push(...mappedCategories);
                        renderTree(document.getElementById('tree-search').value.trim());
                        syncStateToForm();
                    }
                } else {
                    showToast((currentLang === 'ar' ? 'فشل حفظ الترتيب: ' : 'Failed to save sort order: ') + data.message, 'danger');
                }
            })
            .catch(err => {
                clearLoadingToasts();
                showToast((currentLang === 'ar' ? 'حدث خطأ في الاتصال: ' : 'Network connection error: ') + err.message, 'danger');
            });
        }

        // Float-toast status feedback notifications system
        function showToast(message, type = 'success', isLoading = false) {
            const toastContainer = document.getElementById('toast-container') || createToastContainer();
            const toast = document.createElement('div');
            toast.className = `alert alert-${type} alert-dismissible fade show border-0 shadow-sm rounded-3 mb-2`;
            toast.style.minWidth = '300px';
            toast.style.boxShadow = '0 4px 12px rgba(0,0,0,0.1)';
            if (isLoading) {
                toast.classList.add('tp-loading-toast');
            }

            const iconClass = type === 'info' ? 'bi-info-circle-fill text-info' : 
                             (type === 'success' ? 'bi-check-circle-fill text-success' : 'bi-exclamation-triangle-fill text-danger');

            toast.innerHTML = `
                <div class="d-flex align-items-center">
                    ${isLoading ? `<div class="spinner-border spinner-border-sm text-info me-2" role="status"></div>` : `<i class="bi ${iconClass} me-2 fs-5"></i>`}
                    <div class="fw-bold">${message}</div>
                </div>
                ${isLoading ? '' : `<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>`}
            `;
            toastContainer.appendChild(toast);

            if (!isLoading) {
                setTimeout(() => {
                    const bsAlert = new bootstrap.Alert(toast);
                    bsAlert.close();
                }, 4000);
            }
        }

        function clearLoadingToasts() {
            document.querySelectorAll('.tp-loading-toast').forEach(toast => {
                const bsAlert = new bootstrap.Alert(toast);
                bsAlert.close();
            });
        }

        function createToastContainer() {
            const container = document.createElement('div');
            container.id = 'toast-container';
            container.style.position = 'fixed';
            container.style.top = '24px';
            container.style.right = currentLang === 'ar' ? 'auto' : '24px';
            container.style.left = currentLang === 'ar' ? '24px' : 'auto';
            container.style.zIndex = '9999';
            document.body.appendChild(container);
            return container;
        }
    </script>
}
