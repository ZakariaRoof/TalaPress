@page
@using System.Text.Json
@model TalaPress.Pages.ContentEditModel
@{
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "إنشاء محتوى" : "تعديل المحتوى";
    var seoFieldNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "SeoTitle", "SeoDescription", "SeoKeywords", "CanonicalUrl"
    };
    var activeSeoFields = Model.ContentFieldsList
        .Where(f => f.IsActive && seoFieldNames.Contains(f.FieldName))
        .OrderBy(f => f.SortOrder)
        .ToList();
}

@section Styles {
  <!-- Quill Rich Text Editor CSS -->
  <link rel="stylesheet" href="~/assets/css/quill.snow.css" asp-append-version="true">
  <style>
    .ql-editor {
      min-height: 200px;
    }
    .tp-uploader-dropzone:hover {
      border-color: var(--tp-primary) !important;
      background-color: rgba(var(--tp-primary-rgb), 0.05) !important;
    }
    .tp-uploader-dropzone.dragover {
      border-color: var(--tp-success) !important;
      background-color: rgba(var(--tp-success-rgb), 0.1) !important;
    }
  </style>
}

<!-- SECONDARY HEADER (BLUE BAR) -->
<section class="tp-sub-header">
  <div class="container-fluid px-4">
    <div class="row align-items-center">
      <div class="col-md-7 mb-3 mb-md-0">
        <h1>
          <span class="tp-only-ar">@(isNew ? $"إنشاء محتوى جديد: {Model.ContentTypeName}" : $"تعديل المحتوى: {Model.Title}")</span>
          <span class="tp-only-en">@(isNew ? $"Create New Content: {Model.ContentTypeNameEn}" : $"Edit Content: {Model.Title_En ?? Model.Title}")</span>
        </h1>
        <p data-page-i18n="subHeaderDesc">قم بتعبئة بيانات المنشور وحفظها مباشرة، يتطابق الترتيب والتصميم مع الإعدادات المهيأة مسبقاً.</p>
      </div>
      <div class="col-md-5 text-md-end d-flex align-items-center justify-content-md-end gap-2">
        <!-- Quick Content Type Switcher -->
        <div class="d-flex align-items-center gap-1 bg-primary-subtle text-primary-emphasis px-2 py-1 rounded border border-primary-subtle">
          <i class="bi bi-folder-fill fs-7"></i>
          <span class="fs-8 fw-bold me-1" data-page-i18n="switchTypeLabel">النوع:</span>
          <select class="form-select form-select-sm border-0 bg-transparent p-0 fs-8 fw-bold" id="contentTypeSwitcher" style="width: auto; box-shadow: none;">
            @foreach (var type in Model.AllContentTypes)
            {
                <option value="@type.Id" selected="@(type.Id == Model.ContentTypeId ? "selected" : null)">
                  <span class="tp-only-ar">@type.Name</span>
                  <span class="tp-only-en">@type.Name_En</span>
                </option>
            }
          </select>
        </div>
        
        <a asp-page="/Content" class="btn btn-sm btn-outline-light">
          <i class="bi bi-arrow-right-short fs-6 align-middle"></i> <span data-page-i18n="btnBack">الرجوع للمحتوى</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- MAIN CONTAINER -->
<main class="container-fluid px-4 pb-5">
  <form id="contentForm" method="post" onsubmit="saveContentForm(event)">
    <input type="hidden" asp-for="Id" id="form-Id" />
    <input type="hidden" asp-for="ContentTypeId" id="form-ContentTypeId" />

    <div class="row">
      <!-- LEFT COLUMN: Dynamic Fields Sequence -->
      <div class="col-lg-8 mb-4">
        <div class="tp-card mb-0">
          <div class="tp-card-header d-flex align-items-center justify-content-between">
            <h5>
              <i class="bi bi-layers-half text-primary me-2"></i>
              <span data-page-i18n="formFieldsTitle">حقول استمارة المحتوى الديناميكية</span>
            </h5>
            <span class="badge bg-primary rounded-pill">@Model.ContentFieldsList.Count(f => f.IsActive) <span data-page-i18n="badgeFieldsCount">حقل نشط</span></span>
          </div>
          
          <div class="tp-card-body">
            <!-- Dynamic Sequenced Fields Wrapper -->
            <div class="d-flex flex-column gap-4" id="dynamic-fields-wrapper">
              
              @foreach (var field in Model.ContentFieldsList.Where(f => f.IsActive))
              {
                  var isSystem = field.IsSystemField;
                  var fieldName = field.FieldName;

                  if (fieldName.Equals("CategoryId", StringComparison.OrdinalIgnoreCase) ||
                      fieldName.Equals("SubCategoryId", StringComparison.OrdinalIgnoreCase) ||
                      fieldName.Equals("Status", StringComparison.OrdinalIgnoreCase) ||
                      fieldName.Equals("PublishDate", StringComparison.OrdinalIgnoreCase) ||
                      fieldName.Equals("FeaturedImage", StringComparison.OrdinalIgnoreCase) ||
                      seoFieldNames.Contains(fieldName))
                  {
                      continue;
                  }

                  var labelTextAr = field.Label;
                  var labelTextEn = field.Label_En ?? field.Label;
                  var helpTextAr = field.HelpText ?? string.Empty;
                  var helpTextEn = field.HelpText_En ?? field.HelpText ?? string.Empty;
                  var isRequired = field.IsRequired;
                  
                  <div class="dynamic-field-row p-3 rounded border border-light-subtle bg-body-tertiary" data-fieldname="@fieldName" data-fieldtype="@field.FieldType">
                    
                    @if (isSystem)
                    {
                        <!-- SYSTEM STANDARD FIELDS -->
                        @if (fieldName.Equals("Title", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- TITLE FIELD -->
                            <div class="tp-only-ar">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextAr <span class="text-danger">*</span>
                                @if(!string.IsNullOrEmpty(helpTextAr)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <input type="text" asp-for="Title" class="form-control form-control-lg" required id="sys-title" />
                            </div>
                            <div class="tp-only-en">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextEn <span class="text-danger">*</span>
                                @if(!string.IsNullOrEmpty(helpTextEn)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <input type="text" asp-for="Title_En" class="form-control form-control-lg" id="sys-title-en" />
                            </div>
                        }
                        else if (fieldName.Equals("Hits", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- HITS / VISITS FIELD -->
                            <div>
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                <span class="tp-only-ar">@labelTextAr</span>
                                <span class="tp-only-en">@labelTextEn</span>
                                @if(!string.IsNullOrEmpty(helpTextAr)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <input type="number" asp-for="Hits" class="form-control" id="sys-hits" min="0" />
                            </div>
                        }
                        else if (fieldName.Equals("Slug", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- SLUG FIELD -->
                            <div>
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                <span class="tp-only-ar">
                                  @labelTextAr
                                  @if(!string.IsNullOrEmpty(helpTextAr)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                                <span class="tp-only-en">
                                  @labelTextEn
                                  @if(!string.IsNullOrEmpty(helpTextEn)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                              </label>
                              <div class="input-group input-group-sm">
                                <button type="button" class="btn btn-outline-secondary" onclick="autoGenerateSlug()" title="Generate from Title"><i class="bi bi-magic"></i></button>
                                <input type="text" asp-for="Slug" class="form-control" id="sys-slug" dir="ltr" />
                                <span class="input-group-text bg-body-secondary" dir="ltr">@($"{Request.Scheme}://{Request.Host}/p/")</span>
                              </div>
                            </div>
                        }
                        else if (fieldName.Equals("Summary", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- SUMMARY FIELD -->
                            <div class="tp-only-ar">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextAr
                                @if(!string.IsNullOrEmpty(helpTextAr)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <textarea asp-for="Summary" class="form-control" rows="3" id="sys-summary"></textarea>
                            </div>
                            <div class="tp-only-en">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextEn
                                @if(!string.IsNullOrEmpty(helpTextEn)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <textarea asp-for="Summary_En" class="form-control" rows="3" id="sys-summary-en"></textarea>
                            </div>
                        }
                        else if (fieldName.Equals("Content", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- CONTENT FIELD (QUILL RICH TEXT) -->
                            <div class="tp-only-ar">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextAr
                                @if(!string.IsNullOrEmpty(helpTextAr)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <textarea asp-for="Content" id="sys-content-input" class="form-control sn-editor" rows="6"></textarea>
                            </div>
                            <div class="tp-only-en">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextEn
                                @if(!string.IsNullOrEmpty(helpTextEn)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <textarea asp-for="Content_En" id="sys-content-en-input" class="form-control sn-editor" rows="6"></textarea>
                            </div>
                        }
                        else if (fieldName.Equals("FeaturedImage", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- FEATURED IMAGE FIELD -->
                            <div>
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                <span class="tp-only-ar">
                                  @labelTextAr
                                  @if(!string.IsNullOrEmpty(helpTextAr)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                                <span class="tp-only-en">
                                  @labelTextEn
                                  @if(!string.IsNullOrEmpty(helpTextEn)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                              </label>
                              <div class="input-group">
                                <input type="text" asp-for="FeaturedImage" class="form-control" id="sys-featuredimage" />
                                <button type="button" class="btn btn-outline-secondary" onclick="simulateMediaLibrarySelect('sys-featuredimage')" title="Browse Media"><i class="bi bi-images"></i></button>
                              </div>
                              <div class="featured-img-preview-slot mt-2" id="preview-sys-featuredimage"></div>
                            </div>
                        }
                        else if (fieldName.Equals("Status", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- STATUS FIELD -->
                            <div>
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                <span class="tp-only-ar">
                                  @labelTextAr
                                  @if(!string.IsNullOrEmpty(helpTextAr)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                                <span class="tp-only-en">
                                  @labelTextEn
                                  @if(!string.IsNullOrEmpty(helpTextEn)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                              </label>
                              <select asp-for="Status" class="form-select" id="sys-status">
                                <option value="Draft" data-label-ar="مسودة" data-label-en="Draft">Draft / مسودة</option>
                                <option value="Published" data-label-ar="منشور" data-label-en="Published">Published / منشور</option>
                                <option value="Scheduled" data-label-ar="مجدول" data-label-en="Scheduled">Scheduled / مجدول</option>
                              </select>
                            </div>
                        }
                        else if (fieldName.Equals("PublishDate", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- PUBLISH DATE FIELD -->
                            <div>
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                <span class="tp-only-ar">
                                  @labelTextAr
                                  @if(!string.IsNullOrEmpty(helpTextAr)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                                <span class="tp-only-en">
                                  @labelTextEn
                                  @if(!string.IsNullOrEmpty(helpTextEn)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                              </label>
                              <input type="datetime-local" asp-for="PublishDate" class="form-control" id="sys-publishdate" />
                            </div>
                        }
                        else if (fieldName.Equals("CategoryId", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- CATEGORY FIELD -->
                            <div>
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                <span class="tp-only-ar">
                                  @labelTextAr
                                  @if(!string.IsNullOrEmpty(helpTextAr)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                                <span class="tp-only-en">
                                  @labelTextEn
                                  @if(!string.IsNullOrEmpty(helpTextEn)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                              </label>
                              <select asp-for="CategoryId" class="form-select" id="sys-category">
                                <option value="" data-label-ar="اختر تصنيف..." data-label-en="Select Category...">اختر تصنيف...</option>
                                @foreach (var cat in Model.CategoriesList.Where(c => c.ParentId == null))
                                {
                                    <option value="@cat.Id" data-label-ar="@cat.Name" data-label-en="@(cat.Name_En ?? cat.Name)">
                                      @cat.Name
                                    </option>
                                }
                              </select>
                            </div>
                        }
                        else if (fieldName.Equals("SubCategoryId", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- SUBCATEGORY FIELD -->
                            <div>
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                <span class="tp-only-ar">
                                  @labelTextAr
                                  @if(!string.IsNullOrEmpty(helpTextAr)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                                <span class="tp-only-en">
                                  @labelTextEn
                                  @if(!string.IsNullOrEmpty(helpTextEn)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                              </label>
                              <select asp-for="SubCategoryId" class="form-select" id="sys-subcategory">
                                <option value="" data-label-ar="اختر تصنيف فرعي..." data-label-en="Select Sub-Category...">اختر تصنيف فرعي...</option>
                                @foreach (var sub in Model.CategoriesList.Where(c => c.ParentId != null))
                                {
                                    <option value="@sub.Id" data-parent="@sub.ParentId" data-label-ar="@sub.Name" data-label-en="@(sub.Name_En ?? sub.Name)">
                                      @sub.Name
                                    </option>
                                }
                              </select>
                            </div>
                        }
                        else if (fieldName.Equals("SeoTitle", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- SEO TITLE -->
                            <div class="tp-only-ar">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextAr
                                @if(!string.IsNullOrEmpty(helpTextAr)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <input type="text" asp-for="SeoTitle" class="form-control" id="sys-seotitle" />
                            </div>
                            <div class="tp-only-en">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextEn
                                @if(!string.IsNullOrEmpty(helpTextEn)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <input type="text" asp-for="SeoTitle_En" class="form-control" id="sys-seotitle-en" />
                            </div>
                        }
                        else if (fieldName.Equals("SeoDescription", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- SEO DESCRIPTION -->
                            <div class="tp-only-ar">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextAr
                                @if(!string.IsNullOrEmpty(helpTextAr)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <textarea asp-for="SeoDescription" class="form-control" rows="2" id="sys-seodescription"></textarea>
                            </div>
                            <div class="tp-only-en">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextEn
                                @if(!string.IsNullOrEmpty(helpTextEn)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <textarea asp-for="SeoDescription_En" class="form-control" rows="2" id="sys-seodescription-en"></textarea>
                            </div>
                        }
                        else if (fieldName.Equals("SeoKeywords", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- SEO KEYWORDS -->
                            <div class="tp-only-ar">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextAr
                                @if(!string.IsNullOrEmpty(helpTextAr)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <input type="text" asp-for="SeoKeywords" class="form-control" id="sys-seokeywords" />
                            </div>
                            <div class="tp-only-en">
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                @labelTextEn
                                @if(!string.IsNullOrEmpty(helpTextEn)){
                                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                          data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                    <i class="bi bi-question-circle fs-7"></i>
                                  </button>
                                }
                              </label>
                              <input type="text" asp-for="SeoKeywords_En" class="form-control" id="sys-seokeywords-en" />
                            </div>
                        }
                        else if (fieldName.Equals("CanonicalUrl", StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- CANONICAL URL -->
                            <div>
                              <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                                <span class="tp-only-ar">
                                  @labelTextAr
                                  @if(!string.IsNullOrEmpty(helpTextAr)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                                <span class="tp-only-en">
                                  @labelTextEn
                                  @if(!string.IsNullOrEmpty(helpTextEn)){
                                    <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                            data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                      <i class="bi bi-question-circle fs-7"></i>
                                    </button>
                                  }
                                </span>
                              </label>
                              <input type="url" asp-for="CanonicalUrl" class="form-control" id="sys-canonicalurl" />
                            </div>
                        }
                    }
                    else
                    {
                        <!-- CUSTOM DYNAMIC FIELDS -->
                        <div>
                          <label class="form-label fw-bold d-inline-flex align-items-center gap-1">
                            <span class="tp-only-ar">
                              @labelTextAr
                              @if(!string.IsNullOrEmpty(helpTextAr)){
                                <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                        data-bs-content="@helpTextAr" style="text-decoration: none;" title="@labelTextAr">
                                  <i class="bi bi-question-circle fs-7"></i>
                                </button>
                              }
                            </span>
                            <span class="tp-only-en">
                              @labelTextEn
                              @if(!string.IsNullOrEmpty(helpTextEn)){
                                <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                                        data-bs-content="@helpTextEn" style="text-decoration: none;" title="@labelTextEn">
                                  <i class="bi bi-question-circle fs-7"></i>
                                </button>
                              }
                            </span>
                            @if (isRequired)
                            {
                                <span class="text-danger">*</span>
                            }
                          </label>

                          @{
                              var inputName = $"custom_{fieldName}";
                              var type = field.FieldType;
                              var savedValue = Model.GetCustomFieldString(fieldName) ?? string.Empty;
                          }

                          @if (type == "Text" || type == "Url" || type == "Email" || type == "Phone")
                          {
                              var htmlType = type.ToLower();
                              if (type == "Text") htmlType = "text";
                              if (type == "Phone") htmlType = "tel";
                              <input type="@htmlType" name="@inputName" class="form-control" value="@savedValue" @(isRequired ? "required" : null) />
                          }
                          else if (type == "Number" || type == "Decimal")
                          {
                              <input type="number" step="@(type == "Decimal" ? "0.01" : "1")" name="@inputName" class="form-control" value="@savedValue" @(isRequired ? "required" : null) />
                          }
                          else if (type == "Textarea")
                          {
                              <textarea name="@inputName" class="form-control" rows="3" @(isRequired ? "required" : null)>@savedValue</textarea>
                          }
                          else if (type == "RichText")
                          {
                              <textarea name="@inputName" id="input-@fieldName" class="form-control sn-editor ql-custom-editor" rows="4" data-fieldname="@fieldName">@savedValue</textarea>
                          }
                          else if (type == "Date")
                          {
                              <input type="date" name="@inputName" class="form-control" value="@savedValue" @(isRequired ? "required" : null) />
                          }
                          else if (type == "DateTime")
                          {
                              <input type="datetime-local" name="@inputName" class="form-control" value="@savedValue" @(isRequired ? "required" : null) />
                          }
                          else if (type == "Boolean")
                          {
                              <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="@inputName" value="true" id="switch-@fieldName" @(Model.GetCustomFieldBool(fieldName) ? "checked" : null) />
                                <label class="form-check-label fw-semibold" for="switch-@fieldName">
                                  <span class="tp-only-ar">تم التفعيل</span>
                                  <span class="tp-only-en">Enabled</span>
                                </label>
                              </div>
                          }
                          else if (type == "Select" || type == "MultiSelect")
                          {
                              var isMulti = type == "MultiSelect";
                              <select name="@inputName" class="form-select" @(isMulti ? "multiple" : null) @(isRequired ? "required" : null)>
                                @if (!isMulti)
                                {
                                    <option value="" data-label-ar="اختر..." data-label-en="Choose...">اختر...</option>
                                }
                                @if (!string.IsNullOrEmpty(field.OptionsJson))
                                {
                                    var opts = JsonSerializer.Deserialize<List<SelectOptionDto>>(field.OptionsJson) ?? new();
                                    @foreach (var opt in opts)
                                    {
                                        <option value="@opt.value" data-label-ar="@opt.label" data-label-en="@(opt.labelEn ?? opt.label)">
                                          @opt.label
                                        </option>
                                    }
                                }
                              </select>
                          }
                          else if (type == "Image" || type == "Gallery" || type == "File")
                          {
                              var fileInputId = $"file-custom-{fieldName}";
                              var targetInputId = $"input-{fieldName}";
                              
                              <div class="tp-uploader-container mt-2">
                                <input type="hidden" name="@inputName" id="@targetInputId" value="@savedValue" />
                                <input type="file" id="@fileInputId" class="d-none" accept="@(type == "File" ? "*/*" : "image/*")" onchange="uploadFileAjax(this, '@targetInputId')" />
                                
                                <div class="tp-uploader-dropzone p-3 border rounded border-2 border-dashed text-center position-relative bg-body-tertiary" 
                                     onclick="document.getElementById('@fileInputId').click()" 
                                     style="cursor: pointer; transition: all 0.2s;"
                                     id="dropzone-@targetInputId">
                                     
                                  <div class="dropzone-placeholder" id="placeholder-@targetInputId">
                                    <i class="bi bi-cloud-arrow-up-fill text-secondary fs-4"></i>
                                    <div class="mt-1 fw-semibold fs-8">
                                      <span class="tp-only-ar">اسحب وأفلت الملف هنا أو انقر للاختيار</span>
                                      <span class="tp-only-en">Drag & drop file here or click to browse</span>
                                    </div>
                                  </div>
                                  
                                  <div class="dropzone-loading d-none" id="loading-@targetInputId">
                                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                    <div class="mt-1 text-muted fs-8">Uploading...</div>
                                  </div>
                                  
                                  <div class="dropzone-preview d-none position-relative" id="preview-container-@targetInputId">
                                    @if (type == "File")
                                    {
                                      <div class="p-2 border rounded bg-body-secondary d-flex align-items-center justify-content-between">
                                        <span class="fs-8 text-truncate" id="file-name-@targetInputId">File</span>
                                        <i class="bi bi-file-earmark-check-fill text-success fs-5"></i>
                                      </div>
                                    }
                                    else
                                    {
                                      <img src="" class="img-fluid rounded border shadow-sm" style="max-height: 120px; object-fit: contain;" id="img-preview-@targetInputId" />
                                    }
                                    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2 rounded-circle border-0 shadow" 
                                            onclick="event.stopPropagation(); clearUploadedFile('@targetInputId')" title="Remove">
                                      <i class="bi bi-x-lg"></i>
                                    </button>
                                  </div>
                                  
                                </div>
                              </div>
                          }
                        </div>
                    }

                  </div>
              }

            </div>
          </div>
        </div>

        <!-- SEO Fields Accordion (Moved inside Main Column) -->
        @if (activeSeoFields.Any())
        {
          <div class="mt-4">
            <div class="accordion" id="seoFieldsAccordion">
              <div class="accordion-item border border-primary-subtle rounded-4 overflow-hidden shadow-sm">
                <h2 class="accordion-header" id="seoFieldsHeading">
                  <button class="accordion-button collapsed fw-bold bg-primary-subtle text-primary-emphasis" type="button" data-bs-toggle="collapse" data-bs-target="#seoFieldsCollapse" aria-expanded="false" aria-controls="seoFieldsCollapse">
                    <i class="bi bi-google me-2"></i>
                    <span class="tp-only-ar">حقول تحسين محركات البحث (SEO)</span>
                    <span class="tp-only-en">Search Engine Optimization Fields (SEO)</span>
                  </button>
                </h2>
                <div id="seoFieldsCollapse" class="accordion-collapse collapse" aria-labelledby="seoFieldsHeading" data-bs-parent="#seoFieldsAccordion">
                  <div class="accordion-body bg-body p-4">
                    <div class="row g-3">
                      @foreach (var seoField in activeSeoFields)
                      {
                          var labelTextAr = seoField.Label;
                          var labelTextEn = seoField.Label_En ?? seoField.Label;
                          var helpTextAr = seoField.HelpText ?? string.Empty;
                          var helpTextEn = seoField.HelpText_En ?? seoField.HelpText ?? string.Empty;

                          if (seoField.FieldName.Equals("SeoTitle", StringComparison.OrdinalIgnoreCase))
                          {
                            <div class="col-lg-6">
                              <div class="tp-only-ar">
                                <label class="form-label fw-bold">@labelTextAr</label>
                                <input type="text" asp-for="SeoTitle" class="form-control" id="sys-seotitle" />
                                @if (!string.IsNullOrWhiteSpace(helpTextAr)) { <div class="form-text">@helpTextAr</div> }
                              </div>
                              <div class="tp-only-en">
                                <label class="form-label fw-bold">@labelTextEn</label>
                                <input type="text" asp-for="SeoTitle_En" class="form-control" id="sys-seotitle-en" />
                                @if (!string.IsNullOrWhiteSpace(helpTextEn)) { <div class="form-text">@helpTextEn</div> }
                              </div>
                            </div>
                          }
                          else if (seoField.FieldName.Equals("SeoDescription", StringComparison.OrdinalIgnoreCase))
                          {
                            <div class="col-lg-6">
                              <div class="tp-only-ar">
                                <label class="form-label fw-bold">@labelTextAr</label>
                                <textarea asp-for="SeoDescription" class="form-control" rows="3" id="sys-seodescription"></textarea>
                                @if (!string.IsNullOrWhiteSpace(helpTextAr)) { <div class="form-text">@helpTextAr</div> }
                              </div>
                              <div class="tp-only-en">
                                <label class="form-label fw-bold">@labelTextEn</label>
                                <textarea asp-for="SeoDescription_En" class="form-control" rows="3" id="sys-seodescription-en"></textarea>
                                @if (!string.IsNullOrWhiteSpace(helpTextEn)) { <div class="form-text">@helpTextEn</div> }
                              </div>
                            </div>
                          }
                          else if (seoField.FieldName.Equals("SeoKeywords", StringComparison.OrdinalIgnoreCase))
                          {
                            <div class="col-lg-6">
                              <div class="tp-only-ar">
                                <label class="form-label fw-bold">@labelTextAr</label>
                                <input type="text" asp-for="SeoKeywords" class="form-control" id="sys-seokeywords" />
                                @if (!string.IsNullOrWhiteSpace(helpTextAr)) { <div class="form-text">@helpTextAr</div> }
                              </div>
                              <div class="tp-only-en">
                                <label class="form-label fw-bold">@labelTextEn</label>
                                <input type="text" asp-for="SeoKeywords_En" class="form-control" id="sys-seokeywords-en" />
                                @if (!string.IsNullOrWhiteSpace(helpTextEn)) { <div class="form-text">@helpTextEn</div> }
                              </div>
                            </div>
                          }
                          else if (seoField.FieldName.Equals("CanonicalUrl", StringComparison.OrdinalIgnoreCase))
                          {
                            <div class="col-lg-6">
                              <label class="form-label fw-bold">
                                <span class="tp-only-ar">@labelTextAr</span>
                                <span class="tp-only-en">@labelTextEn</span>
                              </label>
                              <input type="url" asp-for="CanonicalUrl" class="form-control" id="sys-canonicalurl" dir="ltr" />
                              @if (!string.IsNullOrWhiteSpace(helpTextAr) || !string.IsNullOrWhiteSpace(helpTextEn))
                              {
                                <div class="form-text">
                                  <span class="tp-only-ar">@helpTextAr</span>
                                  <span class="tp-only-en">@helpTextEn</span>
                                </div>
                              }
                            </div>
                          }
                      }
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        }
      </div>

      <!-- RIGHT COLUMN: Publishing Actions Sidebar (Resembles WordPress) -->
      <div class="col-lg-4 position-sticky" style="top: 20px; align-self: flex-start;">
        
        <!-- Category Selection Card -->
        <div class="tp-card mb-3">
          <div class="tp-card-header">
            <h5>
              <i class="bi bi-tags-fill text-primary me-2"></i>
              <span class="tp-only-ar">تصنيف المحتوى</span>
              <span class="tp-only-en">Content Category</span>
            </h5>
          </div>
          <div class="tp-card-body d-flex flex-column gap-3">
            <div>
              <label class="form-label fw-bold" for="sys-category">
                <span class="tp-only-ar">التصنيف الرئيسي</span>
                <span class="tp-only-en">Primary Category</span>
              </label>
              <select asp-for="CategoryId" class="form-select" id="sys-category">
                <option value="" data-label-ar="اختر تصنيف..." data-label-en="Select Category...">اختر تصنيف...</option>
                @foreach (var cat in Model.CategoriesList.Where(c => c.ParentId == null))
                {
                    <option value="@cat.Id" data-label-ar="@cat.Name" data-label-en="@(cat.Name_En ?? cat.Name)">
                      @cat.Name
                    </option>
                }
              </select>
            </div>
            
            <div>
              <label class="form-label fw-bold" for="sys-subcategory">
                <span class="tp-only-ar">التصنيف الفرعي</span>
                <span class="tp-only-en">Sub-Category</span>
              </label>
              <select asp-for="SubCategoryId" class="form-select" id="sys-subcategory">
                <option value="" data-label-ar="اختر تصنيف فرعي..." data-label-en="Select Sub-Category...">اختر تصنيف فرعي...</option>
                @foreach (var sub in Model.CategoriesList.Where(c => c.ParentId != null))
                {
                    <option value="@sub.Id" data-parent="@sub.ParentId" data-label-ar="@sub.Name" data-label-en="@(sub.Name_En ?? sub.Name)">
                      @sub.Name
                    </option>
                }
              </select>
            </div>
          </div>
        </div>

        <!-- Featured Image Card -->
        <div class="tp-card mb-3">
          <div class="tp-card-header">
            <h5>
              <i class="bi bi-image text-primary me-2"></i>
              <span class="tp-only-ar">الصورة البارزة</span>
              <span class="tp-only-en">Featured Image</span>
            </h5>
          </div>
          <div class="tp-card-body">
            <div class="tp-uploader-container">
              <input type="hidden" asp-for="FeaturedImage" id="sys-featuredimage" />
              <input type="file" id="sys-featuredimage-file" class="d-none" accept="image/*" onchange="uploadFileAjax(this, 'sys-featuredimage')" />
              
              <div class="tp-uploader-dropzone p-4 border rounded border-2 border-dashed text-center position-relative bg-body-tertiary" 
                   onclick="document.getElementById('sys-featuredimage-file').click()" 
                   style="cursor: pointer; transition: all 0.2s;"
                   id="dropzone-sys-featuredimage">
                   
                <div class="dropzone-placeholder" id="placeholder-sys-featuredimage">
                  <i class="bi bi-cloud-arrow-up-fill text-primary fs-2"></i>
                  <div class="mt-2 fw-semibold">
                    <span class="tp-only-ar">اسحب وأفلت الصورة هنا أو انقر للاختيار</span>
                    <span class="tp-only-en">Drag & drop image here or click to browse</span>
                  </div>
                  <div class="fs-8 text-muted mt-1">PNG, JPG, WEBP (Max 5MB)</div>
                </div>
                
                <div class="dropzone-loading d-none" id="loading-sys-featuredimage">
                  <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                  </div>
                  <div class="mt-2 text-muted fs-8">
                    <span class="tp-only-ar">جاري رفع الصورة...</span>
                    <span class="tp-only-en">Uploading image...</span>
                  </div>
                </div>
                
                <div class="dropzone-preview d-none position-relative" id="preview-container-sys-featuredimage">
                  <img src="" class="img-fluid rounded border shadow-sm" style="max-height: 180px; object-fit: contain;" id="img-preview-sys-featuredimage" />
                  <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2 rounded-circle border-0 shadow" 
                          onclick="event.stopPropagation(); clearUploadedFile('sys-featuredimage')" title="Remove">
                    <i class="bi bi-x-lg"></i>
                  </button>
                </div>
                
              </div>
            </div>
          </div>
        </div>
        
        <!-- Action Publisher Card -->
        <div class="tp-card mb-0">
          <div class="tp-card-header">
            <h5>
              <i class="bi bi-shield-check text-success me-2"></i>
              <span data-page-i18n="publishingActions">إجراءات النشر</span>
            </h5>
            <i class="bi bi-info-circle text-muted"></i>
          </div>
          <div class="tp-card-body">
            
            <div class="mb-3">
              <label class="form-label fw-bold" for="sys-status">
                <span class="tp-only-ar">حالة النشر</span>
                <span class="tp-only-en">Publishing Status</span>
              </label>
              <select asp-for="Status" class="form-select" id="sys-status">
                <option value="Draft" data-label-ar="مسودة" data-label-en="Draft">Draft / مسودة</option>
                <option value="Published" data-label-ar="منشور" data-label-en="Published">Published / منشور</option>
                <option value="Scheduled" data-label-ar="مجدول" data-label-en="Scheduled">Scheduled / مجدول</option>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold" for="sys-publishdate">
                <span class="tp-only-ar">تاريخ النشر</span>
                <span class="tp-only-en">Publish Date</span>
              </label>
              <input type="datetime-local" asp-for="PublishDate" class="form-control" id="sys-publishdate" />
            </div>

            <div class="mb-3 border-bottom pb-2 text-secondary fs-8">
              <div><i class="bi bi-person me-2"></i><span data-page-i18n="statusAuthor">الكاتب الحالي:</span> <strong class="text-primary-emphasis">@@@User.Identity?.Name</strong></div>
              <div class="mt-2"><i class="bi bi-calendar-check me-2"></i><span data-page-i18n="statusDate">التاريخ:</span> <strong id="sidebar-date-text">@DateTime.Now.ToString("dd/MM/yyyy")</strong></div>
              <div class="mt-2"><i class="bi bi-activity me-2"></i><span data-page-i18n="statusMode">الوضعية:</span> <strong class="text-info">@(isNew ? "إنشاء جديد (New)" : "تعديل (Edit)")</strong></div>
            </div>

            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-primary py-2 shadow-sm rounded-3 fw-bold" id="btn-publish-submit">
                <i class="bi bi-save-fill me-1"></i>
                <span data-page-i18n="btnSaveContent">حفظ ونشر المحتوى</span>
              </button>
              
              <a asp-page="/Content" class="btn btn-outline-secondary py-2">
                <span data-page-i18n="btnCancel">إلغاء</span>
              </a>
            </div>

          </div>
        </div>
        
      </div>


    </div>
  </form>
</main>

@section Scripts {
  <!-- Summernote Rich Text Editor JS/CSS -->
  <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs5.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs5.min.js"></script>
  
  <!-- SweetAlert2 CDN -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  
  <script>
    let currentLang = localStorage.getItem('tp-lang') || 'ar';
    const customFieldsValues = @Html.Raw(Model.CustomFieldsValuesJson);

    const pageTranslations = {
      ar: {
        subHeaderDesc: "قم بتعبئة بيانات المنشور وحفظها مباشرة، يتطابق الترتيب والتصميم مع الإعدادات المهيأة مسبقاً.",
        switchTypeLabel: "النوع:",
        btnBack: "الرجوع للمحتوى",
        formFieldsTitle: "حقول استمارة المحتوى الديناميكية",
        badgeFieldsCount: "حقل نشط",
        publishingActions: "إجراءات النشر",
        statusAuthor: "الكاتب الحالي:",
        statusDate: "التاريخ:",
        statusMode: "الوضعية:",
        btnSaveContent: "حفظ ونشر المحتوى",
        btnCancel: "إلغاء",
        saveSuccess: "تمت عملية التخزين بنجاح",
        saveSuccessText: "تمت مزامنة البيانات وتخزينها في قاعدة البيانات بنجاح.",
        okText: "موافق"
      },
      en: {
        subHeaderDesc: "Fill form fields and save immediately, layout structures align exactly with configured sequences.",
        switchTypeLabel: "Type:",
        btnBack: "Back to Content List",
        formFieldsTitle: "Dynamic Content Form Fields",
        badgeFieldsCount: "active fields",
        publishingActions: "Publishing Actions",
        statusAuthor: "Current Author:",
        statusDate: "Date:",
        statusMode: "Mode:",
        btnSaveContent: "Save and Publish Content",
        btnCancel: "Cancel",
        saveSuccess: "Content has been saved successfully.",
        saveSuccessText: "All parameters synchronized and stored in the database.",
        okText: "OK"
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      applyPageTranslations(currentLang);
      initQuillEditors();
      initCategoriesCascade();
      populateFormValues();

      // Setup Content Type Switcher Change
      document.getElementById('contentTypeSwitcher').addEventListener('change', function() {
        const typeId = this.value;
        const currentId = document.getElementById('form-Id').value;
        
        // Retain the type during switch
        window.location.href = `/ContentEdit?id=${currentId}&contentTypeId=${typeId}`;
      });

      // Initialize Drag & Drop for all uploader zones
      const dropzones = document.querySelectorAll('.tp-uploader-dropzone');
      dropzones.forEach(dz => {
        const targetInputId = dz.id.replace('dropzone-', '');
        initDragAndDrop(targetInputId);
      });

      window.addEventListener('tp-lang-changed', (e) => {
        applyPageTranslations(e.detail.lang);
      });
    });

    function applyPageTranslations(lang) {
      currentLang = lang;
      
      // Update body classes
      document.body.classList.toggle('lang-ar', lang === 'ar');
      document.body.classList.toggle('lang-en', lang === 'en');

      // Update static page translation elements
      const elements = document.querySelectorAll('[data-page-i18n]');
      elements.forEach(el => {
        const key = el.getAttribute('data-page-i18n');
        if (pageTranslations[lang] && pageTranslations[lang][key]) {
          el.textContent = pageTranslations[lang][key];
        }
      });

      // Handle system field validations requirements
      const titleAr = document.getElementById('sys-title');
      const titleEn = document.getElementById('sys-title-en');
      if (titleAr && titleEn) {
        if (lang === 'ar') {
          titleAr.setAttribute('required', 'required');
          titleEn.removeAttribute('required');
        } else {
          titleEn.setAttribute('required', 'required');
          titleAr.removeAttribute('required');
        }
      }

      // Translate dynamic select options
      const dynamicOptions = document.querySelectorAll('option[data-label-ar]');
      dynamicOptions.forEach(opt => {
        const ar = opt.getAttribute('data-label-ar');
        const en = opt.getAttribute('data-label-en');
        opt.textContent = (lang === 'ar') ? ar : (en || ar);
      });

      // Re-initialize popovers to load correct titles and language parameters
      initPopovers();
    }

    function initPopovers() {
      const popoverTriggerList = document.querySelectorAll('[data-bs-toggle="popover"]');
      popoverTriggerList.forEach(el => {
        const existing = bootstrap.Popover.getInstance(el);
        if (existing) existing.dispose();
        new bootstrap.Popover(el, {
          trigger: 'focus'
        });
      });
    }

    // Initialize Summernote Editors for Content fields and Dynamic RichText Custom fields
    function initQuillEditors() {
      const summernoteConfig = {
        height: 250,
        toolbar: [
          ['style', ['style']],
          ['font', ['bold', 'underline', 'clear']],
          ['color', ['color']],
          ['para', ['ul', 'ol', 'paragraph']],
          ['table', ['table']],
          ['insert', ['link', 'picture', 'video']],
          ['view', ['fullscreen', 'codeview', 'help']]
        ]
      };

      if (document.getElementById('sys-content-input')) {
        $('#sys-content-input').summernote(Object.assign({}, summernoteConfig, { placeholder: 'اكتب تفاصيل المحتوى بالعربية هنا...' }));
      }
      if (document.getElementById('sys-content-en-input')) {
        $('#sys-content-en-input').summernote(Object.assign({}, summernoteConfig, { placeholder: 'Write content paragraphs in English here...' }));
      }

      $('.sn-editor.ql-custom-editor').each(function() {
        $(this).summernote(Object.assign({}, summernoteConfig, { placeholder: 'أدخل تفاصيل النص المنسق...' }));
      });
    }

    // Cascading categories
    function initCategoriesCascade() {
      const catSelect = document.getElementById('sys-category');
      const subSelect = document.getElementById('sys-subcategory');

      if (catSelect && subSelect) {
        catSelect.addEventListener('change', function() {
          const parentId = this.value;
          subSelect.value = "";
          
          const options = subSelect.querySelectorAll('option');
          options.forEach(opt => {
            if (opt.value === "") return;
            const parentAttr = opt.getAttribute('data-parent');
            if (!parentId || parentAttr === parentId) {
              opt.style.display = "block";
            } else {
              opt.style.display = "none";
            }
          });
        });
      }
    }

    // Auto generate Slug dynamically from title input
    function autoGenerateSlug() {
      const activeTitleInput = currentLang === 'ar' ? document.getElementById('sys-title') : document.getElementById('sys-title-en');
      if (activeTitleInput) {
        const titleVal = activeTitleInput.value.trim();
        const slugVal = titleVal
          .toLowerCase()
          .replace(/[^\u0621-\u064A\u0660-\u0669a-zA-Z0-9\s-]/g, '') // Keep letters/numbers/spaces
          .replace(/\s+/g, '-') // Replace spaces with dashes
          .replace(/-+/g, '-'); // Condense multiple dashes
        
        const slugInput = document.getElementById('sys-slug');
        if (slugInput) slugInput.value = slugVal;
      }
    }

    // Populate existing values when in Edit Mode (inputs are server-rendered; sync editors/previews here)
    function populateFormValues() {
      if ($('#sys-content-input').length && $('#sys-content-input').val() && typeof $('#sys-content-input').summernote === 'function') {
        $('#sys-content-input').summernote('code', $('#sys-content-input').val());
      }
      if ($('#sys-content-en-input').length && $('#sys-content-en-input').val() && typeof $('#sys-content-en-input').summernote === 'function') {
        $('#sys-content-en-input').summernote('code', $('#sys-content-en-input').val());
      }

      // Sync Featured Image preview
      if (document.getElementById('sys-featuredimage') && document.getElementById('sys-featuredimage').value) {
        syncUploaderPreview('sys-featuredimage');
      }

      // Trigger categories dropdown change cascade if populated
      const catSelect = document.getElementById('sys-category');
      if (catSelect && catSelect.value) {
        catSelect.dispatchEvent(new Event('change'));
      }

      for (const key in customFieldsValues) {
        const val = customFieldsValues[key];
        const inputName = 'custom_' + key;
        const inputs = document.getElementsByName(inputName);

        if (inputs.length > 0) {
          const inputEl = inputs[0];

          if (inputEl.tagName === 'SELECT') {
            if (inputEl.hasAttribute('multiple') && Array.isArray(val)) {
              Array.from(inputEl.options).forEach(opt => {
                opt.selected = val.includes(opt.value);
              });
            } else if (val !== null && val !== undefined) {
              inputEl.value = val;
            }
          }
          else if (inputEl.type === 'checkbox') {
            inputEl.checked = (val === true || val === 'true');
          }
          else if (!inputEl.value && val !== null && val !== undefined) {
            inputEl.value = inputEl.classList.contains('query-field-input') && typeof val === 'object'
              ? JSON.stringify(val)
              : val;
          }

          if (val) {
            syncUploaderPreview('input-' + key);
          }
        }
        else {
          const richEditor = document.getElementById('input-' + key);
          if (richEditor && richEditor.classList.contains('ql-custom-editor') && typeof $(richEditor).summernote === 'function') {
            $(richEditor).summernote('code', val || '');
          }
        }
      }
    }

    // Sync uploader visual preview states
    function syncUploaderPreview(targetInputId) {
      const targetInput = document.getElementById(targetInputId);
      if (!targetInput) return;
      const val = targetInput.value.trim();
      const placeholder = document.getElementById('placeholder-' + targetInputId);
      const loading = document.getElementById('loading-' + targetInputId);
      const previewContainer = document.getElementById('preview-container-' + targetInputId);
      const previewImg = document.getElementById('img-preview-' + targetInputId);
      const fileNameSpan = document.getElementById('file-name-' + targetInputId);

      if (val) {
        if (placeholder) placeholder.classList.add('d-none');
        if (loading) loading.classList.add('d-none');
        if (previewContainer) previewContainer.classList.remove('d-none');
        if (previewImg) {
          previewImg.src = val;
        }
        if (fileNameSpan) {
          fileNameSpan.textContent = val.substring(val.lastIndexOf('/') + 1);
        }
      } else {
        if (previewContainer) previewContainer.classList.add('d-none');
        if (loading) loading.classList.add('d-none');
        if (placeholder) placeholder.classList.remove('d-none');
      }
    }

    // AJAX File Upload Action
    function uploadFileAjax(fileInput, targetInputId) {
      const file = fileInput.files[0];
      if (!file) return;

      const targetInput = document.getElementById(targetInputId);
      const placeholder = document.getElementById('placeholder-' + targetInputId);
      const loading = document.getElementById('loading-' + targetInputId);
      const previewContainer = document.getElementById('preview-container-' + targetInputId);
      const previewImg = document.getElementById('img-preview-' + targetInputId);
      const fileNameSpan = document.getElementById('file-name-' + targetInputId);

      // Show loading
      if (placeholder) placeholder.classList.add('d-none');
      if (loading) loading.classList.remove('d-none');
      if (previewContainer) previewContainer.classList.add('d-none');

      const formData = new FormData();
      formData.append('file', file);

      $.ajax({
        url: '?handler=UploadFile',
        type: 'POST',
        data: formData,
        contentType: false,
        processData: false,
        headers: {
          "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
        },
        success: function(response) {
          if (loading) loading.classList.add('d-none');
          if (response.success) {
            targetInput.value = response.filePath;
            
            if (previewImg) {
              previewImg.src = response.filePath;
            }
            if (fileNameSpan) {
              fileNameSpan.textContent = response.filePath.substring(response.filePath.lastIndexOf('/') + 1);
            }
            if (previewContainer) previewContainer.classList.remove('d-none');

            Swal.fire({
              toast: true,
              position: 'top-end',
              icon: 'success',
              title: currentLang === 'ar' ? 'تم رفع الملف بنجاح' : 'File uploaded successfully',
              showConfirmButton: false,
              timer: 1500
            });
          } else {
            if (placeholder) placeholder.classList.remove('d-none');
            Swal.fire('Error / خطأ', response.message, 'error');
          }
        },
        error: function(xhr, status, error) {
          if (loading) loading.classList.add('d-none');
          if (placeholder) placeholder.classList.remove('d-none');
          Swal.fire('Error / خطأ', 'فشل الرفع: ' + error, 'error');
        }
      });
    }

    // Clear uploader file value
    function clearUploadedFile(targetInputId) {
      const targetInput = document.getElementById(targetInputId);
      const placeholder = document.getElementById('placeholder-' + targetInputId);
      const loading = document.getElementById('loading-' + targetInputId);
      const previewContainer = document.getElementById('preview-container-' + targetInputId);
      const fileInput = document.getElementById(targetInputId + '-file') || document.getElementById('file-custom-' + targetInputId.replace('input-', ''));

      if (targetInput) targetInput.value = '';
      if (fileInput) fileInput.value = '';
      
      if (previewContainer) previewContainer.classList.add('d-none');
      if (loading) loading.classList.add('d-none');
      if (placeholder) placeholder.classList.remove('d-none');
    }

    // Drag and Drop implementation
    function initDragAndDrop(targetInputId) {
      const dropzone = document.getElementById('dropzone-' + targetInputId);
      const fileInput = document.getElementById(targetInputId + '-file') || document.getElementById('file-custom-' + targetInputId.replace('input-', ''));
      
      if (!dropzone || !fileInput) return;
      
      ['dragenter', 'dragover'].forEach(eventName => {
        dropzone.addEventListener(eventName, (e) => {
          e.preventDefault();
          e.stopPropagation();
          dropzone.classList.add('dragover');
        }, false);
      });
      
      ['dragleave', 'drop'].forEach(eventName => {
        dropzone.addEventListener(eventName, (e) => {
          e.preventDefault();
          e.stopPropagation();
          dropzone.classList.remove('dragover');
        }, false);
      });
      
      dropzone.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const files = dt.files;
        if (files.length > 0) {
          fileInput.files = files;
          uploadFileAjax(fileInput, targetInputId);
        }
      }, false);
    }

    // Dynamic Save AJAX Submit Action
    function saveContentForm(e) {
      e.preventDefault();

      // Summernote automatically updates the underlying textarea, no manual sync needed here

      // Sync system Titles based on current active view
      const titleAr = document.getElementById('sys-title').value.trim();
      const titleEn = document.getElementById('sys-title-en').value.trim();
      if (currentLang === 'ar') {
        if (!titleEn) document.getElementById('sys-title-en').value = titleAr;
      } else {
        if (!titleAr) document.getElementById('sys-title').value = titleEn;
      }

      // Post Form via AJAX
      const formEl = document.getElementById('contentForm');
      const formData = new FormData(formEl);

      const trans = pageTranslations[currentLang];

      $.ajax({
        url: '?handler=Save',
        type: 'POST',
        data: formData,
        contentType: false,
        processData: false,
        headers: {
          "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
        },
        success: function(response) {
          if (response.success) {
            Swal.fire({
              title: trans.saveSuccess,
              text: trans.saveSuccessText,
              icon: 'success',
              showConfirmButton: false,
              timer: 1500
            }).then(() => {
              window.location.href = '/Content';
            });
          } else {
            Swal.fire('Error / خطأ', response.message, 'error');
          }
        },
        error: function(xhr, status, error) {
          Swal.fire('Error / خطأ', 'فشلت معالجة الطلب على الخادم: ' + error, 'error');
        }
      });
    }
  </script>
}
