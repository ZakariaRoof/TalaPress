                className: 'buttons-pdf',
                title: 'TalaPress_Content_Export',
                exportOptions: { columns: [2, 3, 4, 5, 6, 7, 8, 9, 10] },
                action: newExportAction
              },
              {
                text: '<i class="bi bi-file-earmark-word-fill text-primary fs-4"></i>',
                titleAttr: currentLang === 'ar' ? 'تصدير إلى Word' : 'Export to Word',
                className: 'buttons-word',
                exportOptions: { columns: [2, 3, 4, 5, 6, 7, 8, 9, 10] },
                action: newExportAction
              },
              {
                extend: 'print',
                text: '<i class="bi bi-printer-fill text-secondary fs-4"></i>',
                titleAttr: currentLang === 'ar' ? 'طباعة التقرير' : 'Print Report',
                className: 'buttons-print',
                title: '',
                exportOptions: { columns: [2, 3, 4, 5, 6, 7, 8, 9, 10] },
                action: newExportAction,
                customize: function (win) {
                    $(win.document.body).css('direction', currentLang === 'ar' ? 'rtl' : 'ltr');
                    $(win.document.body).css('background', '#f8f9fa');
                    $(win.document.body).find('table')
                        .addClass('table-bordered table-striped text-center')
                        .css('font-size', '14px')
                        .css('background', '#fff');
                    
                    $(win.document.body).find('h1').remove();
                    $(win.document.body).prepend(`
                        <div style="text-align: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 2px solid #0d6efd;">
                            <h2 style="color: #0d6efd; font-weight: bold; margin-bottom: 5px; font-family: Cairo, sans-serif;">TalaPress System</h2>
                            <h4 style="color: #6c757d; margin-top: 0; font-family: Cairo, sans-serif;">تقرير شامل للمحتوى والمنشورات</h4>
                            <p style="font-size: 12px; color: #adb5bd; margin-top: 10px;">تاريخ الطباعة: ${new Date().toLocaleString(currentLang === 'ar' ? 'ar-EG' : 'en-US')}</p>
                        </div>
                    `);
                }
              }
            ]
        },
        ajax: {
          url: '?handler=ServerSideData',
          type: 'POST',
          headers: {
            "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
          },
          data: function(d) {
            // Merge custom advanced filters
            d.contentTypeId = document.getElementById('filter-contentType').value;
            d.categoryId = document.getElementById('filter-category').value;
            d.subCategoryId = document.getElementById('filter-subcategory').value;
            d.status = document.getElementById('filter-status').value;
            d.authorId = document.getElementById('filter-author').value;
            d.dateFrom = document.getElementById('filter-dateFrom').value;
            d.dateTo = document.getElementById('filter-dateTo').value;
          }
        },
        language: {
          get search() { return pageTranslations[currentLang].dtSearch; },
          get lengthMenu() { return pageTranslations[currentLang].dtLength; },
          get info() { return pageTranslations[currentLang].dtInfo; },
          get emptyTable() { return pageTranslations[currentLang].dtEmpty; },
          get zeroRecords() { return pageTranslations[currentLang].dtEmpty; },
          get processing() { return `<div class="spinner-border text-primary" role="status"></div><div class="mt-2 text-primary fw-bold">${pageTranslations[currentLang].dtProcessing}</div>`; },
          paginate: {
            first: "<<",
            previous: "<",
            next: ">",
            last: ">>"
          }
        },
        order: [[10, 'desc']], // Default sorting: Created Date DESC
        columnDefs: [
          { targets: [0, 1, 11], orderable: false } // Checkbox, Image and Actions columns are non-sortable
        ],
        columns: [
          // Select Checkbox Column
          {
            data: 'id',
            render: function(data, type, row) {
              return `<input type="checkbox" class="form-check-input row-select-cb" value="${data}">`;
            }
          },
          // Featured Image
          { 
            data: 'featuredImage',
            render: function(data, type, row) {
              if (data) {
                return `<img src="${data}" alt="Thumbnail" class="rounded border shadow-sm" style="width: 45px; height: 45px; object-fit: cover;">`;
              }
              // Icon fallback based on content type
              let iconClass = 'bi bi-file-earmark-richtext';
              if (row.contentTypeNameEn === 'News') iconClass = 'bi bi-newspaper';
              if (row.contentTypeNameEn === 'Event') iconClass = 'bi bi-calendar-event';
              if (row.contentTypeNameEn === 'Gallery') iconClass = 'bi bi-images';
              if (row.contentTypeNameEn === 'Team') iconClass = 'bi bi-people';
              if (row.contentTypeNameEn === 'Service') iconClass = 'bi bi-briefcase';
              if (row.contentTypeNameEn === 'Project') iconClass = 'bi bi-kanban';
              
              return `<div class="rounded bg-light text-secondary border d-flex align-items-center justify-content-center mx-auto" style="width: 45px; height: 45px; font-size: 20px;"><i class="${iconClass}"></i></div>`;
            }
          },
          // Title
          {
            data: 'title',
            render: function(data, type, row) {
              const text = currentLang === 'ar' ? (row.title || 'بدون عنوان') : (row.title_En || row.title || 'Untitled');
              return `<div class="fw-bold text-start px-2"><a href="/ContentEdit?id=${row.id}" class="text-decoration-none text-primary-emphasis">${text}</a></div>`;
            }
          },
          // Content Type
          {
            data: 'contentTypeName',
            render: function(data, type, row) {
              const text = currentLang === 'ar' ? row.contentTypeName : (row.contentTypeNameEn || row.contentTypeName);
              return `<span class="badge bg-secondary-subtle text-secondary-emphasis fs-8 px-2">${text}</span>`;
            }
          },
          // Category
          {
            data: 'categoryName',
            render: function(data, type, row) {
              const text = currentLang === 'ar' ? (row.categoryName || '—') : (row.categoryNameEn || row.categoryName || '—');
              return `<span>${text}</span>`;
            }
          },
          // SubCategory
          {
            data: 'subCategoryName',
            render: function(data, type, row) {
              const text = currentLang === 'ar' ? (row.subCategoryName || '—') : (row.subCategoryNameEn || row.subCategoryName || '—');
              return `<span>${text}</span>`;
            }
          },
          // Status
          {
            data: 'status',
            render: function(data, type, row) {
              let badgeClass = 'bg-warning text-dark';
              let statusText = data;
              if (data === 'Published') {
                badgeClass = 'bg-success';
                statusText = currentLang === 'ar' ? 'منشور' : 'Published';
              } else if (data === 'Draft') {
                badgeClass = 'bg-warning text-dark';
                statusText = currentLang === 'ar' ? 'مسودة' : 'Draft';
              } else if (data === 'Scheduled') {
                badgeClass = 'bg-info text-dark';
                statusText = currentLang === 'ar' ? 'مجدول' : 'Scheduled';
              }
              return `<span class="badge ${badgeClass} fs-8 px-3">${statusText}</span>`;
            }
          },
          // Publish Date
          {
            data: 'publishDate',
            render: function(data) {
              if (!data) return '—';
              const dt = new Date(data);
              return dt.toLocaleDateString(currentLang === 'ar' ? 'ar-EG' : 'en-US') + ' ' + dt.toLocaleTimeString(currentLang === 'ar' ? 'ar-EG' : 'en-US', { hour: '2-digit', minute: '2-digit' });
            }
          },
          // Author
          { data: 'authorName' },
          // Hits
          { data: 'hits' },
          // Created Date
          {
            data: 'createdAt',
            render: function(data) {
              const dt = new Date(data);
              return dt.toLocaleDateString(currentLang === 'ar' ? 'ar-EG' : 'en-US');
            }
          },
          // Actions
          {
            data: 'id',
            render: function(data, type, row) {
              const editTitle = currentLang === 'ar' ? 'تعديل المحتوى' : 'Edit Content';
              const duplicateTitle = currentLang === 'ar' ? 'تكرار المقال كمسودة' : 'Duplicate Draft';
              const previewTitle = currentLang === 'ar' ? 'عرض المحتوى' : 'View Content';
              const deleteTitle = currentLang === 'ar' ? 'حذف المقال' : 'Delete Content';

              return `
                <div class="d-flex align-items-center justify-content-center gap-1">
                  <a href="/ContentEdit?id=${data}" class="btn btn-sm btn-outline-primary btn-icon" title="${editTitle}"><i class="bi bi-pencil-fill"></i></a>
                  <button type="button" class="btn btn-sm btn-outline-secondary btn-icon" onclick="triggerDuplicate(${data})" title="${duplicateTitle}"><i class="bi bi-files"></i></button>
                  <button type="button" class="btn btn-sm btn-outline-info btn-icon" onclick="showHeadlessPreview(${data})" title="${previewTitle}"><i class="bi bi-eye-fill"></i></button>
                  <button type="button" class="btn btn-sm btn-outline-danger btn-icon" onclick="triggerDelete(${data})" title="${deleteTitle}"><i class="bi bi-trash-fill"></i></button>
                </div>
              `;
            }
          }
        ],
        drawCallback: function() {
          $('#selectAll').prop('checked', false);
          updateBulkDeleteButtonState();
        }
      });

      // Move buttons into the new toolbar container
      contentTable.buttons().container().appendTo('#export-buttons-container');
    }

    // Trigger Duplication Form Post
    function triggerDuplicate(id) {
      document.getElementById('duplicate-id-input').value = id;
      document.getElementById('duplicateForm').submit();
    }

    // Trigger Soft Delete AJAX Call
    function triggerDelete(id) {
      const trans = pageTranslations[currentLang];
      
      Swal.fire({
        title: trans.deleteConfirmTitle,
        text: trans.deleteConfirmText,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: trans.deleteConfirmBtn,
        cancelButtonText: trans.btnCancel
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            url: '?handler=Delete',
            type: 'POST',
            data: { id: id },
            headers: {
              "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(response) {
              if (response.success) {
                Swal.fire({
                  title: trans.deleteSuccess,
                  text: response.message,
                  icon: 'success',
                  timer: 1500,
                  showConfirmButton: false
                });
                contentTable.ajax.reload(null, false); // Reload table preserving current pagination
              } else {
                Swal.fire('Error / خطأ', response.message, 'error');
              }
            },
            error: function(xhr, status, error) {
              Swal.fire('Error / خطأ', 'فشلت معالجة الطلب على الخادم: ' + error, 'error');
            }
          });
        }
      });
    }

    // Fetch and show formatted content preview
    function showHeadlessPreview(id) {
      document.getElementById('preview-loading').classList.remove('d-none');
      document.getElementById('content-preview-article').classList.add('d-none');
      document.getElementById('preview-full-page-link').href = '/ContentPreview?id=' + id;
      previewModalInstance.show();

      $.ajax({
        url: '/ContentPreview?id=' + id + '&handler=JSON',
        type: 'GET',
        success: function(response) {
          renderFormattedPreview(response);
        },
        error: function(xhr, status, error) {
          document.getElementById('preview-loading').innerHTML = `<div class="text-danger fw-bold py-4">Failed to load preview: ${escapeHtml(error)} / فشل جلب المعاينة.</div>`;
        }
      });
    }

    function renderFormattedPreview(item) {
      const isAr = currentLang === 'ar';
      const title = isAr ? (item.title || item.titleEn || 'بدون عنوان') : (item.titleEn || item.title || 'Untitled');
      const summary = isAr ? (item.summary || item.summaryEn || '') : (item.summaryEn || item.summary || '');
      const htmlContent = isAr ? (item.content || item.contentEn || '') : (item.contentEn || item.content || '');
      const type = isAr ? (item.contentTypeAr || item.contentType || '—') : (item.contentType || item.contentTypeAr || '—');
      const category = isAr ? [item.category, item.subCategory].filter(Boolean).join(' / ') : [item.categoryEn || item.category, item.subCategoryEn || item.subCategory].filter(Boolean).join(' / ');

      document.getElementById('preview-title').textContent = title;
      document.getElementById('preview-summary').textContent = summary;
      document.getElementById('preview-summary').classList.toggle('d-none', !summary);
      document.getElementById('preview-content').innerHTML = htmlContent || `<p class="text-muted">${isAr ? 'لا يوجد محتوى نصي.' : 'No body content.'}</p>`;
      document.getElementById('preview-type').textContent = type;
      document.getElementById('preview-status').textContent = formatStatus(item.status);
      document.getElementById('preview-date').textContent = item.publishDate || item.createdAt || '—';
      document.getElementById('preview-hits-count').textContent = item.hits || item.hitts || 0;
      document.getElementById('preview-author').textContent = item.author || '—';
      document.getElementById('preview-category').textContent = category || '—';

      const hero = document.getElementById('preview-hero-image');
      if (item.featuredImage) {
        hero.classList.remove('d-none');
        hero.innerHTML = `<img src="${escapeAttribute(item.featuredImage)}" alt="${escapeAttribute(title)}" class="w-100 h-100 object-fit-cover">`;
      } else {
        hero.classList.add('d-none');
        hero.innerHTML = '';
      }

      renderPreviewFields(item.fieldsDisplay || item.fields || {});
      renderPreviewSeo(item.seo || {});

      document.getElementById('preview-loading').classList.add('d-none');
      document.getElementById('content-preview-article').classList.remove('d-none');
    }

    function renderPreviewFields(fields) {
      const wrapper = document.getElementById('preview-fields');
      const keys = Object.keys(fields).filter(k => fields[k] !== null && fields[k] !== undefined && fields[k] !== '');
      if (!keys.length) {
        wrapper.innerHTML = `<div class="text-muted small">${currentLang === 'ar' ? 'لا توجد حقول مخصصة.' : 'No custom fields.'}</div>`;
        return;
      }

      wrapper.innerHTML = keys.map(key => `
        <div class="bg-white border rounded-3 p-3 shadow-sm">
          <div class="text-secondary small fw-semibold mb-1">${escapeHtml(key)}</div>
          <div class="fw-bold text-break">${renderPreviewValue(fields[key])}</div>
        </div>
      `).join('');
    }

    function renderPreviewSeo(seo) {
      const rows = [
        ['Title', currentLang === 'ar' ? (seo.title || seo.titleEn) : (seo.titleEn || seo.title)],
        ['Description', currentLang === 'ar' ? (seo.description || seo.descriptionEn) : (seo.descriptionEn || seo.description)],
        ['Keywords', currentLang === 'ar' ? (seo.keywords || seo.keywordsEn) : (seo.keywordsEn || seo.keywords)],
        ['Canonical', seo.canonical]
      ];

      document.getElementById('preview-seo').innerHTML = rows.map(([label, value]) => `
        <div class="mb-2">
          <div class="fw-bold text-dark">${label}</div>
          <div class="text-break">${escapeHtml(value || '—')}</div>
        </div>
      `).join('');
    }

    function renderCardListIconMarkup(icon) {
      if (!icon) return '<i class="fas fa-circle"></i>';
      const val = String(icon).trim();
      if (/^bi[\s-]/i.test(val)) {
        let cls = val.startsWith('bi ') ? val.slice(3).trim() : val;
        if (!cls.startsWith('bi-')) cls = 'bi-' + cls.replace(/^-/, '');
        return `<i class="bi ${escapeHtml(cls)}"></i>`;
      }
      if (/^(fa-solid|fa-regular|fa-brands|fa-light|fa-thin|fa-duotone)\s+fa-/i.test(val)) {
        const parts = val.split(/\s+/);
        const map = { 'fa-solid': 'fas', 'fa-regular': 'far', 'fa-brands': 'fab', 'fa-light': 'fal', 'fa-thin': 'fat', 'fa-duotone': 'fad' };
        return `<i class="${map[parts[0].toLowerCase()] || 'fas'} ${escapeHtml(parts[1].toLowerCase())}"></i>`;
      }
      if (/^(fas|far|fab|fal|fat|fad)\s+fa-/i.test(val)) {
        return `<i class="${escapeHtml(val.toLowerCase())}"></i>`;
      }
      if (/^fa-/.test(val)) return `<i class="fas ${escapeHtml(val.toLowerCase())}"></i>`;
      return `<i class="fas fa-${escapeHtml(val.replace(/^-/, '').toLowerCase())}"></i>`;
    }

    function renderPreviewValue(value) {
      if (value && typeof value === 'object' && !Array.isArray(value) && value.results) {
        const count = Array.isArray(value.results) ? value.results.length : 0;
        return `<span class="badge bg-info-subtle text-info-emphasis border px-2 py-1"><i class="bi bi-diagram-3 me-1"></i>Query: ${count} result(s)</span>`;
      }
      if (value && typeof value === 'object' && !Array.isArray(value) && Object.prototype.hasOwnProperty.call(value, 'value')) {
        const label = currentLang === 'ar' ? (value.label || value.labelEn || value.value) : (value.labelEn || value.label || value.value);
        return `<span class="badge bg-primary-subtle text-primary-emphasis border px-2 py-1">${escapeHtml(label)}</span><small class="d-block text-muted mt-1" dir="ltr">${escapeHtml(value.value)}</small>`;
      }
      if (value && typeof value === 'object' && Array.isArray(value.items)) {
        const sectionTitle = currentLang === 'ar'
          ? (value.sectionTitle || value.sectionTitleEn || '')
          : (value.sectionTitleEn || value.sectionTitle || '');
        const sectionSubtitle = currentLang === 'ar'
          ? (value.sectionSubtitle || value.sectionSubtitleEn || '')
          : (value.sectionSubtitleEn || value.sectionSubtitle || '');
        const sectionSummary = currentLang === 'ar'
          ? (value.sectionSummary || value.sectionSummaryEn || '')
          : (value.sectionSummaryEn || value.sectionSummary || '');
        let cardsHtml = '';
        value.items.forEach((item, idx) => {
          const title = currentLang === 'ar'
            ? (item.title || item.titleEn || `Card ${idx + 1}`)
            : (item.titleEn || item.title || `Card ${idx + 1}`);
          const subtitle = currentLang === 'ar'
            ? (item.subtitle || item.subtitleEn || '')
            : (item.subtitleEn || item.subtitle || '');
          const desc = currentLang === 'ar'
            ? (item.description || item.descriptionEn || '')
            : (item.descriptionEn || item.description || '');
          const useImage = item.mediaType === 'image' || (!!item.image && item.mediaType !== 'icon');
          const iconHtml = renderCardListIconMarkup(item.icon);
          const mediaHtml = useImage && item.image
            ? `<img src="${escapeAttribute(item.image)}" alt="" class="rounded border mt-1" style="max-height:48px;object-fit:contain;">`
            : `<span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle text-primary border mt-1" style="width:36px;height:36px;">${iconHtml}</span>`;
          cardsHtml += `
            <div class="border rounded-3 p-2 mb-2 bg-body-tertiary ${item.featured ? 'border-warning' : ''}">
              <div class="d-flex align-items-start gap-2">
                ${mediaHtml}
                <div class="flex-grow-1">
                  <div class="fw-bold fs-8">${escapeHtml(title)}${item.featured ? ' <span class="badge bg-warning text-dark fs-9">Featured</span>' : ''}</div>
                  ${subtitle ? `<div class="text-primary fs-9">${escapeHtml(subtitle)}</div>` : ''}
                  ${desc ? `<div class="text-muted fs-9">${escapeHtml(desc)}</div>` : ''}
                  ${item.link ? `<div class="fs-9 text-primary" dir="ltr">${escapeHtml(item.link)}</div>` : ''}
                </div>
              </div>
            </div>`;
        });
        return `
          ${sectionTitle ? `<div class="fw-bold mb-1">${escapeHtml(sectionTitle)}</div>` : ''}
          ${sectionSubtitle ? `<div class="text-primary fs-9 mb-1">${escapeHtml(sectionSubtitle)}</div>` : ''}
          ${sectionSummary ? `<div class="text-muted fs-9 mb-2">${escapeHtml(sectionSummary)}</div>` : ''}
          ${cardsHtml || `<span class="text-muted fs-8">${currentLang === 'ar' ? 'لا توجد بطاقات' : 'No cards'}</span>`}`;
      }
      if (Array.isArray(value)) {
        return value.map(v => renderPreviewValue(v)).join('');
      }
      if (typeof value === 'boolean') {
        return value ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-secondary">No</span>';
      }
      if (typeof value === 'string' && value.match(/\.(jpeg|jpg|gif|png|webp)$/i)) {
        return `<img src="${escapeAttribute(value)}" alt="" class="img-fluid rounded border shadow-sm" style="max-height: 140px; object-fit: contain;">`;
      }
      if (typeof value === 'string' && value.startsWith('/uploads/')) {
        return `<a href="${escapeAttribute(value)}" target="_blank" class="text-decoration-none"><i class="bi bi-paperclip me-1"></i>${escapeHtml(value.split('/').pop())}</a>`;
      }
      return escapeHtml(String(value));
    }

    function formatStatus(status) {
      if (status === 'Published') return currentLang === 'ar' ? 'منشور' : 'Published';
      if (status === 'Draft') return currentLang === 'ar' ? 'مسودة' : 'Draft';
      if (status === 'Scheduled') return currentLang === 'ar' ? 'مجدول' : 'Scheduled';
      return status || '—';
    }

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char]));
    }

    function escapeAttribute(value) {
      return escapeHtml(value).replace(/`/g, '&#96;');
    }
  </script>
}
