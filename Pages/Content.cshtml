@page
@model TalaPress.Pages.ContentModel
@{
    ViewData["Title"] = "إدارة المحتوى";
}

@section Styles {
  <!-- DataTables Bootstrap 5 CSS (local) -->
  <link rel="stylesheet" href="~/lib/datatables/css/dataTables.bootstrap5.min.css" asp-append-version="true">
  <link rel="stylesheet" href="~/lib/datatables/css/responsive.bootstrap5.min.css" asp-append-version="true">
  <link rel="stylesheet" href="~/lib/datatables/css/buttons.bootstrap5.min.css" asp-append-version="true">
  <link rel="stylesheet" href="~/assets/css/fontawesome-all.min.css" asp-append-version="true">
  <link rel="stylesheet" href="~/assets/css/fontawesome-pro-local.css" asp-append-version="true">

  <style>
    .tp-preview-modal .modal-content {
      background: #f3f6fb;
    }

    .tp-preview-modal .modal-header {
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(10px);
      color: #102a43;
    }

    .tp-preview-shell {
      max-width: 1060px;
      margin: 0 auto;
    }

    .tp-preview-hero {
      min-height: 300px;
      max-height: 380px;
      background: linear-gradient(135deg, #0d6efd, #6610f2);
    }

    .tp-preview-hero img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .tp-preview-hero-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: flex-end;
      background: linear-gradient(180deg, rgba(6, 22, 48, 0.05) 0%, rgba(6, 22, 48, 0.38) 45%, rgba(6, 22, 48, 0.88) 100%);
    }

    .tp-preview-title {
      max-width: 820px;
      line-height: 1.35;
      text-shadow: 0 2px 20px rgba(0, 0, 0, 0.45);
    }

    .tp-preview-meta-chip {
      display: inline-flex;
      align-items: center;
      gap: .35rem;
      padding: .45rem .75rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.92);
      color: #102a43;
      font-size: .78rem;
      font-weight: 700;
      box-shadow: 0 8px 24px rgba(15, 23, 42, .12);
    }

    .tp-preview-reader {
      margin-top: -34px;
      position: relative;
      z-index: 2;
    }

    .tp-preview-content-card {
      border-radius: 1.25rem;
      box-shadow: 0 20px 55px rgba(15, 23, 42, .11);
    }

    .tp-preview-content-card p {
      margin-bottom: 1rem;
    }

    .tp-preview-content-card img {
      max-width: 100%;
      height: auto;
      border-radius: .75rem;
    }

    .tp-preview-side-card {
      border: 1px solid rgba(13, 110, 253, .10);
      border-radius: 1rem;
      background: #fff;
      box-shadow: 0 12px 35px rgba(15, 23, 42, .07);
    }

    /* DataTable RTL adjustments: show length on far left and search on far right */
    .lang-ar div.dataTables_wrapper > .row:first-child {
      flex-direction: row-reverse;
    }
    .lang-ar div.dataTables_wrapper div.dataTables_length {
      text-align: left !important;
    }
    .lang-ar div.dataTables_wrapper div.dataTables_filter {
      text-align: right !important;
    }
  </style>
}

<!-- SECONDARY HEADER -->
<section class="tp-sub-header">
  <div class="container-fluid px-4">
    <div class="row align-items-center">
      <div class="col-md-7 mb-3 mb-md-0">
        <h1 data-page-i18n="pageTitle">إدارة المحتوى والمنشورات</h1>
        <p data-page-i18n="pageDesc">قم بنشر وإدارة جميع المدخلات، وتصفية البيانات والبحث فيها، وتكرار أو معاينة السجلات بسهولة.</p>
      </div>
      <div class="col-md-5 text-md-end">
        <a asp-page="/Index" class="btn tp-btn-outline-light">
          <i class="bi bi-house-door-fill"></i> <span data-tp-i18n="home">الرئيسية</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- MAIN CONTAINER -->
<main class="container-fluid px-4 pb-5">

  @if (Model.SuccessMessage != null)
  {
      <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm rounded-3" role="alert">
          <i class="bi bi-check-circle-fill me-2 fs-5"></i> @Model.SuccessMessage
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
  }

  @if (Model.ErrorMessage != null)
  {
      <div class="alert alert-danger alert-dismissible fade show mb-4 border-0 shadow-sm rounded-3" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i> @Model.ErrorMessage
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
  }

  <!-- TOOLBAR ROW -->
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <!-- Left side (RTL start): Add Content Button -->
    <div>
      <button type="button" class="btn btn-primary shadow-sm px-4" data-bs-toggle="modal" data-bs-target="#addContentModal">
        <i class="bi bi-plus-lg fw-bold me-1"></i> <span class="fw-bold" data-page-i18n="btnAddNewContent">إضافة محتوى جديد</span>
      </button>
    </div>

    <!-- Right side (RTL end): Filter and Export -->
    <div class="d-flex align-items-center gap-2">
      <button type="button" id="btn-bulk-delete" class="btn btn-danger shadow-sm disabled" disabled>
        <i class="bi bi-trash-fill me-1"></i> <span data-page-i18n="btnBulkDelete">حذف الحقول المحددة</span>
      </button>
      <button type="button" class="btn btn-outline-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#advancedFilterModal">
        <i class="bi bi-funnel-fill me-1"></i> <span data-page-i18n="filtersHeader">تصفية البحث المتقدم</span>
      </button>
      <div id="export-buttons-container" class="d-flex gap-2 border-start border-2 border-light ps-2 ms-1">
        <!-- DataTables buttons will be appended here -->
      </div>
    </div>
  </div>

  <!-- CONTENT DATATABLE -->
  <div class="tp-card">
    <div class="tp-card-body p-4">
      <div class="table-responsive">
        <table id="contentTable" class="table table-striped table-hover align-middle w-100 text-center">
          <thead>
            <tr>
              <th style="width: 40px; text-align: center;"><input type="checkbox" id="selectAll" class="form-check-input"></th>
              <th data-page-i18n="colImage">الصورة البارزة</th>
              <th data-page-i18n="colTitle">العنوان</th>
              <th data-page-i18n="colType">نوع المحتوى</th>
              <th data-page-i18n="colCategory">التصنيف</th>
              <th data-page-i18n="colSubCategory">الفرعي</th>
              <th data-page-i18n="colStatus">الحالة</th>
              <th data-page-i18n="colPublishDate">تاريخ النشر</th>
              <th data-page-i18n="colAuthor">الكاتب</th>
              <th data-page-i18n="colHits">الزيارات</th>
              <th data-page-i18n="colCreated">تاريخ الإنشاء</th>
              <th style="min-width: 140px;">
                <div class="d-flex justify-content-between align-items-center">
                  <span data-page-i18n="colActions">العمليات</span>
                  <a href="#" class="text-secondary" data-bs-toggle="modal" data-bs-target="#columnSelectionModal" title="تخصيص الحقول">
                    <i class="bi bi-three-dots-vertical fs-5"></i>
                  </a>
                </div>
              </th>
            </tr>
          </thead>
          <tbody>
            <!-- Processed Server-Side -->
          </tbody>
        </table>
      </div>
    </div>
  </div>

</main>

<!-- COLUMN SELECTION MODAL -->
<div class="modal fade" id="columnSelectionModal" tabindex="-1" aria-labelledby="columnSelectionModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content shadow rounded-3 border-0">
      <div class="modal-header bg-light">
        <h6 class="modal-title fw-bold text-primary" id="columnSelectionModalLabel" data-page-i18n="colDisplayFields">عرض الحقول الافتراضية</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body px-4 py-3">
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="1" id="col1" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col1" data-page-i18n="colImage">الصورة البارزة</label>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="2" id="col2" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col2" data-page-i18n="colTitle">العنوان</label>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="3" id="col3" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col3" data-page-i18n="colType">نوع المحتوى</label>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="4" id="col4" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col4" data-page-i18n="colCategory">التصنيف</label>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="5" id="col5" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col5" data-page-i18n="colSubCategory">الفرعي</label>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="6" id="col6" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col6" data-page-i18n="colStatus">الحالة</label>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="7" id="col7" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col7" data-page-i18n="colPublishDate">تاريخ النشر</label>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="8" id="col8" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col8" data-page-i18n="colAuthor">الكاتب</label>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="9" id="col9" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col9" data-page-i18n="colHits">الزيارات</label>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2 text-start">
          <input class="form-check-input toggle-vis m-0" style="cursor: pointer;" type="checkbox" data-column="10" id="col10" checked>
          <label class="form-check-label m-0 fs-7" style="cursor: pointer;" for="col10" data-page-i18n="colCreated">تاريخ الإنشاء</label>
        </div>
      </div>
      <div class="modal-footer bg-light p-2 border-0">
        <button type="button" class="btn btn-sm btn-secondary w-100" data-bs-dismiss="modal" data-page-i18n="btnClose">إغلاق</button>
      </div>
    </div>
  </div>
</div>

<!-- ADVANCED FILTER MODAL -->
<div class="modal fade" id="advancedFilterModal" tabindex="-1" aria-labelledby="advancedFilterModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-primary text-white border-0">
        <h5 class="modal-title" id="advancedFilterModalLabel">
          <i class="bi bi-funnel-fill me-2"></i>
          <span data-page-i18n="filtersHeader">تصفية البحث المتقدم</span>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4 bg-body-tertiary">
        <div class="row g-3">
          
          <!-- Content Type Filter -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-bold" data-page-i18n="filterType">نوع المحتوى</label>
            <select class="form-select form-select-sm" id="filter-contentType">
              <option value="" data-page-i18n="optAll">الكل (All)</option>
              @foreach (var type in Model.ContentTypesList)
              {
                  <option value="@type.Id" data-label-ar="@type.Name" data-label-en="@(type.Name_En ?? type.Name)">
                    @type.Name
                  </option>
              }
            </select>
          </div>

          <!-- Category Filter -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-bold" data-page-i18n="filterCategory">التصنيف الرئيسي</label>
            <select class="form-select form-select-sm" id="filter-category">
              <option value="" data-page-i18n="optAll">الكل (All)</option>
              @foreach (var cat in Model.CategoriesList.Where(c => c.ParentId == null))
              {
                  <option value="@cat.Id" data-label-ar="@cat.Name" data-label-en="@(cat.Name_En ?? cat.Name)">
                    @cat.Name
                  </option>
              }
            </select>
          </div>

          <!-- SubCategory Filter -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-bold" data-page-i18n="filterSubCategory">التصنيف الفرعي</label>
            <select class="form-select form-select-sm" id="filter-subcategory">
              <option value="" data-page-i18n="optAll">الكل (All)</option>
              @foreach (var sub in Model.CategoriesList.Where(c => c.ParentId != null))
              {
                  <option value="@sub.Id" data-parent="@sub.ParentId" data-label-ar="@sub.Name" data-label-en="@(sub.Name_En ?? sub.Name)">
                    @sub.Name
                  </option>
              }
            </select>
          </div>

          <!-- Status Filter -->
          <div class="col-md-4 col-sm-6">
            <label class="form-label fw-bold" data-page-i18n="filterStatus">حالة النشر</label>
            <select class="form-select form-select-sm" id="filter-status">
              <option value="ALL" data-page-i18n="optAll">الكل (All)</option>
              <option value="Draft" data-page-i18n="statusDraft">مسودة (Draft)</option>
              <option value="Published" data-page-i18n="statusPublished">منشور (Published)</option>
              <option value="Scheduled" data-page-i18n="statusScheduled">مجدول (Scheduled)</option>
            </select>
          </div>

          <!-- Author Filter -->
          <div class="col-md-8 col-sm-12">
            <label class="form-label fw-bold" data-page-i18n="filterAuthor">الكاتب والناشر</label>
            <select class="form-select form-select-sm" id="filter-author">
              <option value="" data-page-i18n="optAll">الكل (All)</option>
              @foreach (var author in Model.AuthorsList)
              {
                  <option value="@author.Id">@author.FullName (@@@author.Username)</option>
              }
            </select>
          </div>

          <!-- Date Range: From -->
          <div class="col-md-6 col-sm-6">
            <label class="form-label fw-bold" data-page-i18n="filterDateFrom">تاريخ النشر من</label>
            <input type="date" class="form-control form-control-sm" id="filter-dateFrom">
          </div>

          <!-- Date Range: To -->
          <div class="col-md-6 col-sm-6">
            <label class="form-label fw-bold" data-page-i18n="filterDateTo">تاريخ النشر إلى</label>
            <input type="date" class="form-control form-control-sm" id="filter-dateTo">
          </div>

        </div>
      </div>
      <div class="modal-footer border-0 bg-light justify-content-between">
        <button type="button" class="btn btn-outline-secondary" id="btn-reset-filters" data-bs-dismiss="modal">
          <i class="bi bi-arrow-counterclockwise me-1"></i> <span data-page-i18n="btnReset">إعادة تعيين</span>
        </button>
        <button type="button" class="btn btn-primary px-4" id="btn-apply-filters" data-bs-dismiss="modal">
          <i class="bi bi-search me-1"></i> <span data-page-i18n="btnSearch">بحث وتصفية</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ADD CONTENT SELECTION MODAL -->
<div class="modal fade" id="addContentModal" tabindex="-1" aria-labelledby="addContentModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content shadow-lg rounded-3 border-0">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="addContentModalLabel">
          <i class="bi bi-journal-plus me-2"></i>
          <span data-page-i18n="modalAddTitle">إنشاء محتوى جديد - اختر نوع المحتوى للبدء</span>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4 bg-body-tertiary">
        <div class="row g-3" id="content-types-cards-container">
          @if (Model.ContentTypesList.Count == 0)
          {
              <div class="col-12 text-center text-muted py-4">
                <i class="bi bi-folder-x fs-1 d-block mb-2 text-secondary opacity-50"></i>
                <span data-page-i18n="noContentTypes">لا توجد أنواع محتوى مضافة حالياً. يرجى تهيئتها أولاً.</span>
              </div>
          }
          else
          {
              foreach (var type in Model.ContentTypesList)
              {
                  <div class="col-md-6 col-lg-4 mb-2">
                    <div class="card h-100 tp-cursor-pointer border border-light-subtle shadow-sm hover-shadow transition-all" onclick="window.location.href='/ContentEdit?contentTypeId=@type.Id'">
                      <div class="card-body text-center p-4">
                        <div class="avatar-placeholder rounded-circle tp-content-type-icon d-flex align-items-center justify-content-center mx-auto mb-3">
                          <i class="@(type.IconValue ?? "bi bi-journal-text")"></i>
                        </div>
                        <h6 class="fw-bold mb-1">
                          <span class="tp-only-ar">@type.Name</span>
                          <span class="tp-only-en">@type.Name_En</span>
                        </h6>
                        <small class="text-secondary text-truncate-2 fs-8">
                          <span class="tp-only-ar">@(string.IsNullOrEmpty(type.Description) ? "لا يوجد وصف." : type.Description)</span>
                          <span class="tp-only-en">@(string.IsNullOrEmpty(type.Description_En) ? "No description available." : type.Description_En)</span>
                        </small>
                      </div>
                    </div>
                  </div>
              }
          }
        </div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" data-page-i18n="btnCancel">إلغاء</button>
      </div>
    </div>
  </div>
</div>

<!-- CONTENT READING PREVIEW MODAL -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable tp-preview-modal">
    <div class="modal-content shadow-lg rounded-4 border-0 overflow-hidden">
      <div class="modal-header border-0 shadow-sm">
        <h5 class="modal-title fw-bold" id="previewModalLabel">
          <i class="bi bi-eye-fill me-2 text-primary"></i>
          <span data-page-i18n="previewTitle">معاينة المحتوى</span>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        <div id="preview-loading" class="text-center py-5">
          <div class="spinner-border text-primary" role="status"></div>
          <div class="mt-3 fw-bold text-primary" data-page-i18n="previewLoading">جاري تحميل المعاينة...</div>
        </div>

        <article id="content-preview-article" class="d-none tp-preview-shell p-3 p-lg-4">
          <section class="tp-preview-hero position-relative rounded-4 overflow-hidden shadow-lg mb-0">
            <div id="preview-hero-image" class="position-absolute inset-0 w-100 h-100 d-none"></div>
            <div class="tp-preview-hero-overlay">
              <div class="p-4 p-lg-5 text-white w-100">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                  <span id="preview-type" class="tp-preview-meta-chip"></span>
                  <span id="preview-status" class="tp-preview-meta-chip"></span>
                  <span id="preview-date" class="tp-preview-meta-chip"></span>
                  <span id="preview-hits" class="tp-preview-meta-chip"><i class="bi bi-eye-fill me-1"></i> <span id="preview-hits-count">0</span></span>
                </div>
                <h2 id="preview-title" class="tp-preview-title display-6 fw-bold mb-3"></h2>
                <p id="preview-summary" class="lead mb-0 opacity-90 col-lg-10"></p>
              </div>
            </div>
          </section>

          <div class="tp-preview-reader row g-4 align-items-start px-lg-3 pb-3">
            <div class="col-lg-8">
              <div class="tp-preview-content-card bg-white p-4 p-lg-5">
                <div class="d-flex flex-wrap align-items-center gap-3 text-secondary small mb-4 pb-3 border-bottom">
                  <span><i class="bi bi-person-circle me-1 text-primary"></i><span id="preview-author"></span></span>
                  <span><i class="bi bi-folder2-open me-1 text-primary"></i><span id="preview-category"></span></span>
                </div>
                <div id="preview-content" class="fs-6 lh-lg text-dark"></div>
              </div>
            </div>
            <aside class="col-lg-4">
              <div class="tp-preview-side-card p-4 mb-4">
                <h6 class="fw-bold text-primary mb-3">
                  <i class="bi bi-list-stars me-1"></i>
                  <span data-page-i18n="previewDetails">تفاصيل إضافية</span>
                </h6>
                <div id="preview-fields" class="vstack gap-2"></div>
              </div>

              <div class="tp-preview-side-card p-4">
                <h6 class="fw-bold text-primary mb-3">
                  <i class="bi bi-google me-1"></i>
                  SEO
                </h6>
                <div id="preview-seo" class="small text-secondary"></div>
              </div>
            </aside>
          </div>
        </article>
      </div>
      <div class="modal-footer">
        <a id="preview-full-page-link" href="#" class="btn btn-outline-primary shadow-sm">
          <i class="bi bi-box-arrow-up-left me-1"></i>
