    document.addEventListener('tp-lang-changed', (e) => {
      applyPageTranslations(e.detail.lang);
      if (contentTable) {
        contentTable.ajax.reload();
      }
    });

    document.addEventListener('DOMContentLoaded', () => {
      previewModalInstance = new bootstrap.Modal(document.getElementById('previewModal'));
      
      applyPageTranslations(currentLang);
      initCategoriesCascade();
      initContentDataTable();

      // Filter Actions
      document.getElementById('btn-apply-filters').addEventListener('click', () => {
        contentTable.draw();
      });

      document.getElementById('btn-reset-filters').addEventListener('click', () => {
        document.getElementById('filter-contentType').value = "";
        document.getElementById('filter-category').value = "";
        document.getElementById('filter-subcategory').value = "";
        document.getElementById('filter-status').value = "ALL";
        document.getElementById('filter-author').value = "";
        document.getElementById('filter-dateFrom').value = "";
        document.getElementById('filter-dateTo').value = "";
        
        // Reset subcategory visibility options
        const subOptions = document.querySelectorAll('#filter-subcategory option');
        subOptions.forEach(opt => {
          if (opt.value !== "") opt.style.display = "block";
        });

        contentTable.draw();
      });

      // Initialize Column Visibility from LocalStorage
      let savedColumns = localStorage.getItem('tp-visible-columns');
      if (savedColumns) {
        try {
          const colsState = JSON.parse(savedColumns);
          colsState.forEach(col => {
            let checkbox = document.querySelector(`.toggle-vis[data-column="${col.id}"]`);
            if (checkbox) {
              checkbox.checked = col.visible;
              contentTable.column(col.id).visible(col.visible);
            }
          });
        } catch(e) {}
      }

      // Handle column visibility toggles
      document.querySelectorAll('.toggle-vis').forEach(function(el) {
        el.addEventListener('change', function(e) {
          var colId = parseInt(this.getAttribute('data-column'));
          var isVisible = this.checked;
          contentTable.column(colId).visible(isVisible);
          
          // Save to LocalStorage
          let currentState = [];
          document.querySelectorAll('.toggle-vis').forEach(cb => {
             currentState.push({
               id: parseInt(cb.getAttribute('data-column')),
               visible: cb.checked
             });
          });
          localStorage.setItem('tp-visible-columns', JSON.stringify(currentState));
        });
      });

      // Selection Checkbox Event Handlers & State Sync
      $('#contentTable').on('change', '#selectAll', function() {
        const checked = this.checked;
        $('.row-select-cb').prop('checked', checked);
        updateBulkDeleteButtonState();
      });

      $('#contentTable').on('change', '.row-select-cb', function() {
        const total = $('.row-select-cb').length;
        const checked = $('.row-select-cb:checked').length;
        $('#selectAll').prop('checked', total === checked && total > 0);
        updateBulkDeleteButtonState();
      });

      // Bulk Delete Click Handler
      $('#btn-bulk-delete').on('click', function() {
        const selectedIds = $('.row-select-cb:checked').map(function() {
          return this.value;
        }).get();
        
        if (selectedIds.length === 0) return;
        
        const trans = pageTranslations[currentLang];
        const confirmTitle = currentLang === 'ar' ? 'هل أنت متأكد من حذف السجلات المحددة؟' : 'Are you sure you want to delete selected records?';
        const confirmText = currentLang === 'ar' ? `سيتم حذف ${selectedIds.length} من السجلات المحددة ونقلها لسلة المهملات.` : `This will soft-delete ${selectedIds.length} selected records.`;
        
        Swal.fire({
          title: confirmTitle,
          text: confirmText,
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#d33',
          cancelButtonColor: '#3085d6',
          confirmButtonText: trans.deleteConfirmBtn,
          cancelButtonText: trans.btnCancel
        }).then((result) => {
          if (result.isConfirmed) {
            $.ajax({
              url: '?handler=BulkDelete',
              type: 'POST',
              data: { ids: selectedIds.join(',') },
              headers: {
                "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
              },
              success: function(response) {
                if (response.success) {
                  Swal.fire({
                    title: trans.deleteSuccess,
                    text: response.message,
                    icon: 'success',
                    timer: 1500,
                    showConfirmButton: false
                  });
                  contentTable.ajax.reload(null, false);
                } else {
                  Swal.fire('Error / خطأ', response.message, 'error');
                }
              },
              error: function(xhr, status, error) {
                Swal.fire('Error / خطأ', 'فشلت معالجة الطلب على الخادم: ' + error, 'error');
              }
            });
          }
        });
      });
    });

    function updateBulkDeleteButtonState() {
      const count = $('.row-select-cb:checked').length;
      const btn = $('#btn-bulk-delete');
      
      if (count > 0) {
        btn.removeClass('disabled').prop('disabled', false);
        const text = currentLang === 'ar' ? `حذف الحقول المحددة (${count})` : `Delete Selected (${count})`;
        btn.find('span').text(text);
      } else {
        btn.addClass('disabled').prop('disabled', true);
        const text = currentLang === 'ar' ? 'حذف الحقول المحددة' : 'Delete Selected';
        btn.find('span').text(text);
      }
    }

    function applyPageTranslations(lang) {
      currentLang = lang;
      
      // Update body classes
      document.body.classList.toggle('lang-ar', lang === 'ar');
      document.body.classList.toggle('lang-en', lang === 'en');

      // Update data attributes i18n
      const elements = document.querySelectorAll('[data-page-i18n]');
      elements.forEach(el => {
        const key = el.getAttribute('data-page-i18n');
        if (pageTranslations[lang] && pageTranslations[lang][key]) {
          el.textContent = pageTranslations[lang][key];
        }
      });

      // Translate dynamic select options
      const dynamicOptions = document.querySelectorAll('option[data-label-ar]');
      dynamicOptions.forEach(opt => {
        const ar = opt.getAttribute('data-label-ar');
        const en = opt.getAttribute('data-label-en');
        opt.textContent = (lang === 'ar') ? ar : (en || ar);
      });
    }

    // Cascading Category -> SubCategory selection
    function initCategoriesCascade() {
      const catSelect = document.getElementById('filter-category');
      const subSelect = document.getElementById('filter-subcategory');

      catSelect.addEventListener('change', function() {
        const parentId = this.value;
        subSelect.value = ""; // Reset subcategory selection
        
        const subOptions = subSelect.querySelectorAll('option');
        subOptions.forEach(opt => {
          if (opt.value === "") return;
          
          const parentAttr = opt.getAttribute('data-parent');
          if (!parentId || parentAttr === parentId) {
            opt.style.display = "block";
          } else {
            opt.style.display = "none";
          }
        });
      });
    }

    // Custom Word Export
    function customWordExport(e, dt, button, config) {
        var html = "<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'>";
        html += "<head><meta charset='utf-8'><title>Export HTML To Doc</title></head><body>";
        html += "<h2 style='text-align:center;font-family:Arial;'>TalaPress Content Report</h2>";
        html += "<table border='1' style='width:100%; border-collapse: collapse; font-family:Arial;' dir='" + (currentLang === 'ar' ? 'rtl' : 'ltr') + "'>";
        
        // Headers
        html += "<thead><tr>";
        dt.columns(config.exportOptions.columns).header().each(function(th) {
            html += "<th style='background-color:#f8f9fa;padding:8px;'>" + $(th).text() + "</th>";
        });
        html += "</tr></thead>";
        
        // Body
        html += "<tbody>";
        dt.rows({ search: 'applied' }).every(function() {
            html += "<tr>";
            dt.cells(this.index(), config.exportOptions.columns).every(function() {
                var cellText = $('<div>' + this.render('display') + '</div>').text().trim();
                html += "<td style='padding:8px;'>" + cellText + "</td>";
            });
            html += "</tr>";
        });
        html += "</tbody></table></body></html>";
        
        var blob = new Blob(['\ufeff', html], { type: 'application/msword' });
        var url = URL.createObjectURL(blob);
        var downloadLink = document.createElement("a");
        downloadLink.href = url;
        downloadLink.download = 'TalaPress_Report.doc';
        document.body.appendChild(downloadLink);
        downloadLink.click();
        document.body.removeChild(downloadLink);
        setTimeout(function() { URL.revokeObjectURL(url); }, 100);
    }

    function isArabicChar(code) {
        if (code >= 0x0660 && code <= 0x0669) return false;
        if (code >= 0x06F0 && code <= 0x06F9) return false;
        
        return (code >= 0x0600 && code <= 0x06FF) || 
               (code >= 0x0750 && code <= 0x077F) || 
               (code >= 0xFB50 && code <= 0xFDFF) || 
               (code >= 0xFE70 && code <= 0xFEFF);
    }

    function fixArabicPdfText(text) {
        if (text === null || text === undefined) return "";
        text = String(text);
        if (!text.trim()) return text;
        
        // إضافة علامة RTL Mark (\u200F) حول علامات الترقيم لمنع تشويه الترتيب (Bidi Shifting) في قارئ الـ PDF
        text = text.replace(/:/g, '\u200F:\u200F')
                   .replace(/\|/g, '\u200F|\u200F')
                   .replace(/-/g, '\u200F-\u200F');
        
        var hasArabic = false;
        for (var i = 0; i < text.length; ++i) {
            var code = text.charCodeAt(i);
            if (isArabicChar(code)) {
                hasArabic = true;
                break;
            }
        }
        
        if (!hasArabic) return text;
        
        var words = text.split(' ');
        var processedWords = [];
        
        for (var j = 0; j < words.length; ++j) {
            var word = words[j];
            if (word === "") {
                processedWords.push("");
                continue;
            }
            
            var wordHasArabic = false;
            for (var k = 0; k < word.length; ++k) {
                if (isArabicChar(word.charCodeAt(k))) {
                    wordHasArabic = true;
                    break;
                }
            }
            
            if (wordHasArabic) {
                var shaped = ArabicReshaper.convertArabic(word);
                var reversed = shaped.split('').reverse().join('');
                processedWords.push(reversed);
            } else {
                processedWords.push(word);
            }
        }
        
        processedWords.reverse();
        return processedWords.join(' ');
    }

    // Custom PDF Export using jsPDF and autoTable with Amiri font
    function customPdfExport(e, dt, button, config) {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF({
            orientation: 'landscape',
            unit: 'mm',
            format: 'a4'
        });

        // Register Amiri font as bold too so bold headers don't fall back to Helvetica
        doc.addFont('Amiri-normal.ttf', 'Amiri', 'bold');

        // تعيين الخط والاتجاه
        doc.setFont("Amiri", "normal");
        doc.setFontSize(14);

        var isAr = currentLang === 'ar';
        var contentType = $('#filter-contentType option:selected').text();
        var hasContentType = $('#filter-contentType').val() !== "";
        var dateStr = new Date().toLocaleDateString(isAr ? 'ar-EG' : 'en-US');

        var reportTitle = "";
        if (isAr) {
            reportTitle = hasContentType ? `تقرير محتوى: ${contentType} - تاريخ: ${dateStr}` : `تقرير شامل للمحتوى - تاريخ: ${dateStr}`;
        } else {
            reportTitle = hasContentType ? `Content Report: ${contentType} - Date: ${dateStr}` : `Comprehensive Content Report - Date: ${dateStr}`;
        }

        // A4 landscape width is approx 297mm. Use 283 for right-aligned text.
        var textX = isAr ? 283 : 14;

        // ضبط اتجاه الصفحة
        doc.text(isAr ? fixArabicPdfText(reportTitle) : reportTitle, textX, 10, { align: isAr ? 'right' : 'left' });

        var filters = [];
        var status = $('#filter-status option:selected').text();
        
        if (hasContentType) filters.push((isAr ? 'النوع: ' : 'Type: ') + contentType);
        if ($('#filter-status').val() !== 'ALL') filters.push((isAr ? 'الحالة: ' : 'Status: ') + status);

        if (filters.length > 0) {
            doc.setFontSize(10);
            var filtersText = (isAr ? "الفلاتر: " : "Filters: ") + filters.join(' | ');
            doc.text(isAr ? fixArabicPdfText(filtersText) : filtersText, textX, 20, { align: isAr ? 'right' : 'left' });
        }

        // Extract Headers
        var headers = [];
        dt.columns(config.exportOptions.columns).header().each(function(th) {
            headers.push($(th).text());
        });

        // Extract Body
        var bodyData = [];
        dt.rows({ search: 'applied' }).every(function() {
            var row = [];
            dt.cells(this.index(), config.exportOptions.columns).every(function() {
                var cellText = $('<div>' + this.render('display') + '</div>').text().trim();
                row.push(cellText);
            });
            if (isAr) row.reverse(); // Reverse columns for RTL support in autotable
            bodyData.push(row);
        });
        
        if (isAr) headers.reverse();

        doc.autoTable({
            head: [headers],
            body: bodyData,
            startY: filters.length > 0 ? 30 : 25,
            styles: {
                font: "Amiri",
                fontStyle: "normal",
                fontSize: 10,
                halign: isAr ? 'right' : 'left'
            },
            headStyles: {
                font: "Amiri",
                fontStyle: "bold",
                fillColor: [173, 216, 230], // Light Blue
                halign: 'center',
                textColor: 20
            },
            bodyStyles: {
                font: "Amiri",
                fontStyle: "normal"
            },
            alternateRowStyles: { fillColor: [245, 245, 245] },
            margin: { left: 10, right: 10 }
        });

        doc.save("TalaPress_Content_Export.pdf");
    }

    // Server-Side Export Interceptor
    function newExportAction(e, dt, button, config) {
        var self = this;
        var oldStart = dt.settings()[0]._iDisplayStart;
        var oldLength = dt.settings()[0]._iDisplayLength;
        
        // Temporarily fetch all data (-1)
        dt.page.len(-1);
        dt.one('preDraw', function (e, settings) {
            // Call original action based on button type
            if (button[0].className.indexOf('buttons-excel') >= 0) {
                $.fn.dataTable.ext.buttons.excelHtml5.action.call(self, e, dt, button, config);
            } else if (button[0].className.indexOf('buttons-pdf') >= 0) {
                customPdfExport(e, dt, button, config);
            } else if (button[0].className.indexOf('buttons-word') >= 0) {
                customWordExport(e, dt, button, config);
            } else if (button[0].className.indexOf('buttons-print') >= 0) {
                $.fn.dataTable.ext.buttons.print.action.call(self, e, dt, button, config);
            }
            // Restore pagination on next XHR
            dt.one('preXhr', function (e, s, data) {
                settings._iDisplayStart = oldStart;
                settings._iDisplayLength = oldLength;
            });
            // Reload data with original settings
            setTimeout(dt.ajax.reload, 0);
            return false;
        });
        // Trigger reload to fetch all data
        dt.ajax.reload();
    }

    // Initialize jQuery DataTables with server-side queries
    function initContentDataTable() {
      contentTable = $('#contentTable').DataTable({
        processing: true,
