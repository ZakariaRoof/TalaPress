        btnSearch: "Apply Filters",
        colImage: "Featured Image",
        colTitle: "Title",
        colType: "Content Type",
        colCategory: "Category",
        colSubCategory: "SubCategory",
        colStatus: "Status",
        colPublishDate: "Publish Date",
        colAuthor: "Author",
        colHits: "Hits",
        colCreated: "Created Date",
