                </div>
              </div>

              <div class="alert alert-info py-2 fs-8 d-none" id="dynamic-options-help">
                <i class="bi bi-info-circle me-1"></i>
                <span class="tp-only-ar">القيمة تحفظ كرقم السجل، والاسم يظهر كخيار حسب لغة الواجهة.</span>
                <span class="tp-only-en">The stored value is the record ID, and the label follows the interface language.</span>
              </div>

              <div class="border rounded-3 bg-body-tertiary mb-3 d-none" id="query-options-builder">
                <!-- Query Mode Tabs -->
                <ul class="nav nav-tabs px-3 pt-2" id="query-mode-tabs" role="tablist">
                  <li class="nav-item" role="presentation">
                    <button class="nav-link active d-flex align-items-center gap-1" id="tab-builder-btn"
                            data-bs-toggle="tab" data-bs-target="#tab-builder-pane" type="button" role="tab">
                      <i class="bi bi-diagram-3"></i>
                      <span class="tp-only-ar">منشئ مرئي</span>
                      <span class="tp-only-en">Builder</span>
                    </button>
                  </li>
                  <li class="nav-item" role="presentation">
                    <button class="nav-link d-flex align-items-center gap-1" id="tab-sqlquery-btn"
                            data-bs-toggle="tab" data-bs-target="#tab-sqlquery-pane" type="button" role="tab">
                      <i class="bi bi-terminal"></i>
                      <span class="tp-only-ar">استعلام SQL</span>
                      <span class="tp-only-en">SQL Query</span>
                    </button>
                  </li>
                </ul>
                <div class="tab-content p-3">

                  <!-- TAB 1: Visual Builder -->
                  <div class="tab-pane fade show active" id="tab-builder-pane" role="tabpanel">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                      <div class="fw-bold text-primary-emphasis fs-8">
                        <span class="tp-only-ar">حدد الجدول، أضف شروط الفلترة، ثم اضغط تنفيذ لتوليد الخيارات.</span>
                        <span class="tp-only-en">Select a table, add filter rules, then click Execute to generate options.</span>
                      </div>
                      <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="addOptionsQueryRule()">
                          <i class="bi bi-plus-circle me-1"></i>Add Rule
                        </button>
                        <button type="button" class="btn btn-sm btn-success" onclick="executeOptionsQuery()">
                          <i class="bi bi-play-fill me-1"></i>
                          <span class="tp-only-ar">تنفيذ</span>
                          <span class="tp-only-en">Execute</span>
                        </button>
                      </div>
                    </div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                      <select class="form-select form-select-sm" id="options-query-table" style="max-width:260px;" onchange="onOptionsQueryTableChanged()">
                        @foreach (var table in Model.DatabaseTables)
                        {
                          <option value="@table.Name">@table.Name</option>
                        }
                      </select>
                      <select class="form-select form-select-sm" id="options-query-logic" style="width:110px;">
                        <option value="AND">AND</option>
                        <option value="OR">OR</option>
                      </select>
                      <span class="text-muted fs-8 text-nowrap flex-shrink-0">
                        <span class="tp-only-ar">العمليات باللغة الإنجليزية، والبحث يراعي الحقول العربية والإنجليزية مثل Title و Summary.</span>
                        <span class="tp-only-en">Operators are English; Title/Summary search Arabic and English columns.</span>
                      </span>
                    </div>
                    <div id="options-query-rules" class="vstack gap-2 mb-3"></div>
                  </div>

                  <!-- TAB 2: SQL Query -->
                  <div class="tab-pane fade" id="tab-sqlquery-pane" role="tabpanel">
                    <div class="alert alert-warning py-2 fs-8 mb-3">
                      <i class="bi bi-shield-lock-fill me-1"></i>
                      <span class="tp-only-ar">يُسمح فقط بجمل <strong>SELECT</strong>. لا يُسمح بأوامر INSERT أو UPDATE أو DELETE أو DROP. يجب أن يحتوي الاستعلام على عمودين على الأقل: الأول للقيمة (value) والثاني للاسم (label).</span>
                      <span class="tp-only-en">Only <strong>SELECT</strong> statements are allowed. INSERT, UPDATE, DELETE, DROP are blocked. The query must return at least 2 columns: first for value, second for label.</span>
                    </div>
                    <div class="mb-3">
                      <label class="form-label fw-semibold fs-8">
                        <span class="tp-only-ar">الاستعلام (مثال: <code>SELECT Id, Name, Name_En FROM dbo.Categories WHERE IsActive=1</code>)</span>
                        <span class="tp-only-en">SQL Query (e.g. <code>SELECT Id, Name, Name_En FROM dbo.Categories WHERE IsActive=1</code>)</span>
                      </label>
                      <textarea id="sql-query-textarea" class="form-control font-monospace" rows="5" dir="ltr"
                                placeholder="SELECT Id, Name, Name_En FROM dbo.Categories WHERE IsActive = 1 ORDER BY Name"
                                style="font-size:0.82rem; resize:vertical;"></textarea>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                      <button type="button" class="btn btn-sm btn-success" onclick="executeSqlQuery()">
                        <i class="bi bi-play-fill me-1"></i>
                        <span class="tp-only-ar">تنفيذ الاستعلام</span>
                        <span class="tp-only-en">Execute Query</span>
                      </button>
                      <span id="sql-query-spinner" class="d-none">
                        <span class="spinner-border spinner-border-sm text-primary me-1" role="status"></span>
                        <span class="tp-only-ar fs-8">جاري التنفيذ...</span>
                        <span class="tp-only-en fs-8">Executing...</span>
                      </span>
                      <span id="sql-query-status" class="fs-8 text-muted"></span>
                    </div>
                  </div>

                </div>
              </div>
              
              <div class="input-group mb-2" id="static-options-builder">
                <input type="text" class="form-control form-control-sm" id="opt-value" 
                       data-title-ar="الكود (Value)" data-title-en="Value Code (Value)" />
                <input type="text" class="form-control form-control-sm tp-only-ar" id="opt-label-ar" />
                <input type="text" class="form-control form-control-sm tp-only-en" id="opt-label-en" />
                <button type="button" class="btn btn-sm btn-primary" onclick="addOptionToBuilder()"><i class="bi bi-plus-lg"></i></button>
              </div>

              <div class="table-responsive border rounded-3 bg-body-tertiary">
                <table class="table table-sm align-middle mb-0 text-center">
                  <thead class="table-light">
                    <tr>
                      <th>
                        <span class="tp-only-ar">الكود</span>
                        <span class="tp-only-en">Value Code</span>
                      </th>
                      <th class="tp-only-ar">الاسم بالعربية</th>
                      <th class="tp-only-en">Label (English)</th>
                      <th>
                        <span class="tp-only-ar">عمليات</span>
                        <span class="tp-only-en">Actions</span>
                      </th>
                    </tr>
                  </thead>
                  <tbody id="opt-table-body">
                    <!-- Dynamic -->
                  </tbody>
                </table>
              </div>
            </div>

          </div>

          <div class="d-flex gap-2 justify-content-end border-top pt-3 mt-4">
            <button type="submit" class="btn btn-primary px-4 fw-bold">
              <i class="bi bi-check2-circle me-1"></i> 
              <span class="tp-only-ar">تأكيد وحفظ</span>
              <span class="tp-only-en">Confirm & Save</span>
            </button>
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
              <span class="tp-only-ar">إلغاء</span>
              <span class="tp-only-en">Cancel</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- PREVIEW ENTRY FORM MODAL -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content shadow-lg rounded-3">
      <div class="modal-header bg-info-subtle border-bottom border-info-subtle text-info-emphasis">
        <h5 class="modal-title fw-bold" id="previewModalLabel">
          <i class="bi bi-eye-fill me-2"></i>
          <span data-page-i18n="previewModalTitle">معاينة نموذج إدخال المحتوى</span>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <!-- Language Switcher for Preview -->
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
          <div class="fs-8 text-secondary">
            <i class="bi bi-info-circle-fill me-1"></i>
            <span data-page-i18n="previewDesc">هذه معاينة حية تفاعلية للنموذج النهائي كما سيظهر للكتّاب والمحررين.</span>
          </div>
          <div class="btn-group btn-group-sm" role="group">
            <button type="button" class="btn btn-outline-primary active" id="preview-lang-ar" onclick="togglePreviewLang('ar')">العربية</button>
            <button type="button" class="btn btn-outline-primary" id="preview-lang-en" onclick="togglePreviewLang('en')">English</button>
          </div>
        </div>
        
        <!-- Form Fields Container -->
        <div id="preview-form-container" class="row g-3">
          <!-- Dynamic content -->
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary shadow-sm" data-bs-dismiss="modal">
          <span class="tp-only-ar">إغلاق المعاينة</span>
          <span class="tp-only-en">Close Preview</span>
        </button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <!-- SortableJS served locally -->
  <script src="~/assets/js/sortable.min.js" asp-append-version="true"></script>
  
  <script>
    // Initial load of custom fields from the page model
    let customFields = [];
    let modalOptions = []; // Array of options { value: '', label: '', labelEn: '' } for current editing field
    let previewLang = 'ar';
    const dynamicMainCategories = @Html.Raw(JsonSerializer.Serialize(Model.MainCategoryOptions));
    const dynamicSubCategories = @Html.Raw(JsonSerializer.Serialize(Model.SubCategoryOptions));
    const dynamicRoles = @Html.Raw(JsonSerializer.Serialize(Model.RoleOptions));
    const dynamicRoleUsers = @Html.Raw(JsonSerializer.Serialize(Model.RoleUserOptions));
    const databaseTables = @Html.Raw(JsonSerializer.Serialize(Model.DatabaseTables));
    const databaseColumns = @Html.Raw(JsonSerializer.Serialize(Model.DatabaseColumns));

    const pageTranslations = {
      ar: {
        pageTitle: "منشئ أنواع المحتوى (Content Type Builder)",
        pageDesc: "قم بتصميم وتعديل أنواع المحتوى وقوالب البيانات، وإضافة حقول مخصصة بالكامل لصحفيتك الرقمية.",
        btnAddNewType: "إنشاء نوع جديد",
        listHeader: "قوالب أنواع المحتوى المتوفرة",
        badgeSystem: "أساسي",
        headerAdd: "إنشاء قالب نوع محتوى جديد",
        headerEdit: "تعديل قالب المحتوى: ",
        metaHeader: "البيانات التعريفية لنوع المحتوى",
        labelTypeNameAr: "الاسم بالعربية",
        labelTypeNameEn: "الاسم بالإنجليزية",
        labelTypeDescAr: "الوصف بالعربية",
        labelTypeDescEn: "الوصف بالإنجليزية",
        labelIcon: "الأيقونة (Bootstrap Icons)",
        labelStatus: "حالة التنشيط",
        customFieldsHeader: "حقول قالب المحتوى والترتيب (سحب وإفلات لإعادة الترتيب)",
        btnAddField: "إضافة حقل مخصص",
        btnPreviewForm: "معاينة نموذج الإدخال",
        btnSave: "حفظ نوع المحتوى وحقوله",
        btnCancel: "إلغاء التغييرات",
        statusActive: "نشط ومتاح للاستخدام",
        modalTitleAdd: "إعداد الحقل المخصص",
        modalSaveBtn: "تأكيد وحفظ",
        noCustomFields: "لا توجد حقول معرفة حالياً. اضغط على 'إضافة حقل مخصص' للبدء.",
        requiredLabel: "مطلوب إجباري",
        translatableLabel: "يقبل الترجمة",
        helpText: "مساعدة",
        previewModalTitle: "معاينة نموذج إدخال المحتوى",
        previewDesc: "هذه معاينة حية تفاعلية للنموذج النهائي كما سيظهر للكتّاب والمحررين."
      },
      en: {
        pageTitle: "Content Type Builder",
        pageDesc: "Design and build content models, schemas and data configurations with fully integrated custom fields.",
        btnAddNewType: "Create New Type",
        listHeader: "Available Content Models",
        badgeSystem: "System",
        headerAdd: "Create New Content Model",
        headerEdit: "Edit Content Model: ",
        metaHeader: "Content Model Details",
        labelTypeNameAr: "Name (Arabic)",
        labelTypeNameEn: "Name (English)",
        labelTypeDescAr: "Description (Arabic)",
        labelTypeDescEn: "Description (English)",
        labelIcon: "Icon (Bootstrap Icons)",
        labelStatus: "Status",
        customFieldsHeader: "Content Model Layout & Schema (Drag and drop to reorder)",
        btnAddField: "Add Custom Field",
        btnPreviewForm: "Preview Entry Form",
        btnSave: "Save Content Model & Schema",
        btnCancel: "Cancel Changes",
        statusActive: "Active and available for use",
        modalTitleAdd: "Configure Custom Attribute",
        modalSaveBtn: "Confirm & Add",
        noCustomFields: "No attributes configured. Click 'Add Custom Field' to start.",
        requiredLabel: "Required",
        translatableLabel: "Translatable",
        helpText: "Help Text",
        previewModalTitle: "Preview Content Entry Form",
        previewDesc: "This is a live interactive preview of the final entry form for writers/editors."
      }
    };

    let currentLang = localStorage.getItem('tp-lang') || 'ar';
    let fieldModalInstance = null;
    let previewModalInstance = null;

    const reservedNames = ['id', 'title', 'slug', 'summary', 'content', 'featuredimage', 'status', 'publishdate', 'categoryid', 'subcategoryid', 'seotitle', 'seodescription', 'seokeywords', 'canonicalurl'];
    const seoFieldNames = ['seotitle', 'seodescription', 'seokeywords', 'canonicalurl'];

    document.addEventListener('DOMContentLoaded', () => {
      // Initialize Bootstrap Modals
      fieldModalInstance = new bootstrap.Modal(document.getElementById('fieldModal'));
      previewModalInstance = new bootstrap.Modal(document.getElementById('previewModal'));

      // Initialize static label popovers on the page (metadata and modal)
      const staticPopovers = document.querySelectorAll('label [data-bs-toggle="popover"], .form-label [data-bs-toggle="popover"]');
      staticPopovers.forEach(el => {
        new bootstrap.Popover(el, {
          sanitize: false,
          placement: 'auto'
        });
      });

      // Load existing fields
      const initialJson = document.getElementById('form-customfieldsjson').value;
      try {
        customFields = JSON.parse(initialJson || '[]');
        normalizeCustomFieldsOrder();
      } catch (e) {
        customFields = [];
      }

      // Render custom fields
      renderCustomFields();

      // Initialize SortableJS
      initSortableWorkspace();

      // Align forms layout on initial load
      applyPageTranslations(currentLang);

      // Listen to language changes
      window.addEventListener('tp-lang-changed', (e) => {
        applyPageTranslations(e.detail.lang);
      });

      // Bind show field modal buttons
      document.getElementById('btn-add-field').addEventListener('click', () => {
        openFieldModalForAdd();
      });

      // Synchronize live icon preview
      const iconInput = document.getElementById('form-icon');
      if (iconInput) {
        iconInput.addEventListener('input', function() {
          const preview = document.getElementById('icon-preview');
          preview.innerHTML = `<i class="bi ${this.value || 'bi-folder-fill'}"></i>`;
        });
      }

      // Sync field type selection to show/hide options JSON builder
      document.getElementById('modal-fieldtype').addEventListener('change', function() {
        const type = this.value;
        const optionsWrapper = document.getElementById('modal-options-wrapper');
        if (type === 'Select' || type === 'MultiSelect') {
          optionsWrapper.classList.remove('d-none');
          onOptionsModeChanged();
        } else {
          optionsWrapper.classList.add('d-none');
        }
      });

      document.getElementById('modal-fieldname').addEventListener('input', function() {
        this.value = this.value.replace(/[^A-Za-z0-9_]/g, '');
        if (this.value && !/^[A-Za-z]/.test(this.value)) {
          this.value = this.value.replace(/^[^A-Za-z]+/, '');
        }
      });

      // Form submission sync
      document.getElementById('contentTypeForm').addEventListener('submit', function(e) {
        normalizeCustomFieldsOrder();

        // Prepare sort indexes
        customFields.forEach((field, index) => {
          field.SortOrder = index + 1;
        });

        // Sync hidden Name / Description inputs to ensure backend validation passes
        const nameAr = document.getElementById('form-name').value.trim();
        const nameEn = document.getElementById('form-name-en').value.trim();
        const descAr = document.getElementById('form-desc').value.trim();
        const descEn = document.getElementById('form-desc-en').value.trim();
        
        if (currentLang === 'ar') {
          if (!nameEn) {
            document.getElementById('form-name-en').value = nameAr;
          }
          if (!descEn) {
            document.getElementById('form-desc-en').value = descAr;
          }
        } else if (currentLang === 'en') {
          if (!nameAr) {
            document.getElementById('form-name').value = nameEn;
          }
          if (!descAr) {
            document.getElementById('form-desc').value = descEn;
          }
        }

        // Set value
        document.getElementById('form-customfieldsjson').value = JSON.stringify(customFields);
      });
    });

    function confirmDeleteType(e) {
      e.preventDefault();

      const form = e.target;
      const isAr = currentLang === 'ar';

      if (typeof Swal === 'undefined') {
        form.submit();
        return false;
      }

      Swal.fire({
        title: isAr ? 'هل أنت متأكد؟' : 'Are you sure?',
        text: isAr
          ? 'سيتم حذف قالب نوع المحتوى وجميع حقوله والمحتوى المرتبط به نهائياً.'
          : 'This will permanently delete the content model, its fields, and related content.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: isAr ? 'نعم، احذف' : 'Yes, delete',
        cancelButtonText: isAr ? 'إلغاء' : 'Cancel',
        reverseButtons: isAr
      }).then((result) => {
        if (result.isConfirmed) {
          form.submit();
        }
      });

      return false;
    }

    function applyPageTranslations(lang) {
      currentLang = lang;

      // Toggle body language classes
      document.body.classList.toggle('lang-ar', lang === 'ar');
      document.body.classList.toggle('lang-en', lang === 'en');

      // Manage required attributes dynamically to prevent browser block on hidden elements
      const formName = document.getElementById('form-name');
      const formNameEn = document.getElementById('form-name-en');
      const modalLabel = document.getElementById('modal-label');
      const modalLabelEn = document.getElementById('modal-label-en');
      
      if (lang === 'ar') {
        if (formName) formName.setAttribute('required', 'required');
        if (formNameEn) formNameEn.removeAttribute('required');
        if (modalLabel) modalLabel.setAttribute('required', 'required');
        if (modalLabelEn) modalLabelEn.setAttribute('required', 'required');
      } else {
        if (formNameEn) formNameEn.setAttribute('required', 'required');
        if (formName) formName.removeAttribute('required');
        if (modalLabelEn) modalLabelEn.setAttribute('required', 'required');
        if (modalLabel) modalLabel.setAttribute('required', 'required');
      }

      const elements = document.querySelectorAll('[data-page-i18n]');
      elements.forEach(el => {
        const key = el.getAttribute('data-page-i18n');
        if (pageTranslations[lang] && pageTranslations[lang][key]) {
          if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
            el.setAttribute('placeholder', pageTranslations[lang][key]);
          } else {
            el.textContent = pageTranslations[lang][key];
          }
        }
      });

      // Translate titles and placeholders for custom fields
      const titleElements = document.querySelectorAll('[data-title-ar]');
      titleElements.forEach(el => {
        const text = lang === 'ar' ? el.getAttribute('data-title-ar') : el.getAttribute('data-title-en');
        el.setAttribute('title', text);
      });

      // Translate optgroup labels in field type select
      const selectEl = document.getElementById('modal-fieldtype');
      if (selectEl) {
        const optgroups = selectEl.querySelectorAll('optgroup');
        if (optgroups.length >= 5) {
          if (lang === 'ar') {
            optgroups[0].label = 'حقول المحتوى';
            optgroups[1].label = 'حقول الاختيار';
            optgroups[2].label = 'حقول الوسائط';
            optgroups[3].label = 'حقول التاريخ';
            optgroups[4].label = 'حقول أخرى';
          } else {
            optgroups[0].label = 'Content Fields';
            optgroups[1].label = 'Selection Fields';
            optgroups[2].label = 'Media Fields';
            optgroups[3].label = 'Date Fields';
            optgroups[4].label = 'Other Fields';
          }
        }
      }

      // Re-render fields visually to show localized names/labels
      renderCustomFields();
      if (document.getElementById('modal-options-wrapper') && !document.getElementById('modal-options-wrapper').classList.contains('d-none')) {
        const selectedDynamicParent = document.getElementById('dynamic-parent')?.value || '';
        populateDynamicParentOptions(selectedDynamicParent);
        if (document.getElementById('options-mode').value === 'dynamic') {
          refreshDynamicOptionsPreview();
        }
      }
    }

    // Sortable reordering binding
    function initSortableWorkspace() {
      const el = document.getElementById('custom-fields-workspace');
      if (el) {
        new Sortable(el, {
          handle: '.tp-drag-handle',
          ghostClass: 'tp-sortable-ghost',
          chosenClass: 'tp-sortable-chosen',
          dragClass: 'tp-sortable-drag',
          onEnd: function (evt) {
            // Reorder the local array based on the DOM child node indices
            const children = Array.from(el.children);
            const newOrder = [];
            children.forEach(child => {
              const name = child.getAttribute('data-fieldname');
              const item = customFields.find(f => f.FieldName === name);
              if (item) {
                newOrder.push(item);
              }
            });
            const cardListFields = customFields.filter(f => isCardListField(f));
            const seoFields = customFields.filter(f => isSeoField(f));
            customFields = [...newOrder, ...cardListFields, ...seoFields];
            renderCustomFields(); // Re-render to keep indices fresh
          }
        });
      }
    }

    function isCardListField(field) {
      return field && String(field.FieldType || '').toLowerCase() === 'cardlist';
    }

    function normalizeCustomFieldsOrder() {
      customFields = [
        ...customFields.filter(field => !isSeoField(field) && !isCardListField(field)),
        ...customFields.filter(field => isCardListField(field)),
        ...customFields.filter(field => isSeoField(field))
      ];
    }

    function renderCustomFields() {
      const container = document.getElementById('custom-fields-workspace');
      if (!container) return;

      // Dispose of existing popovers first to prevent memory leaks or orphaned elements
      const existingPopovers = container.querySelectorAll('[data-bs-toggle="popover"]');
      existingPopovers.forEach(el => {
        const instance = bootstrap.Popover.getInstance(el);
        if (instance) {
          instance.dispose();
        }
      });

      container.innerHTML = '';
      const editableLayoutFields = customFields.filter(field => !isSeoField(field) && !isCardListField(field));
      if (editableLayoutFields.length === 0) {
        container.innerHTML = `
          <div class="text-center text-muted py-4">
            <i class="bi bi-grid-3x3-gap fs-1 d-block mb-2 text-secondary opacity-50"></i>
