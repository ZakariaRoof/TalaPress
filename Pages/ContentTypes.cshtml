                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                        data-bs-content="تعليمات تفصيلية تظهر بخط صغير تحت صندوق الإدخال لمساعدة المحررين وإيضاح أية شروط إضافية."
                        style="text-decoration: none;" title="نص المساعدة">
