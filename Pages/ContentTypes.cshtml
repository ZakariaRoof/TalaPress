            <div class="d-flex align-items-center gap-2 flex-shrink-0 ms-2">
              <div class="form-check form-switch mb-0 me-2">
                <input class="form-check-input" type="checkbox" id="active-${index}" ${field.IsActive ? 'checked' : ''} onchange="toggleFieldActive(${index}, this.checked)" title="تبديل ظهور الحقل في نموذج الإدخال">
                <label class="form-check-label fs-8 text-muted" for="active-${index}">${field.IsActive ? (currentLang === 'ar' ? 'ظاهر' : 'Visible') : (currentLang === 'ar' ? 'مخفي' : 'Hidden')}</label>
