@page
@using System.Text.Json
@model TalaPress.Pages.ContentTypesModel
@{
    ViewData["Title"] = "منشئ أنواع المحتوى";
}

<!-- SECONDARY HEADER (BLUE BAR) -->
<section class="tp-sub-header">
  <div class="container-fluid px-4">
    <div class="row align-items-center">
      <div class="col-md-7 mb-3 mb-md-0">
        <h1 data-page-i18n="pageTitle">منشئ أنواع المحتوى (Content Type Builder)</h1>
        <p data-page-i18n="pageDesc">قم بتصميم وتعديل أنواع المحتوى وقوالب البيانات، وإضافة حقول مخصصة بالكامل لصحفيتك الرقمية.</p>
      </div>
      <div class="col-md-5 text-md-end">
        <a asp-page="/Index" class="btn tp-btn-outline-light me-2">
          <i class="bi bi-house-door-fill"></i> <span data-tp-i18n="home">الرئيسية</span>
        </a>
        <a asp-page="/ContentTypes" asp-route-selectedId="0" class="btn btn-light shadow-sm">
          <i class="bi bi-plus-lg text-primary fw-bold"></i> <span class="text-primary fw-bold" data-page-i18n="btnAddNewType">إنشاء نوع جديد</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- MAIN CONTAINER -->
<main class="container-fluid px-4 pb-5">

  @if (Model.SuccessMessage != null)
  {
      <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm rounded-3" role="alert">
          <i class="bi bi-check-circle-fill me-2 fs-5"></i> @Model.SuccessMessage
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
  }

  @if (Model.ErrorMessage != null)
  {
      <div class="alert alert-danger alert-dismissible fade show mb-4 border-0 shadow-sm rounded-3" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i> @Model.ErrorMessage
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
  }

  <div class="row">
    <!-- LEFT PANEL: Content Types Grid -->
    <div class="col-lg-5 mb-4">
      <div class="tp-card mb-0">
        <div class="tp-card-header d-flex align-items-center justify-content-between">
          <h5 data-page-i18n="listHeader">قوالب أنواع المحتوى المتوفرة</h5>
          <span class="badge bg-secondary rounded-pill">@Model.ContentTypeList.Count</span>
        </div>
        <div class="tp-card-body p-2">
          <div class="row row-cols-1 row-cols-md-2 g-2">
            @foreach (var type in Model.ContentTypeList)
            {
                var isSelected = Model.SelectedTypeId == type.Id;
                <div class="col">
                  <div class="card h-100 rounded-3 position-relative overflow-hidden tp-ct-card
                              @(isSelected ? "border-primary border-2 shadow" : "border border-light-subtle shadow-sm")"
                       onclick="window.location.href='?selectedId=@type.Id'"
                       role="button" style="cursor:pointer;transition:box-shadow .15s,border-color .15s;">

                    @if (isSelected)
                    {
                        <div class="position-absolute top-0 start-0 h-100" style="width:4px;background:var(--bs-primary);"></div>
                    }

                    <div class="card-body ps-4">
                      <div class="d-flex align-items-start gap-3 mb-2">
                        <div class="flex-shrink-0 rounded-3 d-flex align-items-center justify-content-center
                                    @(isSelected ? "bg-primary text-white" : "bg-primary-subtle text-primary")"
                             style="width:42px;height:42px;font-size:1.15rem;">
                          <i class="@(type.IconValue ?? "bi bi-folder-fill")"></i>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                          <div class="fw-bold fs-6 lh-sm">
                            <span class="tp-only-ar">@type.Name</span>
                            <span class="tp-only-en">@(type.Name_En ?? type.Name)</span>
                          </div>
                          <div class="text-secondary fs-8 mt-1">
                            <span title="عدد المحتوى / Content count">محتوى @type.ContentCount</span>
                            <span class="mx-1">|</span>
                            <span title="عدد الفئات / Categories count">فئات @type.CategoryCount</span>
                          </div>
                          <div class="d-flex flex-wrap gap-1 mt-1">
                            @if (type.IsSystem)
                            {
                                <span class="badge bg-info text-dark fs-8" data-page-i18n="badgeSystem">أساسي</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border fs-8">مخصص</span>
                            }
                            <span class="badge @(type.IsActive ? "bg-success" : "bg-danger") fs-8">
                              <span class="tp-only-ar">@(type.IsActive ? "نشط" : "معطل")</span>
                              <span class="tp-only-en">@(type.IsActive ? "Active" : "Inactive")</span>
                            </span>
                          </div>
                        </div>
                      </div>
                      <p class="text-secondary fs-8 mb-0 tp-only-ar"
                         style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                        @(string.IsNullOrWhiteSpace(type.Description) ? "لا يوجد وصف لهذا القالب." : type.Description)
                      </p>
                      <p class="text-secondary fs-8 mb-0 tp-only-en"
                         style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                        @(string.IsNullOrWhiteSpace(type.Description_En) ? "No description available." : type.Description_En)
                      </p>
                      <div class="d-flex flex-wrap align-items-center gap-3 mt-3 text-secondary fs-8">
                        <div class="d-inline-flex align-items-center gap-1" title="عدد المحتوى / Content count">
                          <span class="tp-only-ar">محتوى</span>
                          <span class="tp-only-en">Content</span>
                          <span class="rounded-circle bg-secondary-subtle text-secondary-emphasis border d-inline-flex align-items-center justify-content-center fw-bold"
                                style="width:26px;height:26px;line-height:1;">@type.ContentCount</span>
                        </div>
                        <span class="text-secondary opacity-50">|</span>
                        <div class="d-inline-flex align-items-center gap-1" title="عدد الفئات / Categories count">
                          <span class="tp-only-ar">فئات</span>
                          <span class="tp-only-en">Categories</span>
                          <span class="rounded-circle bg-secondary-subtle text-secondary-emphasis border d-inline-flex align-items-center justify-content-center fw-bold"
                                style="width:26px;height:26px;line-height:1;">@type.CategoryCount</span>
                        </div>
                      </div>
                    </div>

                    <div class="card-footer bg-transparent border-top border-light-subtle px-4 py-2 d-flex justify-content-end gap-2"
                         onclick="event.stopPropagation()">
                      <form method="post" asp-page-handler="Clone" asp-route-id="@type.Id" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-primary px-2 py-1"
                                data-title-ar="نسخ قالب البيانات" data-title-en="Clone Template">
                          <i class="bi bi-files me-1"></i><span class="fs-8">نسخ</span>
                        </button>
                      </form>
                      @if (!type.IsSystem)
                      {
                          <form method="post" asp-page-handler="Delete" asp-route-id="@type.Id"
                                onsubmit="return confirmDeleteType(event);" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger px-2 py-1"
                                    data-title-ar="حذف نوع المحتوى" data-title-en="Delete Content Type">
                              <i class="bi bi-trash-fill me-1"></i><span class="fs-8">حذف</span>
                            </button>
                          </form>
                      }
                    </div>

                  </div>
                </div>
            }
          </div>
        </div>
      </div>
    </div>


    <!-- RIGHT PANEL: Visual Field Builder Workspace -->
    <div class="col-lg-7 mb-4" id="builder-col-main">
      <div class="tp-card h-100 mb-0" id="builder-card">
        <div class="tp-card-header">
          <h5 id="builder-header-title">
            <i class="bi bi-folder-plus text-primary me-2"></i>
            @if (Model.Id == 0)
            {
                <span data-page-i18n="headerAdd">إنشاء قالب نوع محتوى جديد</span>
            }
            else
            {
                <span data-page-i18n="headerEdit">تعديل قالب المحتوى: </span> <span>@Model.Name</span>
            }
          </h5>
          <i class="bi bi-kanban-fill text-secondary"></i>
        </div>

        <div class="tp-card-body">
          <form method="post" asp-page-handler="Save" id="contentTypeForm">
            <input type="hidden" asp-for="Id" id="form-Id" />
            <input type="hidden" asp-for="CustomFieldsJson" id="form-customfieldsjson" />

            <!-- Content Type Metadata Group -->
            <h6 class="fw-bold mb-3 border-bottom pb-2" data-page-i18n="metaHeader">البيانات التعريفية لنوع المحتوى</h6>
            <div class="row g-3 mb-4">
              <div class="col-md-6 tp-only-ar">
                <label class="form-label">
                  <span data-page-i18n="labelTypeNameAr">الاسم بالعربية</span> <span class="text-danger">*</span>
                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                          data-bs-content="الاسم العربي الذي يظهر للمحررين في القائمة الجانبية وشاشات الإدخال."
                          style="text-decoration: none;" title="الاسم بالعربية">
                    <i class="bi bi-info-circle fs-8"></i>
                  </button>
                </label>
                <input type="text" asp-for="Name" class="form-control" required id="form-name" />
              </div>
              <div class="col-md-6 tp-only-en">
                <label class="form-label">
                  <span data-page-i18n="labelTypeNameEn">الاسم بالإنجليزية</span> <span class="text-danger">*</span>
                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                          data-bs-content="English identifier name of the content type, used in multilingual views."
                          style="text-decoration: none;" title="Name (English)">
                    <i class="bi bi-info-circle fs-8"></i>
                  </button>
                </label>
                <input type="text" asp-for="Name_En" class="form-control" required id="form-name-en" />
              </div>
              <div class="col-md-6 tp-only-ar">
                <label class="form-label">
                  <span data-page-i18n="labelTypeDescAr">الوصف بالعربية</span>
                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                          data-bs-content="نبذة مختصرة توضح الغرض من نوع المحتوى هذا للمحررين."
                          style="text-decoration: none;" title="الوصف بالعربية">
                    <i class="bi bi-info-circle fs-8"></i>
                  </button>
                </label>
                <textarea asp-for="Description" class="form-control" rows="2" id="form-desc"></textarea>
              </div>
              <div class="col-md-6 tp-only-en">
                <label class="form-label">
                  <span data-page-i18n="labelTypeDescEn">الوصف بالإنجليزية</span>
                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                          data-bs-content="Brief description of this content type in English."
                          style="text-decoration: none;" title="Description (English)">
                    <i class="bi bi-info-circle fs-8"></i>
                  </button>
                </label>
                <textarea asp-for="Description_En" class="form-control" rows="2" id="form-desc-en"></textarea>
              </div>
              <div class="col-md-6">
                <label class="form-label">
                  <span data-page-i18n="labelIcon">الأيقونة (Bootstrap Icons)</span>
                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                          data-bs-content="اسم فئة أيقونة Bootstrap المستعملة لتمييز نوع المحتوى بصرياً (مثال: bi-file-earmark-text)."
                          style="text-decoration: none;" title="الأيقونة">
                    <i class="bi bi-info-circle fs-8"></i>
                  </button>
                </label>
                <div class="input-group">
                  <span class="input-group-text" id="icon-preview"><i class="bi @Model.IconValue"></i></span>
                  <input type="text" asp-for="IconValue" class="form-control" id="form-icon" />
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label">
                  <span data-page-i18n="labelStatus">حالة التنشيط</span>
                  <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center" 
                          data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                          data-bs-content="تحديد ما إذا كان هذا القالب متاحاً للاستخدام الفوري لإنشاء محتوى جديد."
                          style="text-decoration: none;" title="حالة التنشيط">
                    <i class="bi bi-info-circle fs-8"></i>
                  </button>
                </label>
                <div class="form-check form-switch mt-2">
                  <input class="form-check-input" type="checkbox" asp-for="IsActive" id="form-isactive" />
                  <label class="form-check-label fw-bold text-success ms-2" for="form-isactive" id="label-isactive" data-page-i18n="statusActive">نشط ومتاح للاستخدام</label>
                </div>
              </div>
            </div>

            <!-- Single Sortable Workspace -->
            <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-3 mt-4">
              <h6 class="fw-bold mb-0">
                <i class="bi bi-layers-half text-primary me-1"></i>
                <span data-page-i18n="customFieldsHeader">حقول قالب المحتوى والترتيب (سحب وإفلات لإعادة الترتيب)</span>
              </h6>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm btn-outline-info rounded-3 px-3" onclick="showFormPreview()" title="معاينة نموذج إدخال المحتوى للكتّاب">
                  <i class="bi bi-eye-fill"></i> <span data-page-i18n="btnPreviewForm">معاينة نموذج الإدخال</span>
                </button>
                <button type="button" class="btn btn-sm btn-outline-primary rounded-3 px-3" id="btn-add-field">
                  <i class="bi bi-plus-circle-fill"></i> <span data-page-i18n="btnAddField">إضافة حقل مخصص</span>
                </button>
              </div>
            </div>

            <!-- Drag container -->
            <div id="custom-fields-workspace" class="list-group d-flex flex-column gap-2 mb-4 min-vh-10 border border-dashed rounded-3 p-3 bg-body-tertiary">
              <!-- Rendered via JS -->
            </div>

            <!-- CardList Fields Fixed Group -->
            <div class="border border-info-subtle rounded-4 p-3 bg-body mb-4 shadow-sm d-none" id="cardlist-fields-group-wrapper">
              <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-3">
                <h6 class="fw-bold mb-0 text-info-emphasis">
                  <i class="bi bi-collection me-1"></i>
                  <span class="tp-only-ar">مجموعة قوائم البطاقات (CardList)</span>
                  <span class="tp-only-en">Card Lists Group (CardList)</span>
                </h6>
                <span class="badge bg-info-subtle text-info-emphasis">
                  <span class="tp-only-ar">ثابتة فوق SEO — لا يمكن نقلها</span>
                  <span class="tp-only-en">Fixed above SEO — not reorderable</span>
                </span>
              </div>
              <div id="cardlist-fields-group" class="list-group d-flex flex-column gap-2">
                <!-- Rendered via JS -->
              </div>
            </div>

            <!-- SEO Fields Fixed Group -->
            <div class="border border-primary-subtle rounded-4 p-3 bg-body mb-4 shadow-sm" id="seo-fields-group-wrapper">
              <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-3">
                <h6 class="fw-bold mb-0 text-primary-emphasis">
                  <i class="bi bi-google text-warning me-1"></i>
                  <span class="tp-only-ar">مجموعة حقول تحسين محركات البحث (SEO)</span>
                  <span class="tp-only-en">Search Engine Optimization Fields Group (SEO)</span>
                </h6>
                <span class="badge bg-primary-subtle text-primary-emphasis">
                  <span class="tp-only-ar">أسفل نموذج الإدخال دائماً</span>
                  <span class="tp-only-en">Always at entry form bottom</span>
                </span>
              </div>
              <div id="seo-fields-group" class="list-group d-flex flex-column gap-2">
                <!-- Rendered via JS -->
              </div>
            </div>

            <!-- Save Form Action buttons -->
            <div class="d-flex gap-2 border-top pt-4 mt-4">
              <button type="submit" class="btn btn-primary px-4 py-2 shadow-sm rounded-3 fw-bold" id="btn-submit-form">
                <i class="bi bi-save-fill me-1"></i> <span data-page-i18n="btnSave">حفظ نوع المحتوى وحقوله</span>
              </button>
              <a asp-page="/ContentTypes" asp-route-selectedId="@Model.SelectedTypeId" class="btn btn-outline-secondary px-4 py-2 rounded-3">
                <span data-page-i18n="btnCancel">إلغاء التغييرات</span>
              </a>
            </div>

          </form>
        </div>
      </div>
    </div>
  </div>

</main>

<!-- FIELD BUILDER POPUP MODAL (Add/Edit Custom Field) -->
<div class="modal fade" id="fieldModal" tabindex="-1" aria-labelledby="fieldModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content shadow-lg rounded-3">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="fieldModalLabel">
          <i class="bi bi-plus-circle-fill text-primary me-2"></i>
          <span data-page-i18n="modalTitleAdd">إعداد الحقل المخصص</span>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <form id="fieldForm" onsubmit="event.preventDefault(); saveFieldModal();">
          <input type="hidden" id="modal-field-index" value="-1" />
          
          <div class="row g-3">
            <!-- Programmatic Field Name -->
            <div class="col-md-6">
              <label class="form-label fw-bold" for="modal-fieldname">
                <span class="tp-only-ar">الاسم البرمجي للحقل <span class="text-danger">*</span></span>
                <span class="tp-only-en">Field Name <span class="text-danger">*</span></span>
                
                <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center tp-only-ar" 
                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                        data-bs-content="يستخدم كمعرف برمجياً للحقل في قاعدة البيانات ومخرجات الـ API (مثل: source)."
                        style="text-decoration: none;" title="الاسم البرمجي">
                  <i class="bi bi-info-circle fs-8"></i>
                </button>
                <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center tp-only-en" 
                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                        data-bs-content="Used as a programmatic identifier for the field in database and API outputs."
                        style="text-decoration: none;" title="Field Name">
                  <i class="bi bi-info-circle fs-8"></i>
                </button>
              </label>
              <input type="text" class="form-control" id="modal-fieldname" required pattern="^[A-Za-z][A-Za-z0-9_]*$" dir="ltr"
                     data-title-ar="يجب أن يبدأ بحرف إنجليزي، ويسمح بالأحرف الإنجليزية والأرقام والشرطة السفلية فقط دون مسافات أو رموز."
                     data-title-en="Must start with an English letter. Only English letters, numbers, and underscores are allowed." />
            </div>
            
            <!-- Field Type Select -->
            <div class="col-md-6">
              <label class="form-label fw-bold" for="modal-fieldtype">
                <span class="tp-only-ar">نوع الحقل <span class="text-danger">*</span></span>
                <span class="tp-only-en">Field Type <span class="text-danger">*</span></span>
                
                <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center tp-only-ar" 
                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                        data-bs-content="يحدد نوع المدخلات (نص، قائمة خيارات، تاريخ، صورة، إلخ) وطريقة عرضها للكتّاب."
                        style="text-decoration: none;" title="نوع الحقل">
                  <i class="bi bi-info-circle fs-8"></i>
                </button>
                <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center tp-only-en" 
                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                        data-bs-content="Defines the type of inputs (text, selection list, date, image, etc.) and how they are displayed."
                        style="text-decoration: none;" title="Field Type">
                  <i class="bi bi-info-circle fs-8"></i>
                </button>
              </label>
              <select class="form-select" id="modal-fieldtype" required>
                <optgroup label="Content Fields">
                  <option value="Text">Text</option>
                  <option value="Textarea">Textarea</option>
                  <option value="RichText">RichText</option>
                </optgroup>
                <optgroup label="Selection Fields">
                  <option value="Select">Select</option>
                  <option value="MultiSelect">MultiSelect</option>
                </optgroup>
                <optgroup label="Layout Fields">
                  <option value="CardList">CardList</option>
                </optgroup>
                <optgroup label="Media Fields">
                  <option value="Image">Image</option>
                  <option value="Gallery">Gallery</option>
                  <option value="File">File</option>
                </optgroup>
                <optgroup label="Date Fields">
                  <option value="Date">Date</option>
                  <option value="DateTime">DateTime</option>
                </optgroup>
                <optgroup label="Other Fields">
                  <option value="Number">Number</option>
                  <option value="Decimal">Decimal</option>
                  <option value="Boolean">Boolean</option>
                  <option value="Url">Url</option>
                  <option value="Email">Email</option>
                  <option value="Phone">Phone</option>
                </optgroup>
              </select>
            </div>

            <!-- Labels Ar/En -->
            <div class="col-md-6">
              <label class="form-label fw-bold" for="modal-label">
