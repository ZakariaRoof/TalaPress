                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                        data-bs-content="Additional guideline instructions showing under the input box in English."
                        style="text-decoration: none;" title="Help Text English">
                  <i class="bi bi-info-circle fs-8"></i>
                </button>
              </label>
              <input type="text" class="form-control" id="modal-helptext-en" />
            </div>

            <!-- Default Value -->
            <div class="col-md-6">
              <label class="form-label" for="modal-defaultvalue">
                <span class="tp-only-ar">القيمة الافتراضية للحقل</span>
                <span class="tp-only-en">Default Value</span>
                <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center tp-only-ar" 
                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                        data-bs-content="القيمة التي يتم تعبئتها تلقائياً عند قيام الكاتب بإنشاء مقال أو محتوى جديد."
                        style="text-decoration: none;" title="القيمة الافتراضية">
                  <i class="bi bi-info-circle fs-8"></i>
                </button>
                <button type="button" class="btn btn-link text-secondary p-0 border-0 lh-1 ms-1 d-inline-flex align-items-center tp-only-en" 
                        data-bs-toggle="popover" data-bs-trigger="focus" data-bs-html="true" data-bs-placement="top"
                        data-bs-content="Value pre-populated automatically when a writer creates new content."
                        style="text-decoration: none;" title="Default Value">
                  <i class="bi bi-info-circle fs-8"></i>
                </button>
              </label>
              <input type="text" class="form-control" id="modal-defaultvalue" />
            </div>

            <!-- Switches: Required, Translatable, Active -->
            <div class="col-md-6 d-flex flex-column justify-content-center gap-2 pt-3">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="modal-isrequired" />
                <label class="form-check-label fw-semibold" for="modal-isrequired">
                  <span class="tp-only-ar">حقل مطلوب إجباري</span>
                  <span class="tp-only-en">Required Field</span>
                </label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="modal-istranslatable" />
                <label class="form-check-label fw-semibold" for="modal-istranslatable">
                  <span class="tp-only-ar">حقل يقبل الترجمة المتعددة</span>
                  <span class="tp-only-en">Translatable Field</span>
                </label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="modal-isactive" checked />
                <label class="form-check-label fw-semibold" for="modal-isactive">
                  <span class="tp-only-ar">حقل نشط ومفعل في شاشات الإدخال</span>
                  <span class="tp-only-en">Active and Enabled Field</span>
                </label>
              </div>
            </div>

            <!-- Options JSON builder (Dynamic for lists like dropdowns/radios) -->
            <div class="col-12 border-top pt-3 mt-3 d-none" id="modal-options-wrapper">
              <label class="form-label fw-bold">
                <span class="tp-only-ar">إعداد خيارات القائمة المنسدلة</span>
                <span class="tp-only-en">Dropdown Options Setup</span>
              </label>

              <div class="row g-2 mb-3">
                <div class="col-md-4">
                  <label class="form-label fs-8 fw-semibold">
                    <span class="tp-only-ar">نوع القيمة</span>
                    <span class="tp-only-en">Value Mode</span>
                  </label>
                  <select class="form-select form-select-sm" id="options-mode" onchange="onOptionsModeChanged()">
                    <option value="static">ثابتة / Static</option>
                    <option value="dynamic">ديناميكية / Dynamic</option>
                    <option value="query">استعلام / Query</option>
                  </select>
                </div>
                <div class="col-md-4 d-none" id="dynamic-source-wrapper">
                  <label class="form-label fs-8 fw-semibold">
