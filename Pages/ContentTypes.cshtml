    function isSeoField(field) {
      return field && seoFieldNames.includes((field.FieldName || '').toLowerCase());
    }

    function toggleFieldActive(index, checked) {
      customFields[index].IsActive = checked;
      renderCustomFields();
    }

    function duplicateField(index) {
      const original = customFields[index];
      if (!original) return;

      const baseName = original.FieldName;
      const baseLabel = original.Label;
      const baseLabelEn = original.Label_En || '';

      // Generate unique FieldName
      let newName = `${baseName}_copy`;
      let counter = 1;
      while (customFields.some(f => f.FieldName.toLowerCase() === newName.toLowerCase())) {
        newName = `${baseName}_copy${counter}`;
        counter++;
      }

      // Generate labels
      const newLabel = `${baseLabel} Copy`;
      const newLabelEn = baseLabelEn ? `${baseLabelEn} Copy` : '';

      // Clone field object
      const cloned = {
        ...original,
        Id: 0, // Mark as new
        FieldName: newName,
        Label: newLabel,
        Label_En: newLabelEn || null,
        SortOrder: customFields.length + 1,
        IsActive: true
      };

      customFields.push(cloned);
      normalizeCustomFieldsOrder();
      renderCustomFields();
    }

    // Field Modal Management
    function openFieldModalForAdd() {
      document.getElementById('fieldModalLabel').textContent = currentLang === 'ar' ? "إعداد وإضافة حقل مخصص جديد" : "Add Custom Field";
      document.getElementById('modal-field-index').value = "-1";
      
      // Clear inputs
      document.getElementById('modal-fieldname').value = '';
      document.getElementById('modal-fieldname').readOnly = false;
      document.getElementById('modal-fieldtype').value = 'Text';
      document.getElementById('modal-label').value = '';
      document.getElementById('modal-label-en').value = '';
      document.getElementById('modal-helptext').value = '';
      document.getElementById('modal-helptext-en').value = '';
      document.getElementById('modal-defaultvalue').value = '';
      document.getElementById('modal-isrequired').checked = false;
      document.getElementById('modal-istranslatable').checked = false;
      document.getElementById('modal-isactive').checked = true;

      modalOptions = [];
      document.getElementById('options-mode').value = 'static';
      document.getElementById('dynamic-source').value = 'category';
      populateDynamicParentOptions();
      onOptionsModeChanged();
      renderOptionsTable();
      document.getElementById('modal-options-wrapper').classList.add('d-none');

      // Reset SQL query tab state
      const sqlTextarea = document.getElementById('sql-query-textarea');
      if (sqlTextarea) sqlTextarea.value = '';
      const sqlStatus = document.getElementById('sql-query-status');
      if (sqlStatus) sqlStatus.textContent = '';

      fieldModalInstance.show();
    }

    function openFieldModalForEdit(index) {
      const field = customFields[index];
      if (!field) return;

      document.getElementById('fieldModalLabel').textContent = currentLang === 'ar' ? `تعديل الحقل: ${field.Label}` : `Edit Field: ${field.Label_En || field.Label}`;
      document.getElementById('modal-field-index').value = index;
      
      document.getElementById('modal-fieldname').value = field.FieldName;
      // Do not allow changing programmatic field name to prevent breaking existing data mappings
      document.getElementById('modal-fieldname').readOnly = true;

      document.getElementById('modal-fieldtype').value = field.FieldType;
      document.getElementById('modal-label').value = field.Label;
      document.getElementById('modal-label-en').value = field.Label_En || '';
      document.getElementById('modal-helptext').value = field.HelpText || '';
      document.getElementById('modal-helptext-en').value = field.HelpText_En || '';
      document.getElementById('modal-defaultvalue').value = field.DefaultValue || '';
      document.getElementById('modal-isrequired').checked = field.IsRequired;
      document.getElementById('modal-istranslatable').checked = field.IsTranslatable;
      document.getElementById('modal-isactive').checked = field.IsActive;

      // Handle Select/MultiSelect Options Json parsing
      modalOptions = [];
      document.getElementById('options-mode').value = 'static';
      document.getElementById('dynamic-source').value = 'category';
      if (field.OptionsJson) {
        try {
          const parsedOptions = JSON.parse(field.OptionsJson);
          if (Array.isArray(parsedOptions)) {
            modalOptions = parsedOptions;
          } else if (parsedOptions && parsedOptions.mode === 'dynamic') {
            document.getElementById('options-mode').value = 'dynamic';
            document.getElementById('dynamic-source').value = parsedOptions.source || 'category';
            populateDynamicParentOptions(parsedOptions.sourceId ? String(parsedOptions.sourceId) : '');
            modalOptions = parsedOptions.options || [];
          } else if (parsedOptions && parsedOptions.mode === 'query') {
            document.getElementById('options-mode').value = 'query';
            modalOptions = parsedOptions.options || [];
            renderOptionsQuery(parsedOptions.query || null);
            // Restore which sub-tab was used (builder or sql)
            if (parsedOptions.sqlQuery) {
              const sqlTextarea = document.getElementById('sql-query-textarea');
              if (sqlTextarea) sqlTextarea.value = parsedOptions.sqlQuery;
              // Switch to SQL tab
              const sqlTabBtn = document.getElementById('tab-sqlquery-btn');
              if (sqlTabBtn) {
                const bsTab = new bootstrap.Tab(sqlTabBtn);
                bsTab.show();
              }
            } else {
              // Switch to Builder tab
              const builderTabBtn = document.getElementById('tab-builder-btn');
              if (builderTabBtn) {
                const bsTab = new bootstrap.Tab(builderTabBtn);
                bsTab.show();
              }
            }
          }
        } catch(e) {
          modalOptions = [];
        }
      }
      if (document.getElementById('options-mode').value !== 'dynamic') {
        populateDynamicParentOptions();
      }
      onOptionsModeChanged(false);
      renderOptionsTable();

      const optionsWrapper = document.getElementById('modal-options-wrapper');
      if (field.FieldType === 'Select' || field.FieldType === 'MultiSelect') {
        optionsWrapper.classList.remove('d-none');
      } else {
        optionsWrapper.classList.add('d-none');
      }

      fieldModalInstance.show();
    }

    function saveFieldModal() {
      const idx = parseInt(document.getElementById('modal-field-index').value);
      const name = document.getElementById('modal-fieldname').value.trim();
      const type = document.getElementById('modal-fieldtype').value;
      let label = document.getElementById('modal-label').value.trim();
      let labelEn = document.getElementById('modal-label-en').value.trim();
      let helptext = document.getElementById('modal-helptext').value.trim();
      let helptextEn = document.getElementById('modal-helptext-en').value.trim();
      const defaultvalue = document.getElementById('modal-defaultvalue').value.trim();
      const isreq = document.getElementById('modal-isrequired').checked;
      const istrans = document.getElementById('modal-istranslatable').checked;
      const isact = document.getElementById('modal-isactive').checked;

      if (!label || !labelEn) {
        alert(currentLang === 'ar' ? 'يجب إدخال العنوان الظاهر بالعربية والإنجليزية للحقل المخصص.' : 'Arabic and English labels are required for the custom field.');
        return;
      }

      if (!name || !/^[A-Za-z][A-Za-z0-9_]*$/.test(name)) {
        alert(currentLang === 'ar' ? 'الاسم البرمجي يجب أن يبدأ بحرف إنجليزي ويحتوي فقط على أحرف إنجليزية وأرقام وشرطة سفلية.' : 'Field name must start with an English letter and contain only English letters, numbers, and underscores.');
        return;
      }

      // Help text remains optional and can be synced when one language is empty.
      if (currentLang === 'ar') {
        if (!helptextEn) helptextEn = helptext;
      } else if (currentLang === 'en') {
        if (!helptext) helptext = helptextEn;
      }

      // Validation: Duplicate check and Reserved Names Validation (both client-side)
      if (idx === -1) {
        if (reservedNames.includes(name.toLowerCase())) {
          alert(currentLang === 'ar' ? `الاسم البرمجي "${name}" محجوز من قبل النظام.` : `Programmatic field name "${name}" is reserved by the system.`);
          return;
        }

        const nameConflict = customFields.some(f => f.FieldName.toLowerCase() === name.toLowerCase());
        if (nameConflict) {
          alert(currentLang === 'ar' ? `الاسم البرمجي للحقل "${name}" مستخدم بالفعل.` : `Programmatic field name "${name}" is already in use.`);
          return;
        }
      }

      // Serialize select options if needed
      let optionsJsonVal = null;
      if (type === 'Select' || type === 'MultiSelect') {
        const mode = document.getElementById('options-mode').value;
        if (mode === 'dynamic') {
          refreshDynamicOptionsPreview();
          const source = document.getElementById('dynamic-source').value;
          const sourceId = document.getElementById('dynamic-parent').value;
          if (!sourceId) {
            alert(currentLang === 'ar' ? 'يرجى اختيار مصدر الخيارات الديناميكية.' : 'Please choose the dynamic options source.');
            return;
          }
          optionsJsonVal = JSON.stringify({
            mode: 'dynamic',
            source: source,
            sourceId: Number(sourceId),
            options: modalOptions
          });
        } else if (mode === 'query') {
          // Check which sub-tab is active: Builder or SQL Query
          const sqlTabPane = document.getElementById('tab-sqlquery-pane');
          const isSqlTabActive = sqlTabPane && sqlTabPane.classList.contains('active');

          if (isSqlTabActive) {
            // SQL Query mode
            const sqlText = (document.getElementById('sql-query-textarea')?.value || '').trim();
            if (modalOptions.length === 0) {
              alert(currentLang === 'ar' ? 'يرجى تنفيذ استعلام SQL أولاً حتى يتم توليد الخيارات.' : 'Please execute the SQL query first to generate options.');
              return;
            }
            optionsJsonVal = JSON.stringify({
              mode: 'query',
              queryType: 'sql',
              sqlQuery: sqlText,
              options: modalOptions
            });
          } else {
            // Visual Builder mode
            const query = collectOptionsQuery();
            if (modalOptions.length === 0) {
              alert(currentLang === 'ar' ? 'يرجى تنفيذ الاستعلام أولاً حتى يتم توليد الخيارات.' : 'Please execute the query first to generate options.');
              return;
            }
            optionsJsonVal = JSON.stringify({
              mode: 'query',
              queryType: 'builder',
              query: query,
              options: modalOptions
            });
          }
        } else if (modalOptions.length > 0) {
          optionsJsonVal = JSON.stringify(modalOptions);
        }
      }

      const fieldData = {
        Id: idx >= 0 ? customFields[idx].Id : 0,
        FieldName: name,
        FieldType: type,
        Label: label,
        Label_En: labelEn || null,
        Placeholder: null,
        Placeholder_En: null,
        HelpText: helptext || null,
        HelpText_En: helptextEn || null,
        DefaultValue: defaultvalue || null,
        OptionsJson: optionsJsonVal,
        IsRequired: isreq,
        IsTranslatable: istrans,
        IsActive: isact,
        IsSystemField: false,
        SortOrder: idx >= 0 ? customFields[idx].SortOrder : (customFields.length + 1)
      };

      if (idx === -1) {
        customFields.push(fieldData);
      } else {
        customFields[idx] = fieldData;
      }

      normalizeCustomFieldsOrder();
      renderCustomFields();
      fieldModalInstance.hide();
    }

    function deleteField(index) {
      if (confirm(currentLang === 'ar' ? 'هل أنت متأكد من رغبتك في حذف هذا الحقل المخصص؟' : 'Are you sure you want to delete this custom field?')) {
        customFields.splice(index, 1);
        renderCustomFields();
      }
    }

    // Option Builder helpers
    function onOptionsModeChanged(refresh = true) {
      const mode = document.getElementById('options-mode').value;
      const isDynamic = mode === 'dynamic';
      const isQuery = mode === 'query';

      document.getElementById('dynamic-source-wrapper').classList.toggle('d-none', !isDynamic);
      document.getElementById('dynamic-parent-wrapper').classList.toggle('d-none', !isDynamic);
      document.getElementById('dynamic-options-help').classList.toggle('d-none', !isDynamic);
      document.getElementById('static-options-builder').classList.toggle('d-none', isDynamic || isQuery);
      document.getElementById('query-options-builder').classList.toggle('d-none', !isQuery);

      if (isDynamic) {
        if (refresh) {
          populateDynamicParentOptions();
        }
        refreshDynamicOptionsPreview();
      } else if (isQuery) {
        if (refresh && document.getElementById('options-query-rules').children.length === 0) {
          addOptionsQueryRule();
        }
        // Reset SQL query status when switching to query mode
        const sqlStatus = document.getElementById('sql-query-status');
        if (sqlStatus) sqlStatus.textContent = '';
        // Switch to Builder tab by default
        const builderTabBtn = document.getElementById('tab-builder-btn');
        if (builderTabBtn && refresh) {
          const bsTab = new bootstrap.Tab(builderTabBtn);
          bsTab.show();
        }
        renderOptionsTable();
      } else if (refresh) {
        renderOptionsTable();
      }
    }

    function getSelectedQueryTable() {
      const tableSelect = document.getElementById('options-query-table');
      return tableSelect ? tableSelect.value : (databaseTables[0]?.Name || '');
    }

    function getColumnsForQueryTable(tableName = getSelectedQueryTable()) {
      return databaseColumns.filter(c => c.TableName === tableName);
    }

    function onOptionsQueryTableChanged() {
      const rules = document.querySelectorAll('#options-query-rules .options-query-rule');
      rules.forEach(rule => {
        const currentValue = rule.querySelector('.options-query-field').value;
        rule.querySelector('.options-query-field').innerHTML = buildQueryFieldOptions(currentValue);
      });
      modalOptions = [];
      renderOptionsTable();
    }

    function buildQueryFieldOptions(selectedValue = '') {
      const columns = getColumnsForQueryTable();
      return columns.map(c => `<option value="${c.Name}" ${c.Name === selectedValue ? 'selected' : ''}>${c.Name} (${c.DataType})</option>`).join('');
    }

    function addOptionsQueryRule(rule = null) {
      const columns = getColumnsForQueryTable();
      const defaultField = rule?.field || columns[0]?.Name || '';
      const operators = ['Equals', 'DoesNotEqual', 'Contains', 'StartsWith', 'EndsWith', 'GreaterThan', 'LessThan', 'IsBlank', 'IsNotBlank', 'In'];
      const row = document.createElement('div');
      row.className = 'options-query-rule row g-2 align-items-center bg-body border rounded-3 p-2';
      row.innerHTML = `
        <div class="col-md-3"><select class="form-select form-select-sm options-query-field">${buildQueryFieldOptions(defaultField)}</select></div>
        <div class="col-md-3"><select class="form-select form-select-sm options-query-operator">${operators.map(o => `<option value="${o}" ${o === (rule?.operator || 'Equals') ? 'selected' : ''}>${o}</option>`).join('')}</select></div>
        <div class="col-md-5"><input type="text" class="form-control form-control-sm options-query-value" value="${escapeHtml(rule?.value || '')}" placeholder="Value"></div>
        <div class="col-md-1 text-end"><button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.options-query-rule').remove()"><i class="bi bi-x-lg"></i></button></div>`;
      document.getElementById('options-query-rules').appendChild(row);
    }

    function collectOptionsQuery() {
      return {
        tableName: getSelectedQueryTable(),
        logic: document.getElementById('options-query-logic').value,
        rules: Array.from(document.querySelectorAll('#options-query-rules .options-query-rule')).map(row => ({
          field: row.querySelector('.options-query-field').value,
          operator: row.querySelector('.options-query-operator').value,
          value: row.querySelector('.options-query-value').value
        })),
        groups: []
      };
    }

    function renderOptionsQuery(query) {
      if (query?.tableName && document.getElementById('options-query-table')) {
        document.getElementById('options-query-table').value = query.tableName;
      }
      document.getElementById('options-query-logic').value = query?.logic || 'AND';
      document.getElementById('options-query-rules').innerHTML = '';
      (query?.rules || [null]).forEach(rule => addOptionsQueryRule(rule));
    }

    function executeOptionsQuery() {
      const query = collectOptionsQuery();
      $.ajax({
        url: '?handler=ExecuteQuery',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(query),
        headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
        success: function(response) {
          if (response.success) {
            modalOptions = (response.results || []).map(item => ({
              value: String(item.value),
              label: item.label || String(item.value),
              labelEn: item.labelEn || item.label || String(item.value)
            }));
            renderOptionsTable();
          } else {
            alert(response.message || 'Query failed');
          }
        },
        error: function(xhr, status, error) {
          alert(error || 'Query failed');
        }
      });
    }

    function executeSqlQuery() {
      const textarea = document.getElementById('sql-query-textarea');
      const spinner = document.getElementById('sql-query-spinner');
      const status = document.getElementById('sql-query-status');
      const sql = (textarea?.value || '').trim();

      if (!sql) {
        status.textContent = currentLang === 'ar' ? '⚠ يرجى إدخال استعلام SQL.' : '⚠ Please enter a SQL query.';
        status.className = 'fs-8 text-warning';
        return;
      }

      spinner.classList.remove('d-none');
      status.textContent = '';
      status.className = 'fs-8 text-muted';

      $.ajax({
        url: '?handler=ExecuteSqlQuery',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ sql }),
        headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
        success: function(response) {
          spinner.classList.add('d-none');
          if (response.success) {
            modalOptions = (response.results || []).map(item => ({
              value: String(item.value),
              label: item.label || String(item.value),
              labelEn: item.labelEn || item.label || String(item.value)
            }));
            renderOptionsTable();
            const count = modalOptions.length;
            status.textContent = currentLang === 'ar'
              ? `✔ تم توليد ${count} خيار بنجاح.`
              : `✔ ${count} option(s) generated successfully.`;
            status.className = 'fs-8 text-success fw-bold';
          } else {
            status.textContent = '✖ ' + (response.message || 'Query failed');
            status.className = 'fs-8 text-danger';
          }
        },
        error: function(xhr) {
          spinner.classList.add('d-none');
          let msg = 'Query failed';
          try { msg = JSON.parse(xhr.responseText)?.message || msg; } catch(e) {}
          status.textContent = '✖ ' + msg;
          status.className = 'fs-8 text-danger';
        }
      });
    }

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>'"]/g, char => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        "'": '&#39;',
        '"': '&quot;'
      }[char]));
    }

    function onDynamicSourceChanged() {
      populateDynamicParentOptions();
      refreshDynamicOptionsPreview();
    }

    function populateDynamicParentOptions(selectedValue = '') {
      const source = document.getElementById('dynamic-source').value;
      const parentSelect = document.getElementById('dynamic-parent');
      const parentLabel = document.getElementById('dynamic-parent-label');
      parentSelect.innerHTML = '';

      const emptyOption = document.createElement('option');
      emptyOption.value = '';
      emptyOption.textContent = source === 'category'
        ? (currentLang === 'ar' ? 'اختر التصنيف الرئيسي...' : 'Choose main category...')
        : (currentLang === 'ar' ? 'اختر الدور...' : 'Choose role...');
      parentSelect.appendChild(emptyOption);

      const data = source === 'category' ? dynamicMainCategories : dynamicRoles;
      parentLabel.textContent = source === 'category'
        ? (currentLang === 'ar' ? 'التصنيف الرئيسي' : 'Main Category')
        : (currentLang === 'ar' ? 'الدور' : 'Role');

      data.forEach(item => {
        const option = document.createElement('option');
        option.value = item.Id;
        option.textContent = currentLang === 'ar' ? item.Name : (item.Name_En || item.Name);
        parentSelect.appendChild(option);
      });

      if (selectedValue) {
        parentSelect.value = selectedValue;
      }
    }

    function refreshDynamicOptionsPreview() {
      const source = document.getElementById('dynamic-source').value;
      const sourceId = Number(document.getElementById('dynamic-parent').value || 0);
      modalOptions = [];

      if (!sourceId) {
        renderOptionsTable();
        return;
      }

      if (source === 'category') {
        modalOptions = dynamicSubCategories
          .filter(item => Number(item.ParentId) === sourceId)
          .map(item => ({
            value: String(item.Id),
            label: item.Name,
            labelEn: item.Name_En || item.Name
          }));
      } else {
        modalOptions = dynamicRoleUsers
          .filter(item => Number(item.RoleId) === sourceId)
          .map(item => ({
            value: String(item.Id),
            label: item.FullName || item.Username,
            labelEn: item.FullName || item.Username
          }));
      }

      renderOptionsTable();
    }

    function renderOptionsTable() {
      const tbody = document.getElementById('opt-table-body');
      tbody.innerHTML = '';
      if (modalOptions.length === 0) {
        tbody.innerHTML = currentLang === 'ar'
          ? `<tr><td colspan="4" class="text-muted py-2">لا توجد خيارات معينة بعد.</td></tr>`
          : `<tr><td colspan="4" class="text-muted py-2">No options configured yet.</td></tr>`;
        return;
      }

      modalOptions.forEach((opt, idx) => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td><code>${opt.value}</code></td>
          <td>${opt.label}</td>
          <td>${opt.labelEn || ''}</td>
          <td>
            <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="removeOptionFromBuilder(${idx})">
              <i class="bi bi-trash-fill"></i>
            </button>
          </td>
        `;
        tbody.appendChild(row);
      });
    }

    function addOptionToBuilder() {
      const valEl = document.getElementById('opt-value');
      const labelArEl = document.getElementById('opt-label-ar');
      const labelEnEl = document.getElementById('opt-label-en');

      const val = valEl.value.trim();
      let labelAr = labelArEl.value.trim();
      let labelEn = labelEnEl.value.trim();

      if (currentLang === 'ar') {
        if (!val || !labelAr) {
          alert('يجب إدخال الكود والاسم بالعربية.');
          return;
        }
        if (!labelEn) labelEn = labelAr;
      } else {
        if (!val || !labelEn) {
          alert('Please enter both Value Code and English Label.');
          return;
        }
        if (!labelAr) labelAr = labelEn;
      }

      // Check duplicate code
      if (modalOptions.some(opt => opt.value === val)) {
        alert(currentLang === 'ar' ? 'الكود مدخل بالفعل.' : 'Value Code already exists.');
        return;
      }

      modalOptions.push({
        value: val,
        label: labelAr,
        labelEn: labelEn
      });

      // Clear input fields
      valEl.value = '';
      labelArEl.value = '';
      labelEnEl.value = '';

      renderOptionsTable();
    }

    function removeOptionFromBuilder(index) {
      modalOptions.splice(index, 1);
      renderOptionsTable();
    }

    function togglePreviewLang(lang) {
      previewLang = lang;
      document.getElementById('preview-lang-ar').classList.toggle('active', lang === 'ar');
      document.getElementById('preview-lang-en').classList.toggle('active', lang === 'en');
      renderPreviewForm();
    }

    function showFormPreview() {
      renderPreviewForm();
      previewModalInstance.show();
    }

    function renderPreviewForm() {
      const container = document.getElementById('preview-form-container');
      if (!container) return;

      container.innerHTML = '';
      
      // Filter visible fields (IsActive === true), force CardList group then SEO at the bottom
      const visibleFields = [
        ...customFields.filter(f => f.IsActive && !isSeoField(f) && !isCardListField(f)),
        ...customFields.filter(f => f.IsActive && isCardListField(f)),
        ...customFields.filter(f => f.IsActive && isSeoField(f))
      ];
      
      if (visibleFields.length === 0) {
        container.innerHTML = `
          <div class="text-center text-muted py-4 w-100">
            <i class="bi bi-eye-slash fs-1 d-block mb-2 text-secondary opacity-50"></i>
            <span>${previewLang === 'ar' ? 'لا توجد حقول مرئية حالياً في شاشة الإدخال.' : 'No visible fields currently in the entry screen.'}</span>
          </div>`;
        return;
      }

      // Apply RTL/LTR to modal preview based on previewLang
      const modalBody = document.querySelector('#previewModal .modal-body');
      if (previewLang === 'ar') {
        modalBody.setAttribute('dir', 'rtl');
        modalBody.style.textAlign = 'right';
      } else {
        modalBody.setAttribute('dir', 'ltr');
        modalBody.style.textAlign = 'left';
      }

      let seoPreviewHeaderAdded = false;
      let cardListPreviewHeaderAdded = false;
      visibleFields.forEach(field => {
        if (isCardListField(field) && !cardListPreviewHeaderAdded) {
          const header = document.createElement('div');
          header.className = 'col-12 mt-3 pt-3 border-top';
          header.innerHTML = `
            <div class="fw-bold text-info-emphasis mb-2">
              <i class="bi bi-collection text-info me-1"></i>
              ${previewLang === 'ar' ? 'مجموعة قوائم البطاقات (CardList)' : 'Card Lists Group (CardList)'}
            </div>`;
          container.appendChild(header);
          cardListPreviewHeaderAdded = true;
        }

        if (isSeoField(field) && !seoPreviewHeaderAdded) {
          const header = document.createElement('div');
          header.className = 'col-12 mt-3 pt-3 border-top';
          header.innerHTML = `
            <div class="fw-bold text-primary-emphasis mb-2">
              <i class="bi bi-google text-warning me-1"></i>
              ${previewLang === 'ar' ? 'حقول تحسين محركات البحث (SEO)' : 'Search Engine Optimization Fields (SEO)'}
            </div>`;
          container.appendChild(header);
          seoPreviewHeaderAdded = true;
        }

        const label = previewLang === 'ar' ? field.Label : (field.Label_En || field.Label);
        const helpText = previewLang === 'ar' ? (field.HelpText || '') : (field.HelpText_En || field.HelpText || '');
        const isRequired = field.IsRequired;
        
        let colSize = 'col-md-6';
        if (['Textarea', 'RichText', 'Gallery', 'CardList', 'Content'].includes(field.FieldType) || field.FieldName === 'Content' || field.FieldName === 'Summary') {
          colSize = 'col-md-12';
        }

        const formGroup = document.createElement('div');
        formGroup.className = `${colSize} mb-3`;

        let labelHtml = `<label class="form-label fw-bold">${label} ${isRequired ? '<span class="text-danger">*</span>' : ''}</label>`;
        let controlHtml = '';
        const type = field.FieldType;

        if (type === 'Text' || type === 'Url' || type === 'Email' || type === 'Phone') {
          let inputType = 'text';
          if (type === 'Email') inputType = 'email';
          if (type === 'Url') inputType = 'url';
          if (type === 'Phone') inputType = 'tel';
          controlHtml = `<input type="${inputType}" class="form-control" value="${field.DefaultValue || ''}" />`;
        } 
        else if (type === 'Number' || type === 'Decimal') {
          controlHtml = `<input type="number" step="${type === 'Decimal' ? '0.01' : '1'}" class="form-control" value="${field.DefaultValue || ''}" />`;
        } 
        else if (type === 'Textarea') {
          controlHtml = `<textarea class="form-control" rows="3">${field.DefaultValue || ''}</textarea>`;
        } 
        else if (type === 'RichText') {
          controlHtml = `
            <div class="border rounded-3 p-3 bg-body-tertiary">
              <div class="border-bottom pb-2 mb-2 d-flex gap-2 text-secondary border-light-subtle">
                <i class="bi bi-type-bold"></i> <i class="bi bi-type-italic"></i> <i class="bi bi-type-underline"></i> 
                <i class="bi bi-list-ul"></i> <i class="bi bi-list-ol"></i> <i class="bi bi-link-45deg"></i> <i class="bi bi-image"></i>
              </div>
              <div class="text-muted fs-8 py-3">${previewLang === 'ar' ? 'اكتب المحتوى هنا...' : 'Write content here...'}</div>
            </div>`;
        } 
        else if (type === 'Date') {
          controlHtml = `<input type="date" class="form-control" />`;
        } 
        else if (type === 'DateTime') {
          controlHtml = `<input type="datetime-local" class="form-control" />`;
        } 
        else if (type === 'Boolean') {
          labelHtml = '';
          controlHtml = `
            <div class="form-check form-switch mt-2">
              <input class="form-check-input" type="checkbox" id="prev-${field.FieldName}" ${field.DefaultValue === 'true' ? 'checked' : ''}>
              <label class="form-check-label fw-bold" for="prev-${field.FieldName}">${label} ${isRequired ? '<span class="text-danger">*</span>' : ''}</label>
            </div>`;
        } 
        else if (type === 'Select' || type === 'MultiSelect') {
          let options = [];
          if (field.OptionsJson) {
            try {
              options = JSON.parse(field.OptionsJson);
            } catch(e) {
              options = [];
            }
          }
          
          let optionsHtml = '';
          if (options.length === 0) {
            optionsHtml = `<option>${previewLang === 'ar' ? 'لا توجد خيارات معينة' : 'No options configured'}</option>`;
          } else {
            options.forEach(opt => {
              const optLabel = previewLang === 'ar' ? opt.label : (opt.labelEn || opt.label);
              optionsHtml += `<option value="${opt.value}">${optLabel}</option>`;
            });
          }
          controlHtml = `<select class="form-select" ${type === 'MultiSelect' ? 'multiple' : ''}>${optionsHtml}</select>`;
        } 
        else if (type === 'Image') {
          controlHtml = `
            <div class="border border-dashed rounded-3 p-3 text-center bg-body-tertiary tp-cursor-pointer">
              <i class="bi bi-image fs-4 text-primary d-block mb-1"></i>
              <span class="fs-8 text-secondary">${previewLang === 'ar' ? 'اضغط لرفع صورة منفردة أو تصفح مكتبة الوسائط' : 'Click to upload featured image or browse media library'}</span>
            </div>`;
        } 
        else if (type === 'Gallery') {
          controlHtml = `
            <div class="border border-dashed rounded-3 p-3 text-center bg-body-tertiary tp-cursor-pointer">
              <i class="bi bi-images fs-4 text-primary d-block mb-1"></i>
              <span class="fs-8 text-secondary">${previewLang === 'ar' ? 'اضغط لرفع عدة صور أو اختيار من المعرض' : 'Click to upload multiple images or select gallery'}</span>
            </div>`;
        }
        else if (type === 'CardList') {
          controlHtml = `
            <div class="border rounded-3 p-3 bg-body-tertiary">
              <div class="fw-bold fs-8 mb-2">${previewLang === 'ar' ? 'عنوان القسم + ملخص + بطاقات متكررة' : 'Section title + summary + repeating cards'}</div>
              <div class="d-flex flex-wrap gap-2">
                <span class="badge bg-primary-subtle text-primary-emphasis border fs-9">${previewLang === 'ar' ? 'بطاقة 1' : 'Card 1'}</span>
                <span class="badge bg-primary-subtle text-primary-emphasis border fs-9">${previewLang === 'ar' ? 'بطاقة 2' : 'Card 2'}</span>
                <span class="badge bg-secondary-subtle text-secondary-emphasis border fs-9">+</span>
              </div>
            </div>`;
        } 
        else if (type === 'File') {
          controlHtml = `
            <div class="border border-dashed rounded-3 p-3 text-center bg-body-tertiary tp-cursor-pointer">
              <i class="bi bi-cloud-arrow-up fs-4 text-primary d-block mb-1"></i>
              <span class="fs-8 text-secondary">${previewLang === 'ar' ? 'ارفاق ملف مستند (PDF, Word...)' : 'Attach file document (PDF, Word...)'}</span>
            </div>`;
        }

        let helpHtml = '';
        if (helpText) {
          helpHtml = `<div class="form-text fs-8 text-muted mt-1"><i class="bi bi-info-circle me-1"></i>${helpText}</div>`;
        }

        formGroup.innerHTML = `
          ${labelHtml}
          ${controlHtml}
          ${helpHtml}
        `;
        container.appendChild(formGroup);
      });
    }
  </script>
}
