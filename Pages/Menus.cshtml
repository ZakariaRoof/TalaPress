        function applyPageTranslations(lang) {
            currentLang = lang;
            const elements = document.querySelectorAll('[data-page-i18n]');
            elements.forEach(el => {
                const key = el.getAttribute('data-page-i18n');
                if (pageTranslations[lang] && pageTranslations[lang][key]) {
                    el.textContent = pageTranslations[lang][key];
                }
            });

            // Update dropdown options
            document.querySelectorAll('select[name="menuId"] option').forEach(opt => {
                if (opt.value) {
                    const nameAr = opt.getAttribute('data-name-ar');
                    const nameEn = opt.getAttribute('data-name-en');
                    const code = opt.getAttribute('data-code');
                    const displayName = (lang === 'en' && nameEn) ? nameEn : (nameAr || "");
                    opt.textContent = `${displayName} (${code})`;
                }
            });

            // Update menu structure title
            const menuTitleEl = document.getElementById('selected-menu-title');
            if (menuTitleEl) {
                const nameAr = menuTitleEl.getAttribute('data-name-ar');
                const nameEn = menuTitleEl.getAttribute('data-name-en');
                menuTitleEl.textContent = (lang === 'en' && nameEn) ? nameEn : (nameAr || "");
            }

            if (rawMenuItems && rawMenuItems.length >= 0) {
                renderTree(document.getElementById('tree-search').value.trim());
                updateParentDropdown();
                document.getElementById('form-parentid').value = formState.parentId || '';
            }

            updateSwitchLabel();
        }

        // --- Tree Builder & Renderers ---
        function buildTree(list, parentId = null) {
            return list.filter(item => {
                if (parentId === null) {
                    return item.ParentId === null || item.ParentId === 0;
                }
                return Number(item.ParentId) === Number(parentId);
            }).map(item => ({
                ...item,
                children: buildTree(list, item.Id)
            }));
        }

        function renderTree(query = '') {
            const root = document.getElementById('tree-root');
            if (!root) return;
            root.innerHTML = '';
            
            if (rawMenuItems.length === 0) {
                root.innerHTML = `<div class="text-center text-muted py-4">${pageTranslations[currentLang].noItems}</div>`;
                return;
            }
            
            const treeData = buildTree(rawMenuItems);
            let html = '<ul class="tp-tree-list">';
            treeData.forEach(node => {
                html += renderNode(node, 0, query);
            });
            html += '</ul>';
            
            root.innerHTML = html;
            initSortable();
            
            const clearBtn = document.getElementById('btn-clear-search');
            if (query) {
                clearBtn.classList.remove('d-none');
            } else {
                clearBtn.classList.add('d-none');
            }
        }

        function renderNode(node, depth, query) {
            const hasChildren = node.children && node.children.length > 0;
            const isCollapsed = collapsedNodes.has(node.Id) && !query;
            const titleText = currentLang === 'ar' ? node.Title : (node.Title_En || node.Title);
            const isActive = node.IsActive;
            const isEditing = Number(node.Id) === Number(formState.id);
            
            // Search matching
            if (query && !isNodeMatch(node, query)) {
                return '';
            }

            // Resolve dynamic link badge label
            let typeLabel = "رابط مخصص / Custom";
            if (node.ContentId) {
                typeLabel = currentLang === 'ar' ? `مقال: ${node.ContentTitle || 'محدَّد'}` : `Post: ${node.ContentTitleEn || node.ContentTitle || 'Selected'}`;
            } else if (node.CategoryId) {
                typeLabel = currentLang === 'ar' ? `قسم: ${node.CategoryName}` : `Category: ${node.CategoryNameEn || node.CategoryName}`;
            } else if (node.ContentTypeId) {
                typeLabel = currentLang === 'ar' ? `نوع: ${node.ContentTypeName}` : `Type: ${node.ContentTypeNameEn || node.ContentTypeName}`;
            }
            
            let html = `<li class="tp-tree-item" id="node-${node.Id}">`;
            html += `
                <div class="tp-tree-node ${isActive ? '' : 'inactive-node'} ${isEditing ? 'active-node' : ''}" 
                     data-id="${node.Id}" 
                     onclick="selectMenuItem(${node.Id})">
                    
                    <span class="tp-drag-handle">
                        <i class="bi bi-grip-vertical"></i>
                    </span>
                    
                    <div class="tp-tree-node-content">
                        ${hasChildren ? `
                            <span class="tp-tree-toggle-btn ${isCollapsed ? 'collapsed' : ''}" 
                                  onclick="event.stopPropagation(); toggleNode(${node.Id})">
                                <i class="bi bi-chevron-down"></i>
                            </span>
                        ` : `<span class="tp-tree-indent-spacer"></span>`}
                        
                        <span class="tp-tree-node-icon">
                            <i class="${node.IconValue || 'bi bi-link-45deg'}"></i>
                        </span>
                        
                        <span class="tp-tree-node-text">${titleText}</span>
                        <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle fs-9 tp-font-xxs mx-1">${typeLabel}</span>
                        
                        ${!isActive ? `
                            <span class="badge bg-danger rounded-pill fs-9 tp-font-xxs">
                                ${pageTranslations[currentLang].inactiveBadge}
                            </span>
                        ` : ''}
                    </div>
                    
                    <div class="tp-tree-node-actions">
                        <button class="tp-tree-btn" 
                                type="button" 
                                title="${pageTranslations[currentLang].addSubItem}" 
                                onclick="event.stopPropagation(); setAddMode(${node.Id})">
                            <i class="bi bi-plus-circle text-primary"></i>
                        </button>
                        <button class="tp-tree-btn btn-delete" 
                                type="button" 
                                title="${pageTranslations[currentLang].deleteItem}" 
                                onclick="event.stopPropagation(); deleteMenuItem(${node.Id}, '${titleText.replace(/'/g, "\\'")}')">
                            <i class="bi bi-trash text-danger"></i>
                        </button>
                    </div>
                </div>
            `;
            
            html += `<ul class="tp-tree-list mt-2 ${isCollapsed ? 'd-none' : ''}">`;
            if (hasChildren) {
                node.children.forEach(child => {
                    html += renderNode(child, depth + 1, query);
                });
            }
            html += '</ul>';
            html += '</li>';
            return html;
        }

        function isNodeMatch(node, query) {
            if (!query) return true;
            const titleAr = (node.Title || "").toLowerCase();
            const titleEn = (node.Title_En || "").toLowerCase();
            const q = query.toLowerCase();
            
            if (titleAr.includes(q) || titleEn.includes(q)) {
                return true;
            }
            
            if (node.children && node.children.length > 0) {
                return node.children.some(child => isNodeMatch(child, query));
            }
            return false;
        }

        function toggleNode(id) {
            if (collapsedNodes.has(id)) {
                collapsedNodes.delete(id);
            } else {
                collapsedNodes.add(id);
            }
            renderTree(document.getElementById('tree-search').value.trim());
        }

        function expandAll() {
            collapsedNodes.clear();
            renderTree(document.getElementById('tree-search').value.trim());
        }

        function collapseAll() {
            collapsedNodes.clear();
            rawMenuItems.forEach(mi => {
                const hasChildren = rawMenuItems.some(child => Number(child.ParentId) === Number(mi.Id));
                if (hasChildren) {
                    collapsedNodes.add(mi.Id);
                }
            });
            renderTree(document.getElementById('tree-search').value.trim());
        }

        // --- Form management ---
        function selectMenuItem(id) {
            const item = rawMenuItems.find(m => Number(m.Id) === Number(id));
            if (!item) return;

            formState.mode = 'edit';
            formState.id = item.Id;
            formState.title = item.Title;
            formState.titleEn = item.Title_En || '';
            formState.linkType = (item.ContentTypeId || item.CategoryId || item.ContentId) ? 'content' : 'custom';
            formState.url = item.Url || '';
            formState.contentTypeId = item.ContentTypeId;
            formState.categoryId = item.CategoryId;
            formState.contentId = item.ContentId;
            formState.contentTitle = item.ContentTitle || '';
            formState.parentId = item.ParentId;
            formState.iconValue = item.IconValue || 'bi-link-45deg';
            formState.sortOrder = item.SortOrder;
            formState.isActive = item.IsActive;

            syncStateToForm();
            if (window.innerWidth < 992) {
                document.getElementById('form-card').scrollIntoView({ behavior: 'smooth' });
            }
        }

        function setAddMode(parentId = null) {
            formState.mode = 'add';
            formState.id = 0;
            formState.title = '';
            formState.titleEn = '';
            formState.linkType = 'custom';
            formState.url = '';
            formState.contentTypeId = null;
            formState.categoryId = null;
            formState.contentId = null;
            formState.contentTitle = '';
            formState.parentId = parentId;
            formState.iconValue = 'bi-link-45deg';
            formState.sortOrder = 0;
            formState.isActive = true;

            syncStateToForm();
            if (window.innerWidth < 992) {
                document.getElementById('form-card').scrollIntoView({ behavior: 'smooth' });
            }
        }

        function cancelEdit() {
            setAddMode(null);
        }

        function syncStateToForm() {
            document.getElementById('form-Id').value = formState.id;
            document.getElementById('form-title').value = formState.title;
            document.getElementById('form-title-en').value = formState.titleEn;
            document.getElementById('link-type-selector').value = formState.linkType;
            document.getElementById('form-url').value = formState.url;
            document.getElementById('form-contenttypeid').value = formState.contentTypeId || '';
            
            // Populates/filters categories based on content type:
            updateCategoryDropdown();
            document.getElementById('form-categoryid').value = formState.categoryId || '';
            
            document.getElementById('form-contentid').value = formState.contentId || '';
            document.getElementById('content-search-input').value = formState.contentTitle || '';

            const preview = document.getElementById('selected-content-preview');
            if (formState.contentId && formState.contentTitle) {
                preview.style.display = 'block';
                document.getElementById('selected-content-title').textContent = formState.contentTitle;
            } else {
                preview.style.display = 'none';
            }

            document.getElementById('form-iconvalue').value = formState.iconValue;
            updateIconPreview(formState.iconValue);

            document.getElementById('form-sortorder').value = formState.sortOrder;
            
            const activeCheckbox = document.getElementById('form-isactive');
            activeCheckbox.checked = formState.isActive;
            updateSwitchLabel();

            updateParentDropdown();
            document.getElementById('form-parentid').value = formState.parentId || '';
            document.getElementById('form-parentid-hidden').value = formState.parentId || '';

            toggleLinkTypeWrappers();
            updateFormHeaderMode();
        }

        function toggleLinkTypeWrappers() {
            const linkType = document.getElementById('link-type-selector').value;
            const customWrapper = document.getElementById('custom-link-wrapper');
            const contentWrapper = document.getElementById('content-link-wrapper');

            if (linkType === 'custom') {
                customWrapper.style.display = 'block';
                contentWrapper.style.display = 'none';
            } else {
                customWrapper.style.display = 'none';
                contentWrapper.style.display = 'block';
            }
        }

        function updateSwitchLabel() {
            const label = document.getElementById('label-isactive');
            const activeCheckbox = document.getElementById('form-isactive');
            if (!label || !activeCheckbox) return;
            if (activeCheckbox.checked) {
                label.textContent = pageTranslations[currentLang].activeBadge;
                label.className = 'form-check-label fw-bold text-success ms-2';
            } else {
                label.textContent = pageTranslations[currentLang].inactiveBadge;
                label.className = 'form-check-label fw-bold text-danger ms-2';
            }
        }

        function updateCategoryDropdown() {
            const ctSelect = document.getElementById('form-contenttypeid');
            const catSelect = document.getElementById('form-categoryid');
            if (!catSelect) return;

            const selectedCtId = ctSelect.value ? Number(ctSelect.value) : null;
            catSelect.innerHTML = '<option value="">-- كل التصنيفات --</option>';

            const filteredCats = rawCategories.filter(c => {
                if (selectedCtId === null) return true;
                return c.ContentTypeId === null || Number(c.ContentTypeId) === selectedCtId;
            });

            filteredCats.forEach(c => {
                const opt = document.createElement('option');
                opt.value = c.Id;
                opt.textContent = currentLang === 'ar' ? c.Name : (c.Name_En || c.Name);
                catSelect.appendChild(opt);
            });
        }

        function updateParentDropdown() {
            const select = document.getElementById('form-parentid');
            if (!select) return;
            select.innerHTML = `<option value="">${pageTranslations[currentLang].rootItemOption}</option>`;

            const forbiddenIds = new Set();
            if (formState.id > 0) {
                forbiddenIds.add(Number(formState.id));
                const addDescendants = (id) => {
                    const children = rawMenuItems.filter(m => Number(m.ParentId) === Number(id));
                    for (const child of children) {
                        forbiddenIds.add(Number(child.Id));
                        addDescendants(child.Id);
                    }
                };
                addDescendants(formState.id);
            }

            const traverse = (nodes, depth = 0) => {
                nodes.forEach(node => {
                    if (forbiddenIds.has(Number(node.Id))) return;
                    const opt = document.createElement('option');
                    opt.value = node.Id;
                    const prefix = '&nbsp;&nbsp;'.repeat(depth) + (depth > 0 ? '├─ ' : '');
                    const nameText = currentLang === 'ar' ? node.Title : (node.Title_En || node.Title);
                    opt.innerHTML = prefix + nameText;
                    select.appendChild(opt);
                    
                    if (node.children && node.children.length > 0) {
                        traverse(node.children, depth + 1);
                    }
                });
            };

            const treeData = buildTree(rawMenuItems);
            traverse(treeData);
        }

        function updateFormHeaderMode() {
            const card = document.getElementById('form-card');
            const headerTitle = document.getElementById('form-header-title');
            const saveBtn = document.getElementById('form-save-btn');
            const cancelBtn = document.getElementById('form-cancel-btn');
            const deleteBtn = document.getElementById('form-delete-btn');
            const breadcrumb = document.getElementById('form-breadcrumb');

            if (formState.mode === 'edit') {
                headerTitle.innerHTML = `<i class="bi bi-pencil-square text-warning me-2"></i> <span data-tp-i18n="editItem">${pageTranslations[currentLang].editItem}</span> <small class="text-muted fs-7">(رقم: ${formState.id})</small>`;
                saveBtn.innerHTML = `<i class="bi bi-check2-circle fs-6"></i> <span data-tp-i18n="saveEditItemBtn">${pageTranslations[currentLang].saveChanges}</span>`;
                saveBtn.className = 'btn btn-warning px-4 fw-bold';
                
                cancelBtn.classList.remove('d-none');
                deleteBtn.classList.remove('d-none');

                let pathText = "";
                if (formState.parentId) {
                    const parent = rawMenuItems.find(m => Number(m.Id) === Number(formState.parentId));
                    if (parent) {
                        pathText = `${currentLang === 'ar' ? parent.Title : (parent.Title_En || parent.Title)} &gt; `;
                    }
                }
                pathText += currentLang === 'ar' ? formState.title : (formState.titleEn || formState.title);
                breadcrumb.innerHTML = pathText;
                breadcrumb.classList.remove('d-none');
            } else {
                headerTitle.innerHTML = `<i class="bi bi-plus-circle text-primary me-2"></i> <span data-tp-i18n="addNewItem">${pageTranslations[currentLang].addNewItemTitle}</span>`;
                saveBtn.innerHTML = `<i class="bi bi-plus-circle fs-6"></i> <span data-tp-i18n="saveNewItemBtn">${pageTranslations[currentLang].addNewItem}</span>`;
                saveBtn.className = 'btn btn-primary px-4 fw-bold';

                cancelBtn.classList.add('d-none');
                deleteBtn.classList.add('d-none');
                breadcrumb.classList.add('d-none');
            }
        }

        // --- Event Listeners and Setup ---
        function setupFormListeners() {
            document.getElementById('form-title').addEventListener('input', (e) => {
                formState.title = e.target.value;
            });
            document.getElementById('form-title-en').addEventListener('input', (e) => {
                formState.titleEn = e.target.value;
            });
            document.getElementById('form-url').addEventListener('input', (e) => {
                formState.url = e.target.value;
            });
            document.getElementById('form-iconvalue').addEventListener('input', (e) => {
                formState.iconValue = e.target.value;
                updateIconPreview(formState.iconValue);
            });
            document.getElementById('form-sortorder').addEventListener('input', (e) => {
                formState.sortOrder = Number(e.target.value) || 0;
            });
            document.getElementById('form-isactive').addEventListener('change', (e) => {
                formState.isActive = e.target.checked;
                updateSwitchLabel();
            });

            document.getElementById('form-parentid').addEventListener('change', (e) => {
                formState.parentId = e.target.value ? Number(e.target.value) : null;
                updateFormHeaderMode();
            });

            document.getElementById('form-contenttypeid').addEventListener('change', () => {
                updateCategoryDropdown();
                // Reset selected content on type change
                document.getElementById('form-contentid').value = '';
                document.getElementById('content-search-input').value = '';
                document.getElementById('selected-content-preview').style.display = 'none';
            });

            document.getElementById('form-categoryid').addEventListener('change', () => {
                // Reset selected content on category change
                document.getElementById('form-contentid').value = '';
                document.getElementById('content-search-input').value = '';
                document.getElementById('selected-content-preview').style.display = 'none';
            });

            document.getElementById('btn-toggle-icon-grid').addEventListener('click', () => {
                const container = document.getElementById('icon-grid-container');
                new bootstrap.Collapse(container, { toggle: true });
            });

            document.getElementById('form-delete-btn').addEventListener('click', () => {
                deleteMenuItem(formState.id, currentLang === 'ar' ? formState.title : (formState.titleEn || formState.title));
            });

            document.getElementById('menuItemForm').addEventListener('submit', (e) => {
                const titleAr = document.getElementById('form-title').value.trim();
                if (!titleAr) {
                    e.preventDefault();
                    alert(pageTranslations[currentLang].validationTitleAr);
                    document.getElementById('form-title').focus();
                }
            });
        }

        function setupLinkTypeToggle() {
            const selector = document.getElementById('link-type-selector');
            selector.addEventListener('change', (e) => {
                formState.linkType = e.target.value;
                toggleLinkTypeWrappers();
            });
        }

        function setupSearchListener() {
            document.getElementById('tree-search').addEventListener('input', (e) => {
                renderTree(e.target.value.trim());
            });
        }

        // --- Autocomplete Dynamic AJAX Search ---
        function setupContentSearchAutocomplete() {
            const searchInput = document.getElementById('content-search-input');
            const resultsBox = document.getElementById('content-search-results');
            if (!searchInput || !resultsBox) return;

            searchInput.addEventListener('input', (e) => {
                clearTimeout(debounceTimer);
                const query = e.target.value.trim();
                if (!query) {
                    resultsBox.innerHTML = '';
                    resultsBox.classList.add('d-none');
                    return;
                }

                const ctId = document.getElementById('form-contenttypeid').value;
                if (!ctId) {
                    resultsBox.innerHTML = '<div class="list-group-item disabled text-danger">الرجاء اختيار نوع محتوى أولاً.</div>';
                    resultsBox.classList.remove('d-none');
                    return;
                }

                const catId = document.getElementById('form-categoryid').value;

                debounceTimer = setTimeout(() => {
                    fetch(`?handler=SearchContent&contentTypeId=${ctId}&categoryId=${catId || ''}&query=${encodeURIComponent(query)}`)
                        .then(res => res.json())
                        .then(data => {
                            resultsBox.innerHTML = '';
                            if (data.error) {
                                resultsBox.innerHTML = `<div class="list-group-item disabled text-danger">خطأ: ${data.error}</div>`;
                            } else if (data.length === 0) {
                                resultsBox.innerHTML = '<div class="list-group-item disabled">لا توجد نتائج مطابقة</div>';
                            } else {
                                data.forEach(item => {
                                    const btn = document.createElement('div');
                                    btn.className = 'list-group-item';
                                    const text = currentLang === 'ar' ? item.title : (item.title_En || item.title);
                                    btn.textContent = text;
                                    btn.addEventListener('click', () => {
                                        document.getElementById('form-contentid').value = item.id;
                                        searchInput.value = text;
                                        formState.contentId = item.id;
                                        formState.contentTitle = text;
                                        
                                        const preview = document.getElementById('selected-content-preview');
                                        document.getElementById('selected-content-title').textContent = text;
                                        preview.style.display = 'block';

                                        resultsBox.innerHTML = '';
                                        resultsBox.classList.add('d-none');
                                    });
                                    resultsBox.appendChild(btn);
                                });
                            }
                            resultsBox.classList.remove('d-none');
                        })
                        .catch(err => {
                            resultsBox.innerHTML = `<div class="list-group-item disabled text-danger">خطأ اتصال: ${err.message}</div>`;
                            resultsBox.classList.remove('d-none');
                        });
                }, 250);
            });

            // Hide suggestions when clicking outside
            document.addEventListener('click', (e) => {
                if (e.target !== searchInput && e.target !== resultsBox) {
                    resultsBox.classList.add('d-none');
                }
            });
        }

        // --- Preset Icons populate ---
        function populateIconGrid() {
            const grid = document.getElementById('icon-selector-grid');
            if (!grid) return;
            grid.innerHTML = '';
            
            presetIcons.forEach(iconClass => {
                const box = document.createElement('div');
                box.className = 'tp-icon-select-box';
                box.title = iconClass;
                box.innerHTML = `<i class="bi ${iconClass}"></i>`;
                box.addEventListener('click', () => {
                    document.querySelectorAll('#icon-selector-grid .tp-icon-select-box').forEach(b => b.classList.remove('selected'));
                    box.classList.add('selected');
                    
                    formState.iconValue = iconClass;
                    document.getElementById('form-iconvalue').value = iconClass;
                    updateIconPreview(iconClass);
                });
                grid.appendChild(box);
            });

            // Search inside grid
            document.getElementById('icon-search-input').addEventListener('input', (e) => {
                const query = e.target.value.toLowerCase().trim();
                document.querySelectorAll('#icon-selector-grid .tp-icon-select-box').forEach(box => {
                    if (box.title.toLowerCase().includes(query)) {
                        box.style.display = 'flex';
                    } else {
                        box.style.display = 'none';
                    }
                });
            });
        }

        function updateIconPreview(iconClass) {
            const preview = document.getElementById('form-icon-preview');
            if (!preview) return;
            let clean = iconClass.trim() || 'bi-link-45deg';
            if (!clean.startsWith('bi-') && !clean.startsWith('bi ')) {
                clean = 'bi-' + clean;
            }
            preview.innerHTML = `<i class="bi ${clean}"></i>`;
        }

        // --- Delete & AJAX Reordering Operations ---
        function deleteMenuItem(id, name) {
            const hasChildren = rawMenuItems.some(m => Number(m.ParentId) === Number(id));
            if (hasChildren) {
                alert(pageTranslations[currentLang].errorDeleteChildren);
                return;
            }

            if (confirm(pageTranslations[currentLang].confirmDeleteItem)) {
                document.getElementById('delete-item-id').value = id;
                document.getElementById('deleteItemForm').submit();
            }
        }

        function deleteMenu(id, name) {
            if (confirm(pageTranslations[currentLang].confirmDeleteMenu)) {
                document.getElementById('delete-menu-id').value = id;
                document.getElementById('deleteMenuForm').submit();
            }
        }

        function showCreateMenuMode() {
            document.getElementById('menu-settings-container').style.display = 'block';
            document.getElementById('menu-ManageMenuId').value = 0;
            document.getElementById('menu-ManageMenuName').value = '';
            document.getElementById('menu-ManageMenuName_En').value = '';
            document.getElementById('menu-ManageMenuCode').value = '';
            document.getElementById('menu-ManageMenuIsActive').checked = true;
            document.getElementById('menu-settings-header-text').textContent = 'إنشاء قائمة جديدة';
            document.getElementById('menu-save-btn').querySelector('span').textContent = 'إنشاء القائمة';
            document.getElementById('menu-ManageMenuName').focus();
        }

        function toggleMenuSettingsCard() {
            const el = document.getElementById('menu-settings-container');
            if (el.style.display === 'none') {
                el.style.display = 'block';
            } else {
                el.style.display = 'none';
            }
        }

        // --- Drag and Drop (SortableJS) ---
        function initSortable() {
            const lists = document.querySelectorAll('.tp-tree-list');
            lists.forEach(list => {
                new Sortable(list, {
                    group: {
                        name: 'nested-menu-items',
                        pull: true,
                        put: true
                    },
                    animation: 200,
                    fallbackOnBody: true,
                    swapThreshold: 0.65,
                    handle: '.tp-drag-handle',
                    ghostClass: 'tp-sortable-ghost',
                    chosenClass: 'tp-sortable-chosen',
                    dragClass: 'tp-sortable-drag',
                    onStart: function () {
                        document.body.classList.add('dragging-active');
                    },
                    onEnd: function () {
                        document.body.classList.remove('dragging-active');
                        saveDomOrder();
                    }
                });
            });
        }

        function saveDomOrder() {
            const originalState = rawMenuItems.map(m => ({
                Id: m.Id,
                ParentId: m.ParentId,
                SortOrder: m.SortOrder
            }));

            function scanList(ulElement, parentId = null) {
                const liElements = ulElement.querySelectorAll(':scope > .tp-tree-item');
                liElements.forEach((li, index) => {
                    const id = Number(li.getAttribute('id').replace('node-', ''));
                    const item = rawMenuItems.find(m => Number(m.Id) === id);
                    if (item) {
                        item.ParentId = parentId;
                        item.SortOrder = index;
                    }
                    
                    const childUl = li.querySelector(':scope > .tp-tree-list');
                    if (childUl) {
                        scanList(childUl, id);
                    }
                });
            }

            const rootUl = document.querySelector('#tree-root > .tp-tree-list');
            if (rootUl) {
                scanList(rootUl, null);
            }

            const changedItems = [];
            rawMenuItems.forEach(m => {
                const orig = originalState.find(o => Number(o.Id) === Number(m.Id));
                if (orig && (orig.ParentId !== m.ParentId || orig.SortOrder !== m.SortOrder)) {
                    changedItems.push({
                        Id: m.Id,
                        ParentId: m.ParentId,
                        SortOrder: m.SortOrder
                    });
                }
            });

            // Re-render local tree with changes
            renderTree(document.getElementById('tree-search').value.trim());
            syncStateToForm();

            if (changedItems.length > 0) {
                sendReorderDataToServer(changedItems);
            }
        }

        function sendReorderDataToServer(changedItems) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            showToast(currentLang === 'ar' ? 'جاري حفظ الترتيب الجديد...' : 'Saving new sort order...', 'info', true);

            fetch('?handler=Reorder', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token,
                    'X-Request-Verification-Token': token
                },
                body: JSON.stringify(changedItems)
            })
            .then(res => res.json())
            .then(data => {
                clearLoadingToasts();
                if (data.success) {
                    showToast(currentLang === 'ar' ? 'تم حفظ الترتيب بنجاح.' : 'Sort order updated successfully.', 'success');
                } else {
                    showToast((currentLang === 'ar' ? 'فشل الحفظ: ' : 'Failed to save: ') + data.message, 'danger');
                }
            })
            .catch(err => {
                clearLoadingToasts();
                showToast((currentLang === 'ar' ? 'خطأ في الاتصال: ' : 'Network error: ') + err.message, 'danger');
            });
        }

        // --- Custom Floating Toast Notification System ---
        function showToast(message, type = 'success', isLoading = false) {
            const toastContainer = document.getElementById('toast-container') || createToastContainer();
            const toast = document.createElement('div');
            toast.className = `alert alert-${type} alert-dismissible fade show border-0 shadow-sm rounded-3 mb-2`;
            toast.style.minWidth = '300px';
            toast.style.boxShadow = '0 4px 12px rgba(0,0,0,0.1)';
            if (isLoading) {
                toast.classList.add('tp-loading-toast');
            }

            const iconClass = type === 'info' ? 'bi-info-circle-fill text-info' : 
                             (type === 'success' ? 'bi-check-circle-fill text-success' : 'bi-exclamation-triangle-fill text-danger');

            toast.innerHTML = `
                <div class="d-flex align-items-center">
                    ${isLoading ? `<div class="spinner-border spinner-border-sm text-info me-2" role="status"></div>` : `<i class="bi ${iconClass} me-2 fs-5"></i>`}
                    <div class="fw-bold">${message}</div>
                </div>
                ${isLoading ? '' : `<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>`}
            `;
            toastContainer.appendChild(toast);

            if (!isLoading) {
                setTimeout(() => {
                    const bsAlert = new bootstrap.Alert(toast);
                    bsAlert.close();
                }, 4000);
            }
        }

        function clearLoadingToasts() {
            document.querySelectorAll('.tp-loading-toast').forEach(toast => {
                const bsAlert = new bootstrap.Alert(toast);
                bsAlert.close();
            });
        }

        function createToastContainer() {
            const container = document.createElement('div');
            container.id = 'toast-container';
            container.style.position = 'fixed';
            container.style.top = '24px';
            container.style.right = currentLang === 'ar' ? 'auto' : '24px';
            container.style.left = currentLang === 'ar' ? '24px' : 'auto';
            container.style.zIndex = '9999';
            document.body.appendChild(container);
            return container;
        }
    </script>
}
