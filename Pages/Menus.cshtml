@page
@model TalaPress.Pages.MenusModel
@{
    ViewData["Title"] = "إدارة القوائم";
}

@section Styles {
    <style>
        html[dir="rtl"] #menuItemForm .form-label,
        html[dir="rtl"] #menuItemForm .form-text,
        html[dir="rtl"] #menuForm .form-label {
            display: block;
            text-align: right;
        }

        html[dir="ltr"] #menuItemForm .form-label,
        html[dir="ltr"] #menuItemForm .form-text,
        html[dir="ltr"] #menuForm .form-label {
            display: block;
            text-align: left;
        }

        .mb-3 {
            margin-bottom: .8rem !important;
        }

        .form-control,
        .form-select,
        .input-group-text,
        .btn {
            min-height: 42px;
        }

        .form-text {
            margin-top: .3rem;
            font-size: .78rem;
        }

        .tp-link-binding-card {
            padding: .85rem;
            border: 1px solid rgba(13, 110, 253, .18);
            background: rgba(13, 110, 253, .045);
            border-radius: .75rem;
        }

        /* Highlight classes for selected node */
        .tp-tree-node.active-node {
            background-color: var(--bs-warning-bg-subtle, rgba(255, 193, 7, 0.15)) !important;
            border-color: var(--bs-warning, #ffc107) !important;
        }

        /* Auto-complete search result styling */
        #content-search-results {
            background-color: var(--bs-body-bg);
            border: 1px solid var(--bs-border-color);
            max-height: 250px;
            overflow-y: auto;
            border-radius: 0.5rem;
        }
        #content-search-results .list-group-item {
            cursor: pointer;
            transition: background-color 0.2s;
            border-color: var(--bs-border-color-translucent);
            color: var(--bs-body-color);
            background-color: transparent;
        }
        #content-search-results .list-group-item:hover {
            background-color: rgba(13, 110, 253, 0.1);
        }
    </style>
}

<!-- SECONDARY HEADER -->
<section class="tp-sub-header">
    <div class="container-fluid px-4">
        <div class="row align-items-center">
            <div class="col-md-7 mb-3 mb-md-0">
                <h1 data-tp-i18n="menusTitle">إدارة القوائم والملاحة</h1>
                <p data-tp-i18n="menusDesc">أنشئ وأدر قوائم الموقع (مثل القائمة الرئيسية، وقوائم الفوتر)، ونظم عناصر الملاحة والروابط بالسحب والإفلات.</p>
            </div>
            <div class="col-md-5 text-md-end">
                <a asp-page="/Index" class="btn tp-btn-outline-light me-2">
                    <i class="bi bi-house-door-fill"></i> <span data-tp-i18n="home">الرئيسية</span>
                </a>
                <button class="btn btn-light rounded-circle shadow-sm tp-sub-header-btn-icon" onclick="location.reload()" title="Reload Page">
                    <i class="bi bi-arrow-clockwise text-primary fs-5"></i>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- MAIN CONTAINER -->
<main class="container-fluid px-4 pb-5">
    
    <!-- SYSTEM ALERTS -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                <div class="fw-bold">@Model.SuccessMessage</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                <div class="fw-bold">@Model.ErrorMessage</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- SELECT MENU BAR -->
    <div class="tp-card mb-4">
        <div class="tp-card-body py-3">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <form method="get" class="d-flex align-items-center gap-2 flex-grow-1" style="max-width: 500px;">
                    <label class="text-nowrap fw-bold mb-0" data-tp-i18n="selectMenuLabel">اختر القائمة المراد تعديلها:</label>
                    <select name="menuId" class="form-select bg-body-tertiary border-0" onchange="this.form.submit()">
                        <option value="" data-tp-i18n="selectMenuDefault">-- اختر قائمة --</option>
                        @foreach (var m in Model.MenusList)
                        {
                            <!option value="@m.Id" data-name-ar="@m.Name" data-name-en="@m.Name_En" data-code="@m.Code" @(Model.SelectedMenuId == m.Id ? "selected" : "")>
                                @(m.Name) (@(m.Code))
                            </!option>
                        }
                    </select>
                </form>
                <div>
                    <button class="btn btn-outline-primary fw-bold" onclick="showCreateMenuMode()">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span data-tp-i18n="btnCreateNewMenu">إنشاء قائمة جديدة</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- MENU CREATOR / EDIT SETTINGS PANEL -->
    <div id="menu-settings-container" class="tp-card mb-4 @(Model.SelectedMenuId.HasValue ? "smart-form-edit-mode" : "smart-form-add-mode")" style="display: @(Model.MenusList.Count == 0 || Model.SelectedMenuId == null ? "block" : "none")">
        <div class="tp-card-header d-flex align-items-center justify-content-between">
            <h5 id="menu-settings-title">
                <i class="bi bi-plus-circle text-primary me-2"></i>
                <span id="menu-settings-header-text" data-tp-i18n="menuCreateBtn">إنشاء قائمة جديدة</span>
            </h5>
            @if (Model.SelectedMenuId.HasValue)
            {
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleMenuSettingsCard()">
                    <i class="bi bi-x-lg"></i> <span data-tp-i18n="menuCloseBtn">إغلاق الإعدادات</span>
                </button>
            }
        </div>
        <div class="tp-card-body">
            <form method="post" asp-page-handler="SaveMenu" id="menuForm">
                <input type="hidden" asp-for="ManageMenuId" id="menu-ManageMenuId" value="@(Model.SelectedMenu?.Id ?? 0)" />

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold"><span data-tp-i18n="menuNameAr">اسم القائمة بالعربية</span> <span class="text-danger">*</span></label>
                        <input type="text" asp-for="ManageMenuName" id="menu-ManageMenuName" class="form-control" placeholder="مثال: القائمة الرئيسية" data-tp-i18n="menuNameArPlaceholder" value="@(Model.SelectedMenu?.Name ?? "")" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label" data-tp-i18n="menuNameEn">اسم القائمة بالإنجليزية</label>
                        <input type="text" asp-for="ManageMenuName_En" id="menu-ManageMenuName_En" class="form-control" placeholder="Example: Main Menu" data-tp-i18n="menuNameEnPlaceholder" value="@(Model.SelectedMenu?.Name_En ?? "")" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold" data-tp-i18n="menuCode">كود القائمة (فريد)</label>
                        <input type="text" asp-for="ManageMenuCode" id="menu-ManageMenuCode" class="form-control" placeholder="example: main-menu" data-tp-i18n="menuCodePlaceholder" value="@(Model.SelectedMenu?.Code ?? "")" dir="ltr" />
                        <div class="form-text" data-tp-i18n="menuCodeHelp">كود برمجي فريد للاستدعاء (يتم توليده تلقائياً من الاسم إذا ترك فارغاً).</div>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-between mt-2">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="ManageMenuIsActive" value="true" id="menu-ManageMenuIsActive" @(Model.SelectedMenu == null || Model.SelectedMenu.IsActive ? "checked" : "") />
                        <input type="hidden" name="ManageMenuIsActive" value="false" />
                        <label class="form-check-label fw-bold text-success ms-2" for="menu-ManageMenuIsActive" data-tp-i18n="menuIsActive">نشطة ومفعلة</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 fw-bold" id="menu-save-btn">
                            <i class="bi bi-check-circle"></i>
                            <span data-tp-i18n="@(Model.SelectedMenuId.HasValue ? "menuSaveBtn" : "menuCreateBtn")">@(Model.SelectedMenuId.HasValue ? "حفظ الإعدادات" : "إنشاء القائمة")</span>
                        </button>
                        @if (Model.SelectedMenuId.HasValue && Model.SelectedMenu != null)
                        {
                            <button type="button" class="btn btn-outline-danger" onclick="deleteMenu(@Model.SelectedMenuId.Value, '@(Model.SelectedMenu.Name)')">
                                <i class="bi bi-trash"></i> <span data-tp-i18n="menuDeleteBtn">حذف القائمة بالكامل</span>
                            </button>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.SelectedMenuId.HasValue && Model.SelectedMenu != null)
    {
        <!-- ACTIVE MENU EDITING STRUCTURE -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">
                <i class="bi bi-folder-symlink text-primary me-2"></i>
                <span data-tp-i18n="menuStructure">بنية القائمة:</span> <strong id="selected-menu-title" class="text-primary" data-name-ar="@Model.SelectedMenu.Name" data-name-en="@Model.SelectedMenu.Name_En">@Model.SelectedMenu.Name</strong>
            </h4>
            <button class="btn btn-outline-secondary btn-sm" onclick="toggleMenuSettingsCard()">
                <i class="bi bi-gear-fill me-1"></i> <span data-tp-i18n="menuSettingsBtn">إعدادات القائمة</span>
            </button>
        </div>

        <div class="row">
            
            <!-- COLUMN 1: Menu Items Hierarchy Tree -->
            <div class="col-lg-5 mb-4">
                <div class="tp-card h-100 mb-0">
                    <div class="tp-card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-diagram-3 text-primary fs-5"></i>
                            <h5 data-tp-i18n="itemsTreeHeader">عناصر القائمة</h5>
                            <span class="badge bg-primary rounded-pill" id="tree-count-badge">0</span>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-outline-secondary py-1 tp-font-xs" onclick="expandAll()" title="Expand All">
                                <i class="bi bi-arrows-expand"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary py-1 tp-font-xs" onclick="collapseAll()" title="Collapse All">
                                <i class="bi bi-arrows-collapse"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="tp-card-body">
                        <!-- Search Bar -->
                        <div class="input-group mb-3 shadow-sm rounded-3 tp-overflow-hidden">
                            <span class="input-group-text border-0 bg-body-tertiary"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" id="tree-search" class="form-control border-0 bg-body-tertiary" placeholder="ابحث عن عنصر..." data-tp-i18n="searchItemPlaceholder" />
                            <button class="btn btn-outline-secondary border-0 bg-body-tertiary text-muted d-none" type="button" id="btn-clear-search" onclick="document.getElementById('tree-search').value = ''; renderTree();">
                                <i class="bi bi-x-circle-fill"></i>
                            </button>
                        </div>
                        
                        <!-- Add Root Item Button -->
                        <button class="btn btn-outline-primary w-100 mb-3 py-2 border-dashed fw-bold rounded-3 d-flex align-items-center justify-content-center gap-2" onclick="setAddMode(null)">
                            <i class="bi bi-plus-circle"></i>
                            <span data-tp-i18n="addNewRootItem">إضافة عنصر رئيسي جديد</span>
                        </button>
                        
                        <!-- Tree Container -->
                        <div class="tp-tree-container">
                            <div id="tree-root">
                                <!-- Populated dynamically -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- COLUMN 2: Item Form Panel -->
            <div class="col-lg-7 mb-4">
                <div class="tp-card h-100 mb-0" id="form-card">
                    <div class="tp-card-header">
                        <h5 id="form-header-title">
                            <i class="bi bi-plus-circle text-primary me-2"></i>
                            <span id="form-header-title-text" data-tp-i18n="addNewItem">إضافة عنصر جديد</span>
                        </h5>
                    </div>
                    
                    <div class="tp-card-body">
                        <form method="post" asp-page-handler="SaveItem" id="menuItemForm">
                            <!-- Hidden Fields -->
                            <input type="hidden" asp-for="Id" id="form-Id" />
                            <input type="hidden" asp-for="MenuId" id="form-MenuId" value="@Model.SelectedMenuId.Value" />
                            <input type="hidden" id="form-parentid-hidden" />
                            
                            <!-- Breadcrumb Hierarchy -->
                            <div id="form-breadcrumb" class="tp-form-breadcrumb d-none mb-3"></div>

                            <!-- Name fields (Arabic and English ALWAYS visible side-by-side) -->
                            <div class="row mb-3">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <label class="form-label fw-bold"><span data-tp-i18n="itemTitleAr">عنوان الرابط بالعربي</span> <span class="text-danger">*</span></label>
                                    <input type="text" asp-for="Title" class="form-control" id="form-title" placeholder="مثال: من نحن" data-tp-i18n="itemTitleArPlaceholder" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold" data-tp-i18n="itemTitleEn">عنوان الرابط بالإنجليزي</label>
                                    <input type="text" asp-for="Title_En" class="form-control" id="form-title-en" placeholder="Example: About Us" data-tp-i18n="itemTitleEnPlaceholder" />
                                </div>
                            </div>

                            <!-- Link Type Select Option -->
                            <div class="mb-3">
                                <label class="form-label fw-bold" data-tp-i18n="linkType">نوع الرابط الموجه</label>
                                <select id="link-type-selector" class="form-select">
                                    <option value="custom" data-tp-i18n="linkTypeCustom">رابط مخصص (Custom Link)</option>
                                    <option value="content" data-tp-i18n="linkTypeContent">ربط بمحتوى ديناميكي (Linked Content)</option>
                                </select>
                            </div>

                            <!-- Link Options Sub-cards -->
                            <!-- Option A: Custom Link Wrapper -->
                            <div class="mb-3 tp-link-binding-card" id="custom-link-wrapper">
                                <label class="form-label fw-bold" data-tp-i18n="customUrl">الرابط المخصص (URL)</label>
                                <input type="text" asp-for="Url" class="form-control" id="form-url" placeholder="/about-us أو https://google.com" data-tp-i18n="customUrlPlaceholder" dir="ltr" />
                            </div>

                            <!-- Option B: Content Bind Wrapper -->
                            <div class="mb-3 tp-link-binding-card" id="content-link-wrapper" style="display: none;">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold" data-tp-i18n="contentTypeLabel">نوع المحتوى</label>
                                        <select asp-for="ContentTypeId" class="form-select" id="form-contenttypeid">
                                            <option value="" data-tp-i18n="contentTypeDefault">-- اختر نوع محتوى --</option>
                                            @foreach (var ct in Model.ContentTypesList)
                                            {
                                                <option value="@ct.Id">@ct.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold" data-tp-i18n="categoryLabel">التصنيف (اختياري)</label>
                                        <select asp-for="CategoryId" class="form-select" id="form-categoryid">
                                            <option value="" data-tp-i18n="categoryDefault">-- كل التصنيفات --</option>
                                            <!-- Dynamically populated or loaded via JS based on selected content type -->
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-2 position-relative">
                                    <label class="form-label fw-bold" data-tp-i18n="contentSearchLabel">البحث عن المقال واختياره</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-body-tertiary"><i class="bi bi-search"></i></span>
                                        <input type="text" id="content-search-input" class="form-control" placeholder="اكتب اسم المحتوى للبحث..." data-tp-i18n="contentSearchPlaceholder" autocomplete="off" />
                                    </div>
                                    <input type="hidden" asp-for="ContentId" id="form-contentid" />
                                    
                                    <!-- Autocomplete Dropdown list -->
                                    <div id="content-search-results" class="list-group position-absolute w-100 shadow-sm z-3 d-none">
                                        <!-- Search results populated via JS -->
                                    </div>
                                </div>

                                <div id="selected-content-preview" class="text-info fw-bold fs-8 mt-1" style="display: none;">
                                    <i class="bi bi-link-45deg"></i> <span data-tp-i18n="selectedContentPrefix">المحتوى المحدد حالياً:</span> <span id="selected-content-title"></span>
                                </div>
                            </div>

                            <!-- Parent Menu Item Selection -->
                            <div class="mb-3">
                                <label class="form-label" data-tp-i18n="parentItem">العنصر الأب</label>
                                <select asp-for="ParentId" class="form-select" id="form-parentid">
                                    <!-- Populated dynamically -->
                                </select>
                            </div>

                            <!-- Icon Selection -->
                            <div class="mb-3">
                                <label class="form-label" data-tp-i18n="itemIcon">أيقونة العنصر (اختياري)</label>
                                <div class="input-group">
                                    <span class="input-group-text fs-5" id="form-icon-preview"><i class="bi bi-link-45deg"></i></span>
                                    <input type="text" asp-for="IconValue" class="form-control" id="form-iconvalue" placeholder="bi-link-45deg" />
                                    <button class="btn btn-outline-secondary" type="button" id="btn-toggle-icon-grid" title="Browse Icon Gallery">
                                        <i class="bi bi-grid-3x3-gap-fill"></i>
                                    </button>
                                </div>
                                
                                <div id="icon-grid-container" class="collapse mt-2">
                                    <div class="input-group mb-2 input-group-sm">
                                        <span class="input-group-text bg-body-tertiary"><i class="bi bi-search text-muted"></i></span>
                                        <input type="text" id="icon-search-input" class="form-control form-control-sm bg-body-tertiary" placeholder="ابحث عن أيقونة..." data-tp-i18n="itemIconSearch" />
                                    </div>
                                    <div class="tp-icon-selector-grid" id="icon-selector-grid">
                                        <!-- Populated dynamically -->
                                    </div>
                                </div>
                            </div>

                            <!-- Row: SortOrder and Status -->
                            <div class="row align-items-center mb-4">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <label class="form-label" data-tp-i18n="sortOrderLabel">ترتيب العرض</label>
                                    <input type="number" asp-for="SortOrder" class="form-control" id="form-sortorder" min="0" value="0" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" data-tp-i18n="statusLabel">الحالة</label>
                                    <div class="form-check form-switch mt-2">
                                        <input class="form-check-input" type="checkbox" asp-for="IsActive" id="form-isactive" checked />
                                        <label class="form-check-label fw-bold text-success ms-2" for="form-isactive" id="label-isactive" data-tp-i18n="statusActive">نشط ومفعل</label>
                                    </div>
                                </div>
                            </div>

                            <!-- Form Action Buttons -->
                            <div class="d-flex flex-wrap gap-2">
                                <button type="submit" class="btn btn-primary px-4 fw-bold" id="form-save-btn">
                                    <i class="bi bi-plus-circle fs-6"></i>
                                    <span id="btn-save-text" data-tp-i18n="saveNewItemBtn">إضافة العنصر الجديد</span>
                                </button>
                                <button type="button" class="btn btn-outline-secondary px-4 d-none" id="form-cancel-btn" onclick="cancelEdit()">
                                    <i class="bi bi-x-circle fs-6"></i>
                                    <span data-tp-i18n="cancelBtn">إلغاء</span>
                                </button>
                                <button type="button" class="btn btn-danger px-4 ms-auto d-none" id="form-delete-btn">
                                    <i class="bi bi-trash fs-6"></i>
                                    <span data-tp-i18n="deleteItemBtn">حذف العنصر</span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    }
    else if (Model.MenusList.Count > 0)
    {
        <!-- fallback notification if database has menus but none is loaded/selected -->
        <div class="text-center py-5">
            <h5 class="text-muted" data-tp-i18n="noMenusMessage">الرجاء اختيار قائمة من الأعلى للبدء بتعديلها أو إدارة هيكلها.</h5>
        </div>
    }
    else
    {
        <!-- database is empty of menus altogether -->
        <div class="tp-card">
            <div class="tp-card-body text-center py-5">
                <i class="bi bi-list-nested text-secondary display-3 mb-3"></i>
                <h4 data-tp-i18n="emptyDatabaseTitle">لا توجد أي قوائم حالياً في نظام TalaPress.</h4>
                <p class="text-muted" data-tp-i18n="emptyDatabaseDesc">ابدأ بإنشاء أول قائمة لموقعك (مثل القائمة الرئيسية) عبر تعبئة النموذج بالأعلى.</p>
            </div>
        </div>
    }
</main>

<!-- Hidden forms for delete posts -->
<form method="post" asp-page-handler="DeleteMenu" id="deleteMenuForm" class="d-none">
    <input type="hidden" name="id" id="delete-menu-id" />
</form>
<form method="post" asp-page-handler="DeleteItem" id="deleteItemForm" class="d-none">
    <input type="hidden" name="id" id="delete-item-id" />
    <input type="hidden" name="menuId" value="@(Model.SelectedMenuId ?? 0)" />
</form>

@section Scripts {
    <script src="~/assets/js/sortable.min.js" asp-append-version="true"></script>
    <script>
        // Server variables serialized to client JS
        const rawMenuItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MenuItemsList));
        const rawContentTypes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ContentTypesList));
        const rawCategories = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoriesList));

        // Preset Icons list
        const presetIcons = [
            "bi-house-door-fill", "bi-link-45deg", "bi-file-text", "bi-newspaper", "bi-play-circle",
            "bi-images", "bi-info-circle", "bi-telephone", "bi-envelope", "bi-people", "bi-gear-fill",
            "bi-folder-fill", "bi-tags-fill", "bi-star-fill", "bi-heart-fill", "bi-cart-fill", "bi-bookmark-fill",
            "bi-chat-quote-fill", "bi-globe", "bi-shield-lock-fill", "bi-briefcase-fill", "bi-calendar-event"
        ];

        // Selected Menu Item Form state
        const formState = {
            mode: 'add',
            id: 0,
            title: '',
            titleEn: '',
            linkType: 'custom', // custom or content
            url: '',
            contentTypeId: null,
            categoryId: null,
            contentId: null,
            contentTitle: '',
            parentId: null,
            iconValue: 'bi-link-45deg',
            sortOrder: 0,
            isActive: true
        };

        const collapsedNodes = new Set();
        let currentLang = localStorage.getItem('tp-lang') || 'ar';
        let debounceTimer;

        document.addEventListener('DOMContentLoaded', () => {
            initLanguageSync();
            populateIconGrid();
            
            if (rawMenuItems && rawMenuItems.length >= 0) {
                document.getElementById('tree-count-badge').textContent = rawMenuItems.length;
                syncStateToForm();
                setupFormListeners();
                setupSearchListener();
                setupLinkTypeToggle();
                setupContentSearchAutocomplete();
            }
        });

        // Dynamic page orientation/text sync
        function initLanguageSync() {
            applyPageTranslations(currentLang);
            window.addEventListener('tp-lang-changed', (e) => {
                applyPageTranslations(e.detail.lang);
            });
        }

        const pageTranslations = {
            ar: {
                menusTitle: "إدارة القوائم والملاحة",
                menusDesc: "أنشئ وأدر قوائم الموقع (مثل القائمة الرئيسية، وقوائم الفوتر)، ونظم عناصر الملاحة والروابط بالسحب والإفلات.",
                selectMenuLabel: "اختر القائمة المراد تعديلها:",
                selectMenuDefault: "-- اختر قائمة --",
                btnCreateNewMenu: "إنشاء قائمة جديدة",
                itemsTreeHeader: "عناصر القائمة",
                noItems: "لا توجد عناصر مضافة لهذه القائمة حالياً.",
                activeBadge: "نشط",
                inactiveBadge: "معطل",
                validationTitleAr: "عنوان العنصر بالعربية مطلوب.",
                errorDeleteChildren: "لا يمكن حذف هذا العنصر لأنه يحتوي على عناصر ملاحة فرعية.",
                confirmDeleteItem: "هل أنت متأكد من رغبتك في حذف عنصر القائمة هذا؟",
                confirmDeleteMenu: "تحذير: سيؤدي حذف القائمة إلى إزالة كافة العناصر والروابط التابعة لها نهائياً! هل أنت متأكد؟",
                editItem: "تعديل العنصر",
                saveChanges: "حفظ التغييرات",
                rootItemOption: "-- عنصر رئيسي (بدون أب) --",
                addNewItem: "إضافة العنصر الجديد",
                addNewItemTitle: "إضافة عنصر جديد",
                addSubItem: "إضافة عنصر فرعي",
                deleteItem: "حذف العنصر"
            },
            en: {
                menusTitle: "Navigation Menus",
                menusDesc: "Create and manage website navigation menus. Organize items and hierarchical nested structures using drag-and-drop.",
                selectMenuLabel: "Select menu to edit:",
                selectMenuDefault: "-- Select Menu --",
                btnCreateNewMenu: "Create New Menu",
                itemsTreeHeader: "Menu Items Structure",
                noItems: "No items added to this menu yet.",
                activeBadge: "Active",
                inactiveBadge: "Inactive",
                validationTitleAr: "Arabic Title is required.",
                errorDeleteChildren: "Cannot delete this item because it contains sub-items.",
                confirmDeleteItem: "Are you sure you want to delete this menu item?",
                confirmDeleteMenu: "WARNING: Deleting the menu will permanently erase all associated items and links! Proceed?",
                editItem: "Edit Item",
                saveChanges: "Save Changes",
                rootItemOption: "-- Root Item (No Parent) --",
