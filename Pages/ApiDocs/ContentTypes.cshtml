@page "/api/docs/content-types"
@model TalaPress.Pages.ApiDocs.ContentTypesModel

@await Html.PartialAsync("_ApiEndpointHeader", (
    "GET",
    "/api/v1/content-types",
    "أنواع المحتوى",
    "Content Types",
    "قائمة أنواع المحتوى النشطة مع الأيقونة والوصف.",
    "List active content types with icon and description."
))

@{
    var listExample = $@"curl -H ""Authorization: Pearl YOUR_KEY"" ""{Model.ApiV1BaseUrl}/content-types""";
}
@await Html.PartialAsync("_ApiCodeBlock", ("ct-list-curl", listExample))

@await Html.PartialAsync("_ApiCodeBlock", ("ct-list-res", @"{
  ""items"": [
    {
      ""id"": 1,
      ""name"": ""خبر"",
      ""nameEn"": ""News"",
      ""description"": ""..."",
      ""icon"": ""bi-newspaper"",
      ""isSystem"": true,
      ""isActive"": true
    }
  ]
}"))

<hr class="my-5" />

@await Html.PartialAsync("_ApiEndpointHeader", (
    "GET",
    "/api/v1/content-types/{id}/categories",
    "تصنيفات نوع المحتوى",
    "Categories for Content Type",
    "تصنيفات مخصصة للنوع، أو التصنيفات العامة إن لم توجد مخصصة (نفس منطق لوحة الإدارة).",
    "Dedicated categories for the type, or general categories as fallback (same as admin panel)."
))

<h3 class="h6 text-uppercase text-secondary">Query Parameters</h3>
<div class="table-responsive mb-3">
    <table class="table table-striped table-bordered table-sm">
        <thead><tr><th>Name</th><th>Type</th><th>Default</th><th class="tp-only-ar">الوصف</th><th class="tp-only-en">Description</th></tr></thead>
        <tbody>
            <tr><td><code>activeOnly</code></td><td>bool</td><td>true</td><td class="tp-only-ar">نشط فقط</td><td class="tp-only-en">Active only</td></tr>
        </tbody>
    </table>
</div>

@{
    var scopedExample = $@"curl -H ""Authorization: Pearl YOUR_KEY"" ""{Model.ApiV1BaseUrl}/content-types/1/categories""";
}
@await Html.PartialAsync("_ApiCodeBlock", ("ct-cat-curl", scopedExample))

@await Html.PartialAsync("_ApiCodeBlock", ("ct-cat-res", @"{
  ""contentType"": { ""id"": 1, ""name"": ""خبر"", ""nameEn"": ""News"" },
  ""scope"": ""dedicated"",
  ""items"": [
    { ""id"": 2, ""name"": ""الأخبار"", ""parentId"": null, ""contentTypeId"": 1 }
  ],
  ""meta"": { ""total"": 3, ""scopeContentTypeId"": 1 }
}"))

<p class="text-secondary small mb-0">
    <span class="tp-only-ar"><code>scope</code>: <strong>dedicated</strong> = تصنيفات مخصصة، <strong>general</strong> = تصنificات عامة (ContentTypeId = null).</span>
    <span class="tp-only-en"><code>scope</code>: <strong>dedicated</strong> = type-specific, <strong>general</strong> = global categories (ContentTypeId = null).</span>
</p>
