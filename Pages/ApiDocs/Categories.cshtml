@page "/api/docs/categories"
@model TalaPress.Pages.ApiDocs.CategoriesModel

@await Html.PartialAsync("_ApiEndpointHeader", (
    "GET",
    "/api/v1/categories",
    "التصنيفات",
    "Categories",
    "جلب التصنيفات — الكل أو م scoped لنوع محتوى.",
    "Fetch categories — all or scoped to a content type."
))

<h3 class="h6 text-uppercase text-secondary">Query Parameters</h3>
<div class="table-responsive mb-4">
    <table class="table table-striped table-bordered table-sm align-middle">
        <thead><tr><th>Name</th><th>Type</th><th>Default</th><th class="tp-only-ar">الوصف</th><th class="tp-only-en">Description</th></tr></thead>
        <tbody>
            <tr><td><code>contentTypeId</code></td><td>long</td><td>—</td><td class="tp-only-ar">نطاق حسب نوع المحتوى</td><td class="tp-only-en">Scope by content type ID</td></tr>
            <tr><td><code>contentType</code></td><td>string</td><td>—</td><td class="tp-only-ar">نطاق بالاسم (News, Article…)</td><td class="tp-only-en">Scope by name (News, Article…)</td></tr>
            <tr><td><code>activeOnly</code></td><td>bool</td><td>true</td><td class="tp-only-ar">نشط فقط</td><td class="tp-only-en">Active only</td></tr>
        </tbody>
    </table>
</div>

<h3 class="h6">
    <span class="tp-only-ar">كل التصنيفات</span>
    <span class="tp-only-en">All Categories</span>
</h3>
@{
    var allExample = $@"curl -H ""Authorization: Pearl YOUR_KEY"" ""{Model.ApiV1BaseUrl}/categories""";
}
@await Html.PartialAsync("_ApiCodeBlock", ("cat-all-curl", allExample))

<h3 class="h6 mt-4">
    <span class="tp-only-ar">تصنيفات scoped لنوع محتوى</span>
    <span class="tp-only-en">Scoped to Content Type</span>
</h3>
@{
    var scopedExample = $@"curl -H ""Authorization: Pearl YOUR_KEY"" ""{Model.ApiV1BaseUrl}/categories?contentTypeId=1""";
}
@await Html.PartialAsync("_ApiCodeBlock", ("cat-scoped-curl", scopedExample))

@await Html.PartialAsync("_ApiCodeBlock", ("cat-res", @"{
  ""contentType"": { ""id"": 1, ""nameEn"": ""News"" },
  ""scope"": ""dedicated"",
  ""items"": [
    {
      ""id"": 2,
      ""name"": ""الأخبار"",
      ""slug"": ""news"",
      ""parentId"": null,
      ""contentTypeId"": 1,
      ""sortOrder"": 0
    }
  ],
  ""meta"": { ""total"": 3 }
}"))

<p class="text-secondary small mb-0">
    <span class="tp-only-ar">القائمة flat مع <code>parentId</code> — ابنِ الشجرة في Frontend.</span>
    <span class="tp-only-en">Flat list with <code>parentId</code> — build the tree on the frontend.</span>
</p>
