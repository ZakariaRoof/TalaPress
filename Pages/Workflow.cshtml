@page
@model WorkflowModel
@{
    ViewData["Title"] = "سير العمل ونشر المحتوى";
}

@section Styles {
  <!-- bpmn-js CSS -->
  <link rel="stylesheet" href="~/assets/css/diagram-js.css" asp-append-version="true">
  <link rel="stylesheet" href="~/assets/css/bpmn-js.css" asp-append-version="true">
  <link rel="stylesheet" href="~/assets/css/bpmn-font/css/bpmn.css" asp-append-version="true">
}

<!-- SECONDARY HEADER (BLUE BAR) -->
<section class="tp-sub-header">
  <div class="container-fluid px-4">
    <div class="row align-items-center">
      <div class="col-md-6 mb-3 mb-md-0">
        <h1 data-tp-i18n="workflowTitle">سير العمل ونشر المحتوى</h1>
        <p data-tp-i18n="workflowDesc">صمم مسارات عمل مراجعة ونشر المحتوى رقمياً باستخدام مصمم BPMN 2.0 التفاعلي.</p>
      </div>
      <div class="col-md-6 text-md-end">
        <a asp-page="/Index" class="btn tp-btn-outline-light me-2">
          <i class="bi bi-house-door-fill"></i> <span data-tp-i18n="home">الرئيسية</span>
        </a>
        <a asp-page="/Workflow" class="btn btn-light rounded-circle shadow-sm tp-sub-header-btn-icon">
          <i class="bi bi-diagram-3-fill text-primary fs-5"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- MAIN BPMN CANVAS -->
<main class="container-fluid px-4 pb-5">
  <div class="row">
    <div class="col-12">
      <div class="tp-card">
        <div class="tp-card-header d-flex flex-wrap align-items-center justify-content-between gap-3">
          <div>
            <h5 class="mb-0" data-tp-i18n="bpmnTitle">مخطط سير العمل المعتمد لنشر المقالات</h5>
          </div>
          
          <!-- BPMN Toolbar controls -->
          <div class="d-flex align-items-center gap-2">
            <button class="btn btn-sm btn-outline-secondary" id="btn-zoom-in" title="Zoom In">
              <i class="bi bi-zoom-in"></i> <span class="d-none d-sm-inline" data-tp-i18n="zoomIn">تكبير</span>
            </button>
            <button class="btn btn-sm btn-outline-secondary" id="btn-zoom-out" title="Zoom Out">
              <i class="bi bi-zoom-out"></i> <span class="d-none d-sm-inline" data-tp-i18n="zoomOut">تصغير</span>
            </button>
            <button class="btn btn-sm btn-outline-secondary" id="btn-zoom-reset" title="Reset Zoom">
              <i class="bi bi-arrows-angle-expand"></i> <span class="d-none d-sm-inline" data-tp-i18n="resetZoom">إعادة تعيين</span>
            </button>
            <button class="btn btn-sm btn-primary" id="btn-save" title="Save BPMN XML">
              <i class="bi bi-download"></i> <span data-tp-i18n="saveWorkflow">حفظ المسار</span>
            </button>
          </div>
        </div>
        
        <div class="tp-card-body p-0">
          <!-- BPMN Modeler Canvas container -->
          <div id="canvas" class="tp-bpmn-container"></div>
        </div>
      </div>
    </div>
  </div>
</main>

@section Scripts {
  <!-- Fallback Default BPMN XML String in case of CORS file:// block -->
  <script>
    const defaultBpmnXml = `<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="مسودة جديدة">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_1" name="كتابة المحتوى">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1" />
    <bpmn:task id="Task_2" name="المراجعة والتدقيق">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2" />
    <bpmn:exclusiveGateway id="Gateway_1" name="هل تم القبول؟">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Gateway_1" />
    <bpmn:task id="Task_3" name="جدولة ونشر المقال">
      <bpmn:incoming>Flow_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Approved" name="نعم" sourceRef="Gateway_1" targetRef="Task_3" />
    <bpmn:task id="Task_4" name="تعديل المسودة">
      <bpmn:incoming>Flow_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Rejected" name="لا" sourceRef="Gateway_1" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_4" targetRef="Task_1" />
    <bpmn:endEvent id="EndEvent_1" name="تم النشر بنجاح">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_3" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEvent_1">
        <dc:Bounds x="173" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="157" y="145" width="68" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_1_di" bpmnElement="Task_1">
        <dc:Bounds x="260" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_2_di" bpmnElement="Task_2">
        <dc:Bounds x="420" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1_di" bpmnElement="Gateway_1" isMarkerVisible="true">
        <dc:Bounds x="585" y="95" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="578" y="71" width="63" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_3_di" bpmnElement="Task_3">
        <dc:Bounds x="700" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_4_di" bpmnElement="Task_4">
        <dc:Bounds x="420" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="872" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="856" y="145" width="69" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="209" y="120" />
        <di:waypoint x="260" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="360" y="120" />
        <di:waypoint x="420" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="520" y="120" />
        <di:waypoint x="585" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approved_di" bpmnElement="Flow_Approved">
        <di:waypoint x="635" y="120" />
        <di:waypoint x="700" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="659" y="102" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Rejected_di" bpmnElement="Flow_Rejected">
        <di:waypoint x="610" y="145" />
        <di:waypoint x="610" y="260" />
        <di:waypoint x="520" y="260" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="621" y="193" width="9" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="420" y="260" />
        <di:waypoint x="310" y="260" />
        <di:waypoint x="310" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="800" y="120" />
        <di:waypoint x="872" y="120" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>`;
  </script>

  <!-- bpmn-js Modeler package (locally served) -->
  <script src="~/assets/js/bpmn-modeler.production.min.js" asp-append-version="true"></script>
  
  <!-- BPMN Loader and Controller -->
  <script>
    let bpmnModeler = null;

    document.addEventListener('DOMContentLoaded', () => {
      // Initialize modeler
      bpmnModeler = new BpmnJS({
        container: '#canvas',
        keyboard: {
          bindTo: window
        }
      });

      // Fetch local bpmn, fallback to local string if CORS/network blocks it
      fetch('/assets/data/initial-workflow.bpmn')
        .then(response => {
          if (!response.ok) throw new Error('Network file error');
          return response.text();
        })
        .then(xml => loadDiagram(xml))
        .catch(err => {
          console.warn("Could not fetch BPMN file directly. Using default offline string fallback.");
          loadDiagram(defaultBpmnXml);
        });

      // Bind toolbar controls
      document.getElementById('btn-zoom-in').addEventListener('click', () => {
        bpmnModeler.get('canvas').zoom(bpmnModeler.get('canvas').zoom() * 1.2);
      });

      document.getElementById('btn-zoom-out').addEventListener('click', () => {
        bpmnModeler.get('canvas').zoom(bpmnModeler.get('canvas').zoom() * 0.8);
      });

      document.getElementById('btn-zoom-reset').addEventListener('click', () => {
        bpmnModeler.get('canvas').zoom('fit-viewport');
      });

      document.getElementById('btn-save').addEventListener('click', () => {
        bpmnModeler.saveXML({ format: true }).then(result => {
          const xml = result.xml;
          
          // Create a download link
          const element = document.createElement('a');
          element.setAttribute('href', 'data:text/xml;charset=utf-8,' + encodeURIComponent(xml));
          element.setAttribute('download', 'TalaPress-Workflow.bpmn');
          element.style.display = 'none';
          document.body.appendChild(element);
          element.click();
          document.body.removeChild(element);
        }).catch(err => {
          alert('Error exporting workflow: ' + err.message);
        });
      });
    });

    function loadDiagram(xml) {
      bpmnModeler.importXML(xml).then(result => {
        const { warnings } = result;
        if (warnings.length) {
          console.warn('BPMN Import Warnings:', warnings);
        }
        bpmnModeler.get('canvas').zoom('fit-viewport');
      }).catch(err => {
        console.error('Error importing BPMN 2.0 XML:', err);
      });
    }

    // Refresh canvas size on window resize or theme/language change
    window.addEventListener('resize', () => {
      if (bpmnModeler) {
        bpmnModeler.get('canvas').zoom('fit-viewport');
      }
    });

    window.addEventListener('tp-lang-changed', () => {
      // Re-center BPMN drawing after rendering direction switch
      setTimeout(() => {
        if (bpmnModeler) {
          bpmnModeler.get('canvas').zoom('fit-viewport');
        }
      }, 300);
    });
  </script>
}
