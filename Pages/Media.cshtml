@page
@model TalaPress.Pages.MediaModel
@{
    ViewData["Title"] = "مكتبة الوسائط - TalaPress";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4" id="media-library-app">
    <!-- PAGE HEADER -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="h3 fw-bold text-gradient mb-1" data-tp-i18n="mediaTitle" style="background: linear-gradient(45deg, var(--tp-primary), var(--tp-accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                مكتبة الوسائط
            </h1>
            <div id="media-actions-toolbar" class="d-flex align-items-center gap-2 mt-2">
                <span class="text-muted small me-2 fw-bold text-dark-mode-primary" id="toolbar-selected-label" data-tp-i18n="mediaToolbarOptions">خيارات الإدارة:</span>
                
                <button type="button" id="toolbar-rename-btn" class="btn btn-xs btn-outline-warning d-flex align-items-center gap-1 py-1 px-2 rounded disabled" onclick="triggerRename()" style="font-size: 0.8rem; opacity: 0.5; pointer-events: none;" disabled>
                    <i class="bi bi-pencil-square"></i>
                    <span data-tp-i18n="mediaToolbarRename">تغيير الاسم</span>
                </button>
                
                <button type="button" id="toolbar-move-btn" class="btn btn-xs btn-outline-info d-flex align-items-center gap-1 py-1 px-2 rounded disabled" onclick="triggerMove()" style="font-size: 0.8rem; opacity: 0.5; pointer-events: none;" disabled>
                    <i class="bi bi-folder-symlink"></i>
                    <span data-tp-i18n="mediaToolbarMove">نقل</span>
                </button>
                
                <a href="javascript:void(0)" id="toolbar-download-btn" class="btn btn-xs btn-outline-success d-flex align-items-center gap-1 py-1 px-2 rounded text-decoration-none disabled" style="font-size: 0.8rem; opacity: 0.5; pointer-events: none;">
                    <i class="bi bi-download"></i>
                    <span data-tp-i18n="mediaToolbarDownload">تحميل</span>
                </a>
                
                <button type="button" id="toolbar-delete-btn" class="btn btn-xs btn-outline-danger d-flex align-items-center gap-1 py-1 px-2 rounded disabled" onclick="triggerDelete()" style="font-size: 0.8rem; opacity: 0.5; pointer-events: none;" disabled>
                    <i class="bi bi-trash"></i>
                    <span data-tp-i18n="mediaToolbarDelete">حذف</span>
                </button>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2">
            @if (User.HasClaim("Permission", "Media.Upload"))
            {
                <button type="button" class="btn btn-outline-primary d-flex align-items-center gap-2 px-3 rounded-pill" data-bs-toggle="modal" data-bs-target="#newFolderModal">
                    <i class="bi bi-folder-plus"></i>
                    <span data-tp-i18n="mediaNewFolder">مجلد جديد</span>
                </button>

                <button type="button" class="btn btn-primary d-flex align-items-center gap-2 px-3 rounded-pill" onclick="document.getElementById('ajaxFileInput').click()">
                    <i class="bi bi-cloud-arrow-up-fill"></i>
                    <span data-tp-i18n="mediaUploadFiles">رفع ملفات</span>
                </button>
                <input type="file" id="ajaxFileInput" class="d-none" multiple />
            }
        </div>
    </div>
    <!-- MESSAGES WILL BE DISPLAYED VIA SWEETALERT2 -->

    <!-- UPLOAD PROGRESS (AJAX) -->
    <div id="uploadProgressContainer" class="d-none mb-4">
        <div class="card border-0 shadow-sm p-3 rounded-3" style="background-color: var(--tp-bg-secondary); border: 1px solid var(--tp-border-color) !important;">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-bold text-sm" id="uploadStatusText">جاري رفع الملفات...</span>
                <span class="text-muted small" id="uploadPercentText">0%</span>
            </div>
            <div class="progress rounded-pill" style="height: 8px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" id="uploadProgressBar" role="progressbar" style="width: 0%"></div>
            </div>
        </div>
    </div>

    <!-- BREADCRUMBS AND SEARCH -->
    <div class="card border-0 shadow-sm mb-4 p-3 rounded-3" style="background-color: var(--tp-bg-secondary); border: 1px solid var(--tp-border-color) !important;">
        <div class="row align-items-center g-3">
            <div class="col-md-8">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 align-items-center">
                        <li class="breadcrumb-item d-flex align-items-center">
                            <i class="bi bi-folder-fill text-warning me-1 fs-5"></i>
                        </li>
                        @for (int i = 0; i < Model.Breadcrumbs.Count; i++)
                        {
                            var breadcrumb = Model.Breadcrumbs[i];
                            if (i == Model.Breadcrumbs.Count - 1 && string.IsNullOrEmpty(Model.SearchQuery))
                            {
                                <li class="breadcrumb-item active text-primary fw-bold" aria-current="page" @(i == 0 ? "data-tp-i18n=mediaBreadcrumbRoot" : "")>@breadcrumb.Name</li>
                            }
                            else
                            {
                                <li class="breadcrumb-item"><a href="/Media?folder=@breadcrumb.Path" class="text-decoration-none" @(i == 0 ? "data-tp-i18n=mediaBreadcrumbRoot" : "")>@breadcrumb.Name</a></li>
                            }
                        }
                        @if (!string.IsNullOrEmpty(Model.SearchQuery))
                        {
                            <li class="breadcrumb-item active text-primary fw-bold" aria-current="page"><span data-tp-i18n="mediaSearchResults">نتائج البحث عن:</span> "@Model.SearchQuery"</li>
                        }
                    </ol>
                </nav>
            </div>
            <div class="col-md-4">
                <form method="get" class="input-group">
                    <input type="hidden" name="folder" value="@Model.CurrentFolder" />
                    <span class="input-group-text bg-transparent border-end-0 text-muted" style="border-color: var(--tp-border-color)">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="search" data-tp-i18n="mediaSearchPlaceholder" class="form-control border-start-0 ps-0" placeholder="بحث في المجلد الحالي والفرعي..." value="@Model.SearchQuery" style="border-color: var(--tp-border-color); background-color: transparent; color: var(--tp-text-primary);" />
                    @if (!string.IsNullOrEmpty(Model.SearchQuery))
                    {
                        <a asp-page="/Media" asp-route-folder="@Model.CurrentFolder" class="btn btn-outline-secondary" style="border-color: var(--tp-border-color);">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                    <button class="btn btn-primary" type="submit" data-tp-i18n="search">بحث</button>
                </form>
            </div>
        </div>
    </div>

    <!-- MAIN MEDIA LAYOUT (GRID + DETAILS SIDEBAR) -->
    <div class="row g-4 position-relative">
        <!-- Media Items Grid -->
        <div class="col-lg-9 col-md-12" id="media-grid-col">
            <div class="row g-3 row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-xl-5">
                
                <!-- 1. Directories List -->
                @if (string.IsNullOrEmpty(Model.SearchQuery))
                {
                    @foreach (var dir in Model.Directories)
                    {
                        var sanitizedId = dir.RelativePath.Replace("/", "-");
                        <div class="col">
                            <div class="card h-100 folder-card border-0 shadow-sm position-relative text-center p-3 custom-transition rounded-3" 
                                 style="background-color: var(--tp-bg-secondary); border: 1px solid var(--tp-border-color) !important;"
                                 onclick="selectFolder(this)"
                                 ondblclick="window.location.href='?folder=@dir.RelativePath'"
                                 data-name="@dir.Name"
                                 data-physical-path="@dir.RelativePath">
                                
                                <div class="folder-icon-wrapper mb-3 text-warning">
                                    <i class="bi bi-folder-fill fs-1 d-inline-block folder-icon-glow"></i>
                                </div>
                                <h6 class="text-truncate text-dark-mode-primary fw-bold mb-1 px-1" title="@dir.Name">@dir.Name</h6>
                                <span class="text-muted small folder-item-count" data-count="@dir.ItemCount">@dir.ItemCount عنصر</span>

                                <div class="position-absolute top-2 start-2 hover-show">
                                    <a asp-page="/Media" asp-route-folder="@dir.RelativePath" class="btn btn-xs btn-primary rounded-circle p-1 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;" title="فتح المجلد">
                                        <i class="bi bi-folder2-open"></i>
                                    </a>
                                </div>

                                @if (User.HasClaim("Permission", "Media.Delete"))
                                {
                                    bool isArchiveFolder = string.IsNullOrEmpty(Model.CurrentFolder) && int.TryParse(dir.Name, out int yearVal) && yearVal >= 2026 && yearVal <= 2035;
                                    if (!isArchiveFolder)
                                    {
                                        <div class="position-absolute top-2 end-2 hover-show">
                                            <form method="post" asp-page-handler="Delete" id="delete-folder-form-@sanitizedId">
                                                <input type="hidden" name="folder" value="@Model.CurrentFolder" />
                                                <input type="hidden" name="itemPath" value="@dir.RelativePath" />
                                                <input type="hidden" name="type" value="folder" />
                                                <button type="button" class="btn btn-sm btn-link text-danger p-1" title="حذف المجلد" onclick="confirmFolderDelete(this, '@dir.Name')">
                                                    <i class="bi bi-trash-fill fs-6"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                }

                <!-- 2. Files List -->
                @foreach (var file in Model.Files)
                {
                    bool isImage = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp" }.Contains(file.Extension);
                    <div class="col">
                        <div class="card h-100 file-card border-0 shadow-sm position-relative overflow-hidden custom-transition rounded-3" 
                             style="background-color: var(--tp-bg-secondary); border: 1px solid var(--tp-border-color) !important;"
                             onclick="selectFile(this)"
                             data-name="@file.Name"
                             data-url="@file.RelativePath"
                             data-physical-path="@file.PhysicalPath"
                             data-size="@file.Size"
                             data-ext="@file.Extension"
                             data-date="@file.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                             data-is-image="@isImage.ToString().ToLower()">
                            
                            <div class="file-thumbnail-wrapper position-relative d-flex align-items-center justify-content-center border-bottom" style="height: 140px; background-color: var(--tp-bg-primary); border-color: var(--tp-border-color) !important;">
                                @if (isImage)
                                {
                                    <img src="@file.RelativePath" alt="@file.Name" class="w-100 h-100 object-fit-cover lazyload-img" />
                                }
                                else
                                {
                                    <div class="text-center">
                                        @if (file.Extension == ".pdf")
                                        {
                                            <i class="bi bi-file-earmark-pdf-fill text-danger fs-1"></i>
                                        }
                                        else if (new[] { ".doc", ".docx" }.Contains(file.Extension))
                                        {
                                            <i class="bi bi-file-earmark-word-fill text-primary fs-1"></i>
                                        }
                                        else if (new[] { ".xls", ".xlsx" }.Contains(file.Extension))
                                        {
                                            <i class="bi bi-file-earmark-excel-fill text-success fs-1"></i>
                                        }
                                        else if (new[] { ".ppt", ".pptx" }.Contains(file.Extension))
                                        {
                                            <i class="bi bi-file-earmark-slides-fill text-warning fs-1"></i>
                                        }
                                        else if (file.Extension == ".zip")
                                        {
                                            <i class="bi bi-file-earmark-zip-fill text-warning fs-1"></i>
                                        }
                                        else if (file.Extension == ".mp4")
                                        {
                                            <i class="bi bi-file-earmark-play-fill text-info fs-1"></i>
                                        }
                                        else if (file.Extension == ".mp3")
                                        {
                                            <i class="bi bi-file-earmark-music-fill text-info fs-1"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-file-earmark-fill text-secondary fs-1"></i>
                                        }
                                        <div class="text-uppercase fw-bold text-xs mt-1 text-muted">@file.Extension.Replace(".", "")</div>
                                    </div>
                                }
                            </div>
                            
                            <div class="p-2 text-center">
                                <h6 class="text-truncate text-dark-mode-primary text-sm fw-bold mb-1" title="@file.Name">@file.Name</h6>
                                <span class="text-muted text-xs file-size-text" data-size="@file.Size">@FormatFileSize(file.Size)</span>
                            </div>

                            <!-- Fast Action Copy Link on Hover -->
                            <button class="btn btn-sm btn-dark position-absolute top-2 start-2 hover-show rounded-circle p-1 opacity-75" 
                                    style="width: 28px; height: 28px; line-height: 1;" 
                                    onclick="copyToClipboardDirect(event, '@file.RelativePath')" 
                                    title="نسخ الرابط المباشر">
                                <i class="bi bi-link-45deg"></i>
                            </button>
                        </div>
                    </div>
                }

                @if (!Model.Directories.Any() && !Model.Files.Any())
                {
                    <div class="col-12 w-100 text-center py-5">
                        <div class="text-muted py-4">
                            <i class="bi bi-folder-x fs-1 mb-3 d-block text-muted"></i>
                            <h5 data-tp-i18n="mediaEmptyStateTitle">لا توجد ملفات أو مجلدات في هذا المسار.</h5>
                            <p class="small" data-tp-i18n="mediaEmptyStateDesc">اسحب الملفات وأفلتها هنا للرفع الفوري أو اضغط على رفع ملفات.</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- WordPress-style Sidebar Drawer (WordPress Details Panel) -->
        <div class="col-lg-3 col-md-12 d-none d-lg-block" id="media-details-sidebar">
            <div class="card border-0 shadow-sm sticky-top rounded-3 p-3 text-center" style="top: 80px; background-color: var(--tp-bg-secondary); border: 1px solid var(--tp-border-color) !important; min-height: 400px;" id="details-panel-card">
                <div id="details-empty-state" class="py-5 text-muted">
                    <i class="bi bi-info-circle fs-1 mb-3 d-block text-muted"></i>
                    <p class="small" data-tp-i18n="mediaSelectToPreview">حدد ملفاً أو مجلداً لمعاينة التفاصيل هنا.</p>
                </div>

                <div id="details-content-state" class="d-none text-start">
                    <h5 class="fw-bold text-center border-bottom pb-2 mb-3 text-dark-mode-primary" id="detail-panel-title" data-tp-i18n="mediaDetailsTitle" style="border-color: var(--tp-border-color) !important;">تفاصيل الملف</h5>
                    
                    <div class="text-center mb-3 bg-light rounded p-3 d-flex align-items-center justify-content-center overflow-hidden position-relative border" style="height: 180px; background-color: var(--tp-bg-primary) !important; border-color: var(--tp-border-color) !important;">
                        <img id="detail-preview-img" class="img-fluid object-fit-contain d-none max-height-100" style="max-height: 150px;" src="" alt="" />
                        <div id="detail-preview-icon" class="text-center d-none">
                            <i class="bi bi-file-earmark fs-1 d-block text-secondary"></i>
                            <span class="badge bg-secondary text-uppercase fs-8" id="detail-badge-ext"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small mb-1" id="detail-name-label" data-tp-i18n="mediaFileName">اسم الملف</label>
                        <div class="fw-bold text-dark-mode-primary text-break" id="detail-name"></div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label text-muted small mb-1" data-tp-i18n="mediaSize">الحجم</label>
                            <div class="text-dark-mode-primary font-monospace small" id="detail-size"></div>
                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted small mb-1" data-tp-i18n="mediaUploadDate">تاريخ الرفع</label>
                            <div class="text-dark-mode-primary small" id="detail-date"></div>
                        </div>
                    </div>

                    <!-- Image dimensions (loaded via Javascript on preview load) -->
                    <div class="mb-3 d-none" id="detail-dimensions-wrapper">
                        <label class="form-label text-muted small mb-1" data-tp-i18n="mediaDimensions">الأبعاد (عرض × ارتفاع)</label>
                        <div class="text-dark-mode-primary small" id="detail-dimensions">جاري الحساب...</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small mb-1" data-tp-i18n="mediaDirectUrl">الرابط المباشر للويب</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control font-monospace text-xs" id="detail-url-input" readonly />
                            <button class="btn btn-outline-primary" type="button" onclick="copyLinkFromInput()" data-tp-i18n="copy">نسخ</button>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4 pt-3 border-top" style="border-color: var(--tp-border-color) !important;">
                        <a href="" id="detail-download-link" class="btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center gap-2" download>
                            <i class="bi bi-download"></i>
                            <span data-tp-i18n="mediaDownloadFile">تحميل الملف</span>
                        </a>

                        @if (User.HasClaim("Permission", "Media.Delete"))
                        {
                            <form method="post" asp-page-handler="Delete" id="sidebar-delete-form">
                                <input type="hidden" name="folder" value="@Model.CurrentFolder" />
                                <input type="hidden" name="itemPath" id="detail-delete-path" />
                                <input type="hidden" name="type" value="file" />
                                <button type="button" class="btn btn-sm btn-danger w-100 d-flex align-items-center justify-content-center gap-2" onclick="confirmFileDelete(this)">
                                    <i class="bi bi-trash-fill"></i>
                                    <span data-tp-i18n="mediaDeletePermanent">حذف نهائي</span>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- NEW FOLDER MODAL -->
<div class="modal fade" id="newFolderModal" tabindex="-1" aria-labelledby="newFolderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: var(--tp-bg-secondary); color: var(--tp-text-primary); border: 1px solid var(--tp-border-color);">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="newFolderModalLabel" data-tp-i18n="mediaModalCreateFolder">إنشاء مجلد جديد</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="CreateFolder" id="newFolderForm">
                <div class="modal-body py-3">
                    <input type="hidden" name="folder" value="@Model.CurrentFolder" />
                    <div class="mb-3">
                        <label for="folderName" class="form-label text-muted small" data-tp-i18n="mediaModalFolderName">اسم المجلد</label>
                        <input type="text" class="form-control" id="folderName" name="folderName" data-tp-i18n="mediaModalFolderNamePlaceholder" placeholder="أدخل اسم المجلد بدون مسافات أو رموز خاصة..." required />
                        <div class="form-text text-muted text-xs mt-1" data-tp-i18n="mediaModalFolderNameHint">المجلد سيتم إنشاؤه داخل المسار الحالي للمكتبة.</div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal" data-tp-i18n="cancel">إلغاء</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4" data-tp-i18n="create">إنشاء</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- DRAG AND DROP SCREEN OVERLAY -->
<div id="dragDropOverlay" class="position-fixed w-100 h-100 top-0 start-0 d-none justify-content-center align-items-center" style="background-color: rgba(9, 13, 22, 0.85); z-index: 9999; border: 4px dashed var(--tp-primary);">
    <div class="text-center text-white">
        <i class="bi bi-cloud-arrow-up-fill text-primary" style="font-size: 8rem;"></i>
        <h2 class="fw-bold mt-3" data-tp-i18n="mediaDragOverlayTitle">أفلت الملفات لرفعها فورياً</h2>
        <p class="lead" data-tp-i18n="mediaDragOverlayDesc">يمكنك إفلت صور، ملفات PDF، مستندات، أو ملفات مضغوطة.</p>
    </div>
</div>

@functions {
    public string FormatFileSize(long bytes)
    {
        string[] suffix = { "بايت", "ك.ب", "م.ب", "ج.ب" };
        int i;
        double dblSByte = bytes;
        for (i = 0; i < suffix.Length && bytes >= 1024; i++, bytes /= 1024)
        {
            dblSByte = bytes / 1024.0;
        }
        return $"{dblSByte:0.##} {suffix[i == 0 ? 0 : i - 1]}";
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <style>
        /* Custom styles for premium WordPress-style Media Library */
        .text-gradient {
            background-clip: text;
            -webkit-background-clip: text;
        }

        .folder-card, .file-card {
            cursor: pointer;
            border-color: var(--tp-border-color);
            transition: all 0.25s ease-in-out;
        }

        .folder-card:hover, .file-card:hover {
            transform: translateY(-4px);
            border-color: var(--tp-primary) !important;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
        }

        .folder-card.active, .file-card.active {
            border-color: var(--tp-primary) !important;
            box-shadow: 0 0 0 3px rgba(var(--tp-primary-rgb), 0.25);
            background-color: rgba(var(--tp-primary-rgb), 0.05) !important;
        }

        .folder-icon-glow {
            filter: drop-shadow(0 2px 4px rgba(245, 158, 11, 0.2));
            transition: transform 0.2s;
        }

        .folder-card:hover .folder-icon-glow {
            transform: scale(1.1);
        }

        .hover-show {
            opacity: 0;
            transition: opacity 0.2s ease-in-out;
        }

        .folder-card:hover .hover-show, .file-card:hover .hover-show {
            opacity: 1;
        }

        .custom-transition {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .text-xs {
            font-size: 0.75rem;
        }

        .text-sm {
            font-size: 0.875rem;
        }

        .fs-8 {
            font-size: 0.8rem;
        }

        .max-height-100 {
            max-height: 100% !important;
        }

        .text-dark-mode-primary {
            color: var(--tp-text-primary);
        }
        
        /* Dark Theme Support classes */
        [data-bs-theme="dark"] .bg-light {
            background-color: var(--tp-bg-tertiary) !important;
        }
        [data-bs-theme="dark"] .btn-outline-secondary {
            color: var(--tp-text-secondary);
            border-color: var(--tp-border-color);
        }
        [data-bs-theme="dark"] .btn-outline-secondary:hover {
            background-color: var(--tp-bg-tertiary);
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let selectedElement = null;
        let selectedItem = null;

        function getSwalConfig(title, text, icon, showCancel = false, confirmText = 'حسناً', cancelText = 'إلغاء', isDanger = false) {
            const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            return {
                title: title,
                text: text,
                icon: icon,
                showCancelButton: showCancel,
                confirmButtonText: confirmText,
                cancelButtonText: cancelText,
                background: isDark ? '#111827' : '#ffffff',
                color: isDark ? '#f9fafb' : '#111827',
                customClass: {
                    confirmButton: isDanger ? 'btn btn-danger px-4 rounded-pill mx-1' : 'btn btn-primary px-4 rounded-pill mx-1',
                    cancelButton: 'btn btn-outline-secondary px-4 rounded-pill mx-1'
                },
                buttonsStyling: false
            };
        }

        function confirmFolderDelete(button, name) {
            const form = button.closest('form');
            const currentLang = localStorage.getItem('tp-lang') || 'ar';
            const title = currentLang === 'ar' ? 'حذف المجلد؟' : 'Delete folder?';
            const text = currentLang === 'ar' 
                ? `سيتم حذف المجلد "${name}" وكافة الملفات والمجلدات التي بداخله نهائياً من السيرفر!` 
                : `This will permanently delete the folder "${name}" and all its contents from the server!`;
            const confirmBtn = currentLang === 'ar' ? 'نعم، احذف نهائياً' : 'Yes, delete permanently';
            const cancelBtn = currentLang === 'ar' ? 'إلغاء' : 'Cancel';

            Swal.fire(getSwalConfig(title, text, 'warning', true, confirmBtn, cancelBtn, true)).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }

        function confirmFileDelete(button) {
            const form = button.closest('form');
            const name = document.getElementById('detail-name').innerText;
            const currentLang = localStorage.getItem('tp-lang') || 'ar';
            const title = currentLang === 'ar' ? 'حذف الملف؟' : 'Delete file?';
            const text = currentLang === 'ar' 
                ? `هل أنت متأكد من حذف الملف "${name}" نهائياً من السيرفر؟` 
                : `Are you sure you want to permanently delete the file "${name}" from the server?`;
            const confirmBtn = currentLang === 'ar' ? 'نعم، احذف نهائياً' : 'Yes, delete permanently';
            const cancelBtn = currentLang === 'ar' ? 'إلغاء' : 'Cancel';

            Swal.fire(getSwalConfig(title, text, 'warning', true, confirmBtn, cancelBtn, true)).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }

        // Clipboard Copying Helper (Direct Button)
        function copyToClipboardDirect(e, url) {
            e.stopPropagation(); // Stop card click activation
            const fullUrl = window.location.origin + url;
            navigator.clipboard.writeText(fullUrl).then(() => {
                showToast("تم نسخ رابط الملف إلى الحافظة.");
            }).catch(err => {
                const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'bottom-start',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true,
                    background: isDark ? '#111827' : '#ffffff',
                    color: isDark ? '#f9fafb' : '#111827'
                });
                Toast.fire({
                    icon: 'error',
                    title: "تعذر نسخ الرابط تلقائياً: " + err
                });
            });
        }

        // Selection triggers
        // Selection triggers
        function selectFolder(card) {
            document.querySelectorAll('.file-card, .folder-card').forEach(el => el.classList.remove('active'));
            card.classList.add('active');
            selectedElement = card;
            
            const name = card.getAttribute('data-name');
            const physicalPath = card.getAttribute('data-physical-path');

            selectedItem = {
                type: 'folder',
                name: name,
                path: physicalPath,
                url: null
            };

            const currentLang = localStorage.getItem('tp-lang') || 'ar';

            document.getElementById('details-empty-state').classList.add('d-none');
            document.getElementById('details-content-state').classList.remove('d-none');
            
            document.querySelector('#details-content-state h5').innerText = translations[currentLang]?.mediaFolderDetailsTitle || (currentLang === 'ar' ? "تفاصيل المجلد" : "Folder Details");
            document.getElementById('detail-name-label').innerText = translations[currentLang]?.mediaFolderName || (currentLang === 'ar' ? "اسم المجلد" : "Folder Name");
            document.getElementById('detail-name').innerText = name;
            document.getElementById('detail-size').innerText = card.querySelector('.text-muted').innerText;
            document.getElementById('detail-date').innerText = '—';
            
            const previewImg = document.getElementById('detail-preview-img');
            const previewIcon = document.getElementById('detail-preview-icon');
            const dimsWrapper = document.getElementById('detail-dimensions-wrapper');
            
            previewImg.classList.add('d-none');
            previewIcon.classList.remove('d-none');
            dimsWrapper.classList.add('d-none');
            previewIcon.querySelector('i').className = 'bi bi-folder-fill text-warning fs-1 d-block';
            document.getElementById('detail-badge-ext').innerText = translations[currentLang]?.folder || (currentLang === 'ar' ? 'مجلد' : 'Folder');
            
            document.getElementById('detail-url-input').closest('.mb-3').classList.add('d-none');
            document.getElementById('detail-download-link').classList.add('d-none');
            document.getElementById('detail-delete-path').value = physicalPath;
            
            const delForm = document.getElementById('sidebar-delete-form');
            if (delForm) {
                // If it is a top-level year folder (2026-2035) at uploads root, hide delete button in sidebar
                const isArchive = !currentFolder && !isNaN(parseInt(name)) && parseInt(name) >= 2026 && parseInt(name) <= 2035;
                if (isArchive) {
                    delForm.classList.add('d-none');
                } else {
                    delForm.classList.remove('d-none');
                    delForm.querySelector('input[name="type"]').value = 'folder';
                    const delBtn = delForm.querySelector('button');
                    delBtn.setAttribute('onclick', `confirmFolderDelete(this, '${name}')`);
                }
            }

            updateToolbar();
        }

        function selectFile(card) {
            document.querySelectorAll('.file-card, .folder-card').forEach(el => el.classList.remove('active'));
            card.classList.add('active');
            selectedElement = card;

            const name = card.getAttribute('data-name');
            const url = card.getAttribute('data-url');
            const physicalPath = card.getAttribute('data-physical-path');
            const size = parseInt(card.getAttribute('data-size'));
            const ext = card.getAttribute('data-ext');
            const date = card.getAttribute('data-date');
            const isImage = card.getAttribute('data-is-image') === 'true';

            selectedItem = {
                type: 'file',
                name: name,
                path: physicalPath,
                url: url
            };

            const currentLang = localStorage.getItem('tp-lang') || 'ar';

            document.getElementById('details-empty-state').classList.add('d-none');
            document.getElementById('details-content-state').classList.remove('d-none');

            document.querySelector('#details-content-state h5').innerText = translations[currentLang]?.mediaDetailsTitle || (currentLang === 'ar' ? "تفاصيل الملف" : "File Details");
            document.getElementById('detail-name-label').innerText = translations[currentLang]?.mediaFileName || (currentLang === 'ar' ? "اسم الملف" : "File Name");
            document.getElementById('detail-name').innerText = name;
            document.getElementById('detail-size').innerText = formatBytes(size);
            document.getElementById('detail-date').innerText = date;
            
            const urlInput = document.getElementById('detail-url-input');
            urlInput.value = window.location.origin + url;
            urlInput.closest('.mb-3').classList.remove('d-none');
            
            document.getElementById('detail-delete-path').value = physicalPath;
            
            const dlLink = document.getElementById('detail-download-link');
            dlLink.href = url;
            dlLink.classList.remove('d-none');

            const previewImg = document.getElementById('detail-preview-img');
            const previewIcon = document.getElementById('detail-preview-icon');
            const dimsWrapper = document.getElementById('detail-dimensions-wrapper');

            if (isImage) {
                previewImg.src = url;
                previewImg.alt = name;
                previewImg.classList.remove('d-none');
                previewIcon.classList.add('d-none');
                
                dimsWrapper.classList.remove('d-none');
                const img = new Image();
                img.onload = function() {
                    document.getElementById('detail-dimensions').innerText = this.width + ' × ' + this.height + ' ' + (currentLang === 'ar' ? 'بكسل' : 'pixels');
                };
                img.src = url;
            } else {
                previewImg.classList.add('d-none');
                previewIcon.classList.remove('d-none');
                dimsWrapper.classList.add('d-none');
                
                let iconClass = 'bi-file-earmark';
                if (ext === '.pdf') iconClass = 'bi-file-earmark-pdf-fill text-danger';
                else if (['.doc', '.docx'].includes(ext)) iconClass = 'bi-file-earmark-word-fill text-primary';
                else if (['.xls', '.xlsx'].includes(ext)) iconClass = 'bi-file-earmark-excel-fill text-success';
                else if (['.ppt', '.pptx'].includes(ext)) iconClass = 'bi-file-earmark-slides-fill text-warning';
                else if (ext === '.zip') iconClass = 'bi-file-earmark-zip-fill text-warning';
                else if (ext === '.mp4') iconClass = 'bi-file-earmark-play-fill text-info';
                else if (ext === '.mp3') iconClass = 'bi-file-earmark-music-fill text-info';
                
                previewIcon.querySelector('i').className = 'bi ' + iconClass + ' fs-1 d-block';
                document.getElementById('detail-badge-ext').innerText = ext.replace('.', '');
            }

            const delForm = document.getElementById('sidebar-delete-form');
            if (delForm) {
                delForm.classList.remove('d-none');
                delForm.querySelector('input[name="type"]').value = 'file';
                const delBtn = delForm.querySelector('button');
                delBtn.setAttribute('onclick', `confirmFileDelete(this)`);
            }

            updateToolbar();
        }

        function updateToolbar() {
            const renameBtn = document.getElementById('toolbar-rename-btn');
            const moveBtn = document.getElementById('toolbar-move-btn');
            const downloadBtn = document.getElementById('toolbar-download-btn');
            const deleteBtn = document.getElementById('toolbar-delete-btn');
            const label = document.getElementById('toolbar-selected-label');

            const currentLang = localStorage.getItem('tp-lang') || 'ar';
            const toolbarOptionsText = translations[currentLang]?.mediaToolbarOptions || (currentLang === 'ar' ? "خيارات الإدارة:" : "Management Options:");

            if (!selectedItem) {
                label.innerText = toolbarOptionsText;
                [renameBtn, moveBtn, downloadBtn, deleteBtn].forEach(btn => {
                    btn.classList.add('disabled');
                    btn.style.opacity = '0.5';
                    btn.style.pointerEvents = 'none';
                    if (btn.tagName === 'BUTTON') btn.disabled = true;
                });
                downloadBtn.href = "javascript:void(0)";
                downloadBtn.removeAttribute('download');
                return;
            }

            const badgeText = selectedItem.type === 'folder' 
                ? (translations[currentLang]?.folder || (currentLang === 'ar' ? 'مجلد' : 'Folder')) 
                : (translations[currentLang]?.file || (currentLang === 'ar' ? 'ملف' : 'File'));

            label.innerHTML = `${toolbarOptionsText.replace(':', '')} <span class="badge bg-primary text-white mx-1">${badgeText}</span> : <span class="fw-bold text-primary">${selectedItem.name}</span>`;

            [renameBtn, moveBtn, deleteBtn].forEach(btn => {
                btn.classList.remove('disabled');
                btn.style.opacity = '1';
                btn.style.pointerEvents = 'auto';
                if (btn.tagName === 'BUTTON') btn.disabled = false;
            });

            if (selectedItem.type === 'file') {
                downloadBtn.classList.remove('disabled');
                downloadBtn.style.opacity = '1';
                downloadBtn.style.pointerEvents = 'auto';
                downloadBtn.href = selectedItem.url;
                downloadBtn.setAttribute('download', selectedItem.name);
            } else {
                downloadBtn.classList.add('disabled');
                downloadBtn.style.opacity = '0.5';
                downloadBtn.style.pointerEvents = 'none';
                downloadBtn.href = "javascript:void(0)";
                downloadBtn.removeAttribute('download');
            }
        }

        function triggerRename() {
            if (!selectedItem) return;

            const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            const currentLang = localStorage.getItem('tp-lang') || 'ar';

            // Validation: Reject renaming an existing archive folder (2026-2035) at uploads root
            if (selectedItem.type === 'folder' && !selectedItem.path.includes('/')) {
                const year = parseInt(selectedItem.path);
                if (!isNaN(year) && year >= 2026 && year <= 2035) {
                    Swal.fire({
                        icon: 'error',
                        title: currentLang === 'ar' ? 'خطأ' : 'Error',
                        text: currentLang === 'ar' ? 'غير مسموح بتعديل أسماء مجلدات الأرشيف السنوية.' : 'Modifying annual archive folders names is not allowed.',
                        confirmButtonText: currentLang === 'ar' ? 'حسناً' : 'OK',
                        background: isDark ? '#111827' : '#ffffff',
                        color: isDark ? '#f9fafb' : '#111827',
                        customClass: {
                            confirmButton: 'btn btn-primary px-4 rounded-pill'
                        },
                        buttonsStyling: false
                    });
                    return;
                }
            }
            
            let nameForEdit = selectedItem.name;
            if (selectedItem.type === 'file') {
                const idx = selectedItem.name.lastIndexOf('.');
                if (idx !== -1) {
                    nameForEdit = selectedItem.name.substring(0, idx);
                }
            }

            const title = selectedItem.type === 'folder' 
                ? (currentLang === 'ar' ? 'تغيير اسم المجلد' : 'Rename Folder')
                : (currentLang === 'ar' ? 'تغيير اسم الملف' : 'Rename File');
                
            const inputPlaceholder = currentLang === 'ar' ? 'أدخل الاسم الجديد' : 'Enter new name';
            const confirmBtn = currentLang === 'ar' ? 'تغيير' : 'Rename';
            const cancelBtn = currentLang === 'ar' ? 'إلغاء' : 'Cancel';

            Swal.fire({
                title: title,
                input: 'text',
                inputValue: nameForEdit,
                inputPlaceholder: inputPlaceholder,
                showCancelButton: true,
                confirmButtonText: confirmBtn,
                cancelButtonText: cancelBtn,
                background: isDark ? '#111827' : '#ffffff',
                color: isDark ? '#f9fafb' : '#111827',
                customClass: {
                    confirmButton: 'btn btn-primary px-4 rounded-pill mx-1',
                    cancelButton: 'btn btn-outline-secondary px-4 rounded-pill mx-1'
                },
                buttonsStyling: false,
                inputValidator: (value) => {
                    if (!value || !value.trim()) {
                        return currentLang === 'ar' ? 'الاسم لا يمكن أن يكون فارغاً!' : 'Name cannot be empty!';
                    }
                    // Validation: Reject renaming to an archive folder name (2026-2035) at root
                    if (selectedItem.type === 'folder' && (!currentFolder || currentFolder === "" || currentFolder === "/")) {
                        const year = parseInt(value.trim());
                        if (!isNaN(year) && year >= 2026 && year <= 2035) {
                            return currentLang === 'ar' ? 'غير مسموح بإنشاء مجلدات الأرشيف السنوية يدوياً.' : 'Creating annual archive folders manually is not allowed.';
                        }
                    }
                },
                showLoaderOnConfirm: true,
                preConfirm: (newName) => {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const formData = new FormData();
                    formData.append('folder', currentFolder);
                    formData.append('itemPath', selectedItem.path);
                    formData.append('newName', newName.trim());
                    formData.append('type', selectedItem.type);

                    return fetch('?handler=Rename', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': token
                        }
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(currentLang === 'ar' ? 'فشل الاتصال بالسيرفر.' : 'Failed to connect to server.');
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (!data.success) {
                            throw new Error(data.message || (currentLang === 'ar' ? 'حدث خطأ أثناء تعديل الاسم.' : 'An error occurred during rename.'));
                        }
                        return data;
                    })
                    .catch(error => {
                        Swal.showValidationMessage(error.message);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    location.reload();
                }
            });
        }

        function triggerMove() {
            if (!selectedItem) return;

            const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            const currentLang = localStorage.getItem('tp-lang') || 'ar';

            // Validation: Reject moving a top-level year folder (2026-2035)
            if (selectedItem.type === 'folder' && !selectedItem.path.includes('/')) {
                const year = parseInt(selectedItem.path);
                if (!isNaN(year) && year >= 2026 && year <= 2035) {
                    Swal.fire({
                        icon: 'error',
                        title: currentLang === 'ar' ? 'خطأ' : 'Error',
                        text: currentLang === 'ar' ? 'غير مسموح بنقل مجلدات الأرشيف السنوية.' : 'Moving annual archive folders is not allowed.',
                        confirmButtonText: currentLang === 'ar' ? 'حسناً' : 'OK',
                        background: isDark ? '#111827' : '#ffffff',
                        color: isDark ? '#f9fafb' : '#111827',
                        customClass: {
                            confirmButton: 'btn btn-primary px-4 rounded-pill'
                        },
                        buttonsStyling: false
                    });
                    return;
                }
            }

            const allFolders = @Html.Raw(Model.AllFoldersJson);

            const getParentPath = (path) => {
                if (!path) return "";
                const parts = path.split('/');
                parts.pop();
                return parts.join('/');
            };

            const currentParent = getParentPath(selectedItem.path);
            const options = {};

            allFolders.forEach(f => {
                const cleanF = f === '/' ? '' : f.substring(1);
                
                if (selectedItem.type === 'folder') {
                    if (cleanF === selectedItem.path || cleanF.startsWith(selectedItem.path + '/')) {
                        return;
                    }
                }
                
                if (cleanF === currentParent) {
                    return;
                }

                options[f] = f === '/' ? 'الرئيسية (uploads)' : f;
            });

            if (Object.keys(options).length === 0) {
                Swal.fire({
                    icon: 'info',
                    title: currentLang === 'ar' ? 'تنبيه' : 'Notice',
                    text: currentLang === 'ar' ? 'لا توجد مجلدات وجهة أخرى متاحة لنقل هذا العنصر إليها.' : 'No other target folders available to move this item to.',
                    confirmButtonText: currentLang === 'ar' ? 'حسناً' : 'OK',
                    background: isDark ? '#111827' : '#ffffff',
                    color: isDark ? '#f9fafb' : '#111827',
                    customClass: {
                        confirmButton: 'btn btn-primary px-4 rounded-pill'
                    },
                    buttonsStyling: false
                });
                return;
            }

            const title = currentLang === 'ar' ? 'نقل العنصر' : 'Move Item';
            const confirmBtn = currentLang === 'ar' ? 'نقل' : 'Move';
            const cancelBtn = currentLang === 'ar' ? 'إلغاء' : 'Cancel';

            Swal.fire({
                title: title,
                input: 'select',
                inputOptions: options,
                inputPlaceholder: currentLang === 'ar' ? 'اختر المجلد الوجهة' : 'Select target folder',
                showCancelButton: true,
                confirmButtonText: confirmBtn,
                cancelButtonText: cancelBtn,
                background: isDark ? '#111827' : '#ffffff',
                color: isDark ? '#f9fafb' : '#111827',
                customClass: {
                    confirmButton: 'btn btn-primary px-4 rounded-pill mx-1',
                    cancelButton: 'btn btn-outline-secondary px-4 rounded-pill mx-1'
                },
                buttonsStyling: false,
                inputValidator: (value) => {
                    if (!value) {
                        return currentLang === 'ar' ? 'يرجى اختيار مجلد وجهة!' : 'Please select a target folder!';
                    }
                },
                showLoaderOnConfirm: true,
                preConfirm: (targetFolder) => {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const formData = new FormData();
                    formData.append('folder', currentFolder);
                    formData.append('itemPath', selectedItem.path);
                    formData.append('targetFolder', targetFolder);
                    formData.append('type', selectedItem.type);

                    return fetch('?handler=Move', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': token
                        }
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(currentLang === 'ar' ? 'فشل الاتصال بالسيرفر.' : 'Failed to connect to server.');
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (!data.success) {
                            throw new Error(data.message || (currentLang === 'ar' ? 'حدث خطأ أثناء نقل العنصر.' : 'An error occurred during move.'));
                        }
                        return data;
                    })
                    .catch(error => {
                        Swal.showValidationMessage(error.message);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    location.reload();
                }
            });
        }

