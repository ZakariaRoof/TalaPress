                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    location.reload();
                }
            });
        }

        // Global background click selection clear helper
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.folder-card') && 
                !e.target.closest('.file-card') && 
                !e.target.closest('#media-actions-toolbar') && 
                !e.target.closest('#media-details-sidebar') &&
                !e.target.closest('.swal2-container') &&
                !e.target.closest('.modal')) {
                
                selectedItem = null;
                selectedElement = null;
                document.querySelectorAll('.file-card, .folder-card').forEach(el => el.classList.remove('active'));
                
                document.getElementById('details-empty-state').classList.remove('d-none');
                document.getElementById('details-content-state').classList.add('d-none');
                
                updateToolbar();
            }
        });

        function copyLinkFromInput() {
            const input = document.getElementById('detail-url-input');
            input.select();
            input.setSelectionRange(0, 99999);
            navigator.clipboard.writeText(input.value).then(() => {
                const currentLang = localStorage.getItem('tp-lang') || 'ar';
                showToast(currentLang === 'ar' ? "تم نسخ رابط الملف إلى الحافظة." : "File link copied to clipboard.");
            });
        }

        function formatBytes(bytes) {
            const currentLang = localStorage.getItem('tp-lang') || 'ar';
            if (bytes === 0) return currentLang === 'ar' ? '0 بايت' : '0 Bytes';
            const k = 1024;
            const sizes = currentLang === 'ar' 
                ? ['بايت', 'ك.ب', 'م.ب', 'ج.ب'] 
                : ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        function updateLanguageSpecificElements() {
            const currentLang = localStorage.getItem('tp-lang') || 'ar';
            
            // 1. Update breadcrumbs root
            document.querySelectorAll('[data-tp-i18n="mediaBreadcrumbRoot"]').forEach(el => {
                el.textContent = translations[currentLang]?.mediaBreadcrumbRoot || (currentLang === 'ar' ? "الرئيسية (uploads)" : "Root (uploads)");
            });
            
            // 2. Update folder item counts on cards
            document.querySelectorAll('.folder-item-count').forEach(el => {
                const count = el.getAttribute('data-count');
                el.textContent = currentLang === 'ar' ? `${count} عنصر` : `${count} items`;
            });
            
            // 3. Update file sizes on cards
            document.querySelectorAll('.file-size-text').forEach(el => {
                const size = parseInt(el.getAttribute('data-size'));
                el.textContent = formatBytes(size);
            });
            
            // 4. Update dynamic details & toolbar if there is a selected element
            if (selectedElement) {
                if (selectedItem.type === 'folder') {
                    selectFolder(selectedElement);
                } else {
                    selectFile(selectedElement);
                }
            } else {
                updateToolbar();
            }
        }

        window.addEventListener('tp-lang-changed', (e) => {
            updateLanguageSpecificElements();
        });

        function showToast(message) {
            const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            const Toast = Swal.mixin({
                toast: true,
                position: 'bottom-start',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                background: isDark ? '#111827' : '#ffffff',
                color: isDark ? '#f9fafb' : '#111827',
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });
            Toast.fire({
                icon: 'success',
                title: message
            });
        }

        // =========================================================================
        // AJAX Drag & Drop & Input File Upload Code
        // =========================================================================
        const fileInput = document.getElementById('ajaxFileInput');
        const overlay = document.getElementById('dragDropOverlay');
        const currentFolder = "@Html.Raw(Model.CurrentFolder)";

        window.addEventListener('dragenter', (e) => {
            e.preventDefault();
            overlay.classList.remove('d-none');
            overlay.classList.add('d-flex');
        });

        overlay.addEventListener('dragover', (e) => {
            e.preventDefault();
        });

        overlay.addEventListener('dragleave', (e) => {
            e.preventDefault();
            if (e.clientX === 0 || e.clientY === 0) {
                overlay.classList.add('d-none');
                overlay.classList.remove('d-flex');
            }
        });

        overlay.addEventListener('drop', (e) => {
            e.preventDefault();
            overlay.classList.add('d-none');
            overlay.classList.remove('d-flex');
            
            if (e.dataTransfer.files.length > 0) {
                uploadFiles(e.dataTransfer.files);
            }
        });

        fileInput.addEventListener('change', () => {
            if (fileInput.files.length > 0) {
                uploadFiles(fileInput.files);
            }
        });

        function uploadFiles(filesList) {
            const container = document.getElementById('uploadProgressContainer');
            const bar = document.getElementById('uploadProgressBar');
            const percentText = document.getElementById('uploadPercentText');
            const statusText = document.getElementById('uploadStatusText');

            container.classList.remove('d-none');
            bar.style.width = '0%';
            percentText.innerText = '0%';
            statusText.innerText = `جاري رفع ${filesList.length} من الملفات...`;

            let uploadedCount = 0;
            let errors = [];

            const uploadNext = (index) => {
                if (index >= filesList.length) {
                    bar.style.width = '100%';
                    percentText.innerText = '100%';
                    if (errors.length > 0) {
                        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                        Swal.fire({
                            icon: 'error',
                            title: 'اكتمل الرفع مع وجود أخطاء',
                            html: errors.map(err => `<div class="text-start text-danger mb-1 font-monospace text-xs">${err}</div>`).join(''),
                            background: isDark ? '#111827' : '#ffffff',
                            color: isDark ? '#f9fafb' : '#111827',
                            confirmButtonText: 'حسناً',
                            customClass: {
                                confirmButton: 'btn btn-primary px-4 rounded-pill'
                            },
                            buttonsStyling: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        location.reload();
                    }
                    return;
                }

                const file = filesList[index];
                const formData = new FormData();
                formData.append('file', file);
                formData.append('folder', currentFolder);

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const xhr = new XMLHttpRequest();
                xhr.open('POST', '?handler=Upload&folder=' + encodeURIComponent(currentFolder), true);
                if (token) {
                    xhr.setRequestHeader('RequestVerificationToken', token);
                }

                xhr.upload.onprogress = (event) => {
                    if (event.lengthComputable) {
                        const totalUploaded = uploadedCount + (event.loaded / event.total);
                        const progressPercent = Math.round((totalUploaded / filesList.length) * 100);
                        bar.style.width = `${progressPercent}%`;
                        percentText.innerText = `${progressPercent}%`;
                    }
                };

                xhr.onload = () => {
                    let result = { success: false, message: 'خطأ غير معروف في الاتصال.' };
                    try {
                        result = JSON.parse(xhr.responseText);
                    } catch(e) {}

                    if (xhr.status === 200 && result.success) {
                        uploadedCount++;
                    } else {
                        errors.push(`ملف ${file.name}: ${result.message || 'فشل الرفع'}`);
                    }
                    
                    uploadNext(index + 1);
                };

                xhr.onerror = () => {
                    errors.push(`ملف ${file.name}: خطأ في الاتصال بالشبكة.`);
                    uploadNext(index + 1);
                };

                xhr.send(formData);
            };

            uploadNext(0);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const currentLang = localStorage.getItem('tp-lang') || 'ar';
            updateLanguageSpecificElements();

            // Client-side validation: Reject manual year folder creation (2026-2035) at root
            document.getElementById('newFolderForm')?.addEventListener('submit', (e) => {
                const folderNameInput = document.getElementById('folderName');
                const folderName = folderNameInput ? folderNameInput.value.trim() : '';
                const currentFolder = "@Html.Raw(Model.CurrentFolder)";
                
                if (!currentFolder || currentFolder === "" || currentFolder === "/") {
                    const year = parseInt(folderName);
                    if (!isNaN(year) && year >= 2026 && year <= 2035) {
                        e.preventDefault();
                        
                        // Close bootstrap modal if open
                        const modalEl = document.getElementById('newFolderModal');
                        if (modalEl) {
                            const modalInstance = bootstrap.Modal.getInstance(modalEl);
                            if (modalInstance) modalInstance.hide();
                        }

                        Swal.fire({
                            icon: 'error',
                            title: currentLang === 'ar' ? 'خطأ' : 'Error',
                            text: currentLang === 'ar' ? 'غير مسموح بإنشاء مجلدات الأرشيف السنوية يدوياً.' : 'Creating annual archive folders manually is not allowed.',
                            confirmButtonText: currentLang === 'ar' ? 'حسناً' : 'OK',
                            background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#111827' : '#ffffff',
                            color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#f9fafb' : '#111827',
                            customClass: {
                                confirmButton: 'btn btn-primary px-4 rounded-pill'
                            },
                            buttonsStyling: false
                        });
                    }
                }
            });
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: currentLang === 'ar' ? 'نجاح' : 'Success',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    confirmButtonText: currentLang === 'ar' ? 'حسناً' : 'OK',
                    background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#111827' : '#ffffff',
                    color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#f9fafb' : '#111827',
                    customClass: {
                        confirmButton: 'btn btn-primary px-4 rounded-pill'
                    },
                    buttonsStyling: false
                });
                </text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: currentLang === 'ar' ? 'خطأ' : 'Error',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonText: currentLang === 'ar' ? 'حسناً' : 'OK',
                    background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#111827' : '#ffffff',
                    color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#f9fafb' : '#111827',
                    customClass: {
                        confirmButton: 'btn btn-primary px-4 rounded-pill'
                    },
                    buttonsStyling: false
                });
                </text>
            }
        });
    </script>
}
